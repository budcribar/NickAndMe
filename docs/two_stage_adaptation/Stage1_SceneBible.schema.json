{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nickandme.local/schemas/stage1_scene_bible.json",
  "title": "Stage1_SceneBible",
  "description": "Provider-agnostic scene bible: book story broken into scenes and beats. No video clip grid.",
  "type": "object",
  "required": [
    "schema_version",
    "movie_title",
    "source_book_title",
    "global_production_variables",
    "scenes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "stage1.v1"
    },
    "movie_title": { "type": "string" },
    "source_book_title": { "type": "string" },
    "adaptation_notes": {
      "type": "string",
      "description": "Tone, era, what to cut/compress, spoiler policies."
    },
    "next_scene_number": {
      "type": ["integer", "null"],
      "description": "Resume pointer if partial delivery."
    },
    "cumulative_duration_target_seconds": {
      "type": "number",
      "description": "Sum of scene duration_target_seconds delivered so far."
    },
    "global_production_variables": {
      "type": "object",
      "required": [
        "target_aspect_ratio",
        "resolution",
        "frame_rate",
        "directorial_treatment",
        "total_runtime_target_seconds",
        "character_seed_tokens"
      ],
      "properties": {
        "target_aspect_ratio": { "type": "string" },
        "resolution": {
          "type": "string",
          "description": "Delivery target (e.g. 720p). Draft res may differ in pipeline_config."
        },
        "frame_rate": { "type": "integer" },
        "directorial_treatment": { "type": "string" },
        "total_runtime_target_seconds": {
          "type": "integer",
          "description": "Usually 5400 for 90 minutes."
        },
        "character_seed_tokens": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "description",
              "reference_image_placeholder",
              "voice_profile",
              "voice_label"
            ],
            "properties": {
              "description": { "type": "string" },
              "reference_image_placeholder": { "type": "string" },
              "voice_profile": { "type": "string" },
              "voice_label": { "type": "string" },
              "age_band": { "type": "string" },
              "variant_of": { "type": "string" },
              "display_name_policy": {
                "type": "string",
                "enum": ["ok_anytime", "withheld_until_reveal", "never_on_screen"]
              },
              "canonical_given_name": { "type": "string" },
              "name_reveal_note": { "type": "string" }
            }
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "scene_number",
        "scene_filename",
        "setting",
        "story_day",
        "duration_target_seconds",
        "dramatic_function",
        "summary",
        "story_beats",
        "transition_type",
        "lighting_continuity_token",
        "music_intent"
      ],
      "properties": {
        "scene_number": { "type": "integer", "minimum": 1 },
        "scene_filename": {
          "type": "string",
          "description": "e.g. Scene_02_Day1_Alley_Flashback"
        },
        "setting": {
          "type": "string",
          "description": "Human-readable place + time (not a shot list)."
        },
        "story_day": {
          "type": "string",
          "description": "e.g. Day 1, Night 3, Flashback summer ~age 12"
        },
        "location_type": {
          "type": "string",
          "enum": ["int", "ext", "mixed", "flashback", "dream", "montage"]
        },
        "duration_target_seconds": {
          "type": "integer",
          "minimum": 8,
          "maximum": 134,
          "description": "Story budget for this scene. Stage 2 snaps to legal clip sums."
        },
        "dramatic_function": {
          "type": "string",
          "description": "e.g. establish P, Viking memory, meet-cute, bar explosion"
        },
        "summary": {
          "type": "string",
          "description": "1–3 sentences: what happens and why it matters."
        },
        "source_book_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Book file names, page ranges, or chapter notes for fidelity QA."
        },
        "source_excerpts": {
          "type": "array",
          "description": "Optional passages from book_text_pages_*.txt (or PDF extract) supporting this scene.",
          "items": {
            "type": "object",
            "required": ["source", "excerpt"],
            "properties": {
              "source": { "type": "string" },
              "score": { "type": "string" },
              "excerpt": { "type": "string" }
            }
          }
        },
        "characters_on_screen": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Character_* tokens that may appear."
        },
        "transition_type": {
          "type": "string",
          "description": "cut | dissolve | fade | match_cut | smash ..."
        },
        "lighting_continuity_token": { "type": "string" },
        "wardrobe_notes": {
          "type": "string",
          "description": "Incremental wardrobe vs prior scene."
        },
        "spoiler_constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g. no name tags for Character_P; no reveal of X"
        },
        "story_beats": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/story_beat" },
          "description": "Ordered narrative/visual events. Not yet timed clips."
        },
        "music_intent": {
          "type": "object",
          "required": ["style_description"],
          "properties": {
            "style_description": { "type": "string" },
            "vocal_style": { "type": "string" },
            "mood_arc": {
              "type": "string",
              "description": "How music should move across the scene."
            },
            "lyric_hooks": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional; Stage 2 may expand into timed sections."
            }
          }
        },
        "optional_video_provider_hint": {
          "type": "string",
          "description": "Never required. Do not encode clip lengths here."
        }
      }
    },
    "story_beat": {
      "type": "object",
      "required": [
        "beat_id",
        "intent",
        "visual_event",
        "shot_scale_hint",
        "continuity"
      ],
      "properties": {
        "beat_id": {
          "type": "string",
          "description": "Stable id within scene, e.g. b1, b2."
        },
        "intent": {
          "type": "string",
          "description": "Dramatic purpose of this beat."
        },
        "visual_event": {
          "type": "string",
          "description": "Concrete filmable event (what we must SEE). VO fidelity lives here."
        },
        "shot_scale_hint": {
          "type": "string",
          "description": "ecu|cu|ms|ws|establishing|ots|two_shot — soft preference for Stage 2."
        },
        "primary_subject": {
          "type": "string",
          "description": "Character_* token that should identity-lock first in visual prompts."
        },
        "blocking_notes": {
          "type": "string",
          "description": "Eyeline / who faces whom / camera side — Stage 2 must honor."
        },
        "action_class": {
          "type": "string",
          "enum": [
            "hold",
            "dialogue",
            "small_motion",
            "big_action",
            "establishing",
            "hard_cut",
            "flashback_enter",
            "flashback_exit",
            "montage"
          ],
          "description": "Guides Stage 2 continuation: big_action/hard_cut → none, not extend."
        },
        "time_weight": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 10,
          "description": "Relative weight for duration allocation (default 1). Not seconds."
        },
        "must_not": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Forbidden outcomes (name on badge, ball over wall if VO says window)."
        },
        "audio": {
          "type": "object",
          "properties": {
            "delivery": {
              "type": "string",
              "enum": ["spoken_on_camera", "voiceover_internal", "none"]
            },
            "speaker": { "type": "string" },
            "dialogue": {
              "type": "string",
              "description": "Full or partial line for this beat. Empty if none."
            },
            "ambient_or_sfx": { "type": "string" }
          }
        },
        "continuity": {
          "type": "string",
          "enum": [
            "new_setup",
            "continuous_from_previous_beat",
            "return_to_present",
            "parallel"
          ]
        }
      }
    }
  }
}
