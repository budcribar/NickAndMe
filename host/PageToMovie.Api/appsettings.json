{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PageToMovie": {
    "WorkspaceRoot": "",
    "DefaultModel": "grok-imagine-video",
    "DefaultResolution": "480p",
    "DefaultDurationSeconds": 6,
    "GrokPollSeconds": 5,
    "GrokTimeoutSeconds": 900,
    "UseFakes": false,
    "EnableReadCaches": true,
    "ThreadPool": {
      "MinWorkerThreads": 0,
      "MinIoThreads": 0
    },
    "Capacity": {
      "MaxVideoInFlight": 4,
      "MaxVideoInFlightPerUser": 1,
      "MaxFfmpegInFlight": 2,
      "MaxQueuePerUser": 5
    },
    "Fakes": {
      "VideoMode": "MergeRealistic",
      "VideoDelayMs": 200,
      "FailRate": 0,
      "RateLimitEveryN": 0
    },
    "Auth": {
      "DefaultUserId": "local",
      "AdminUsername": "admin",
      "AdminPassword": "",
      "AdminPasswordHash": "",
      "AdminUserIds": [],
      "UserApiKeys": {},
      // Development default only — host refuses this key outside Development (set PageToMovie_JWT_KEY).
      "JwtSigningKey": "PageToMovie-Dev-Only-Change-Me-32chars!!",
      "JwtHours": 8,
      "AllowDevBypass": false
    }
  },
  "Urls": "http://127.0.0.1:5088"
}
