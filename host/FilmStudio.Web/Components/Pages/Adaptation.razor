@page "/adaptation"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Adaptation</PageTitle>

<h1>Adaptation</h1>
<p class="text-muted">
    Book → Stage 1 scene bible → Stage 2 clip plan.
    <strong>All steps run in native C#</strong>: PdfPig + page render + Grok vision,
    Stage 1 Grok chat, Stage 2 deterministic planner.
</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="LoadAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="LoadAsync">Reload</button>
        @if (JobRunning)
        {
            <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel job</button>
        }
    </div>
</div>

@* ---- Live job (show while running; keep errors visible) ---- *@
@if (_job is not null &&
     (_job.Status is "running" or "error" or "cancelled" ||
      (_job.Status == "done" && _job.Kind is "stage1" or "stage2" or "book_prepare")))
{
    <div class="card mb-3 border-@(_job.Status == "running" ? "primary" : _job.Status == "error" ? "danger" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between flex-wrap gap-2 align-items-center">
                <div>
                    <span class="badge bg-secondary">@_job.Status</span>
                    @if (_job.Kind is { Length: > 0 } k)
                    {
                        <span class="badge bg-info text-dark ms-1">@k</span>
                    }
                    @{
                var jobIdx = Math.Max(_job.Index, _progressIndex);
                var jobTot = Math.Max(_job.Total, _progressTotal);
            }
                    @if (jobTot > 0)
                    {
                        <span class="small text-muted ms-1">@jobIdx / @jobTot</span>
                    }
                    <span class="ms-2 small">@_job.Message</span>
                </div>
                @if (JobRunning)
                {
                    <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel</button>
                }
            </div>
            @if (JobRunning)
            {
                var pct = jobTot > 0
                    ? (int)Math.Round(100.0 * Math.Clamp(jobIdx, 0, jobTot) / Math.Max(1, jobTot))
                    : 40;
                <div class="progress mt-2" style="height: 0.85rem;" role="progressbar"
                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         style="width: @(Math.Clamp(pct, 8, 100))%">
                        @if (jobTot > 0)
                        {
                            <span class="small">@pct%</span>
                        }
                    </div>
                </div>
            }
            @if (_job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 200px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(40))</pre>
            }
        </div>
    </div>
}

@if (_status is null)
{
    <p class="text-muted">Loading adaptation status…</p>
}
else
{
    @* ---- Pipeline progress ---- *@
    <div class="alert @NextStepAlertClass(_status.NextStep) py-2">
        <strong>Next:</strong> @NextStepLabel(_status.NextStep)
        @if (!_status.XaiConfigured)
        {
            <span class="ms-2">· <code>XAI_API_KEY</code> not set on API process (Stage 1 / vision need it)</span>
        }
    </div>

    <div class="row g-3">
        @* ---- 1 Book ---- *@
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header">1) Book</div>
                <div class="card-body">
                    @if (_status.Book.ReadyForStage1)
                    {
                        <div class="alert alert-success py-2 small">
                            Book text ready for Stage 1
                            @if (!string.IsNullOrEmpty(_status.Book.BookKind))
                            {
                                <span>· @_status.Book.BookKind</span>
                            }
                            @if (_status.Book.SuggestedTotalMinutes is int m)
                            {
                                <span>· ~@m min</span>
                            }
                        </div>
                    }
                    else if (_status.Book.PdfExists || _status.Book.BookTextExists)
                    {
                        <div class="alert alert-warning py-2 small">
                            Source on disk but text may need re-import / vision cleanup.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary py-2 small">No book source yet — upload a PDF or TXT.</div>
                    }

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button class="btn btn-primary btn-sm"
                                disabled="@(_busy || JobRunning || (!_status.Book.PdfExists && !_status.Book.BookTextExists))"
                                @onclick="() => PrepareBookAsync(forceVision: false)">
                            Prepare book (extract + auto vision)
                        </button>
                        <button class="btn btn-outline-primary btn-sm"
                                disabled="@(_busy || JobRunning || !_status.XaiConfigured || (!_status.Book.PdfExists && _status.Book.PageImageCount == 0))"
                                @onclick="() => PrepareBookAsync(forceVision: true)">
                            Force Grok vision OCR
                        </button>
                    </div>
                    <p class="small text-muted mb-3">
                        C# path: PdfPig text extract → score quality → if picture book / garbled text,
                        rebuild <code>book_full.txt</code> page-by-page with Grok vision (needs key).
                    </p>

                    <ul class="list-unstyled small mb-3">
                        <li>
                            PDF:
                            @if (_status.Book.PdfExists)
                            {
                                <code>@_status.Book.PdfName</code>
                            }
                            else
                            {
                                <span class="text-muted">none</span>
                            }
                        </li>
                        <li>
                            book_full.txt:
                            @(_status.Book.BookTextExists
                                ? $"{_status.Book.BookTextBytes:N0} bytes · {_status.Book.TextWords ?? 0} words"
                                : "missing")
                        </li>
                        <li>
                            quality: <code>@(_status.Book.TextQuality ?? "—")</code>
                            · garbage @(_status.Book.GarbageScore.ToString("0.00"))
                            · engine <code>@(_status.Book.TextEngine ?? "—")</code>
                        </li>
                        <li>page images: @_status.Book.PageImageCount</li>
                    </ul>

                    @if (_status.Book.Notes.Count > 0)
                    {
                        <ul class="small text-muted">
                            @foreach (var n in _status.Book.Notes.Take(4))
                            {
                                <li>@n</li>
                            }
                        </ul>
                    }

                    <div class="mb-2">
                        <label class="form-label small">Upload PDF or TXT</label>
                        <InputFile OnChange="OnFileSelected" class="form-control form-control-sm" accept=".pdf,.txt" disabled="@_busy" />
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(_busy || _pendingFile is null)" @onclick="UploadAsync">
                        Save upload to project
                    </button>
                    <p class="small text-muted mt-2 mb-0">
                        After upload, click <strong>Prepare book</strong>. Plain TXT unlocks Stage 1 immediately when quality is good.
                    </p>

                    @if (!string.IsNullOrEmpty(_status.Book.Preview))
                    {
                        <details class="mt-3">
                            <summary class="small text-muted">Text preview</summary>
                            <pre class="small bg-light border rounded p-2 mt-1" style="max-height:140px; overflow:auto; white-space:pre-wrap;">@_status.Book.Preview</pre>
                        </details>
                    }
                </div>
            </div>
        </div>

        @* ---- 2 Stage 1 ---- *@
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between">
                    <span>2) Stage 1 — scene bible</span>
                    @if (_status.Stage1.Present && _status.Stage1.SceneCount > 0)
                    {
                        <span class="badge bg-success">ready</span>
                    }
                </div>
                <div class="card-body">
                    @if (_status.Stage1.Present && _status.Stage1.SceneCount > 0)
                    {
                        <p class="small mb-2">
                            <strong>@(_status.Stage1.MovieTitle ?? "Untitled")</strong><br />
                            @_status.Stage1.SceneCount scenes ·
                            @_status.Stage1.BeatCount beats ·
                            @_status.Stage1.CharacterCount chars ·
                            @_status.Stage1.LocationCount locs
                            @if (_status.Stage1.RuntimeSeconds is double rs)
                            {
                                <span>· ~@((int)(rs / 60)) min</span>
                            }
                            @if (!string.IsNullOrEmpty(_status.Stage1.Mtime))
                            {
                                <span class="text-muted">· updated @_status.Stage1.Mtime</span>
                            }
                        </p>
                        @if (_status.Stage1.CastNames.Count > 0)
                        {
                            <p class="small text-muted">Cast: @string.Join(", ", _status.Stage1.CastNames)</p>
                        }
                    }
                    else
                    {
                        <p class="small text-muted">No Stage 1 bible yet (<code>@(_status.Stage1.ScenesFile ?? "scenes.json")</code>).</p>
                    }

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label small">Target minutes</label>
                            <input type="number" class="form-control form-control-sm" min="3" max="180" @bind="_totalMinutes" disabled="@_busy" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Pages / chunk</label>
                            <input type="number" class="form-control form-control-sm" min="5" max="30" @bind="_chunkPages" disabled="@_busy" />
                        </div>
                        <div class="col-8">
                            <label class="form-label small">Model</label>
                            <input class="form-control form-control-sm" @bind="_model" disabled="@_busy" />
                        </div>
                        <div class="col-4 form-check align-self-end mb-2">
                            <input class="form-check-input" type="checkbox" id="s1resume" @bind="_resume" disabled="@_busy" />
                            <label class="form-check-label small" for="s1resume">Resume</label>
                        </div>
                    </div>

                    <button class="btn btn-primary"
                            disabled="@(_busy || JobRunning || !CanRunStage1 || !_status.XaiConfigured)"
                            @onclick="RunStage1Async">
                        @(_status.Stage1.SceneCount > 0 ? "Re-run Stage 1" : "Run Stage 1")
                    </button>
                    @if (!_status.XaiConfigured)
                    {
                        <span class="small text-muted ms-2">Needs XAI_API_KEY on API</span>
                    }
                    else if (!CanRunStage1)
                    {
                        <span class="small text-muted ms-2">Locked until book text exists (Prepare book)</span>
                    }
                    else if (!_status.Book.ReadyForStage1 && _status.Stage1.SceneCount > 0)
                    {
                        <span class="small text-success ms-2">Re-run allowed (existing bible)</span>
                    }
                    <p class="small text-muted mt-2 mb-0">
                        C# Stage1Service (Grok chat) · writes <code>@(_status.Stage1.ScenesFile ?? "scenes.json")</code>.
                        Re-run rewrites seeds (nickname scrub + new prompt) and backs up the previous file.
                    </p>
                </div>
            </div>
        </div>

        @* ---- 3 Stage 2 ---- *@
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span>3) Stage 2 — clip plan</span>
                    @if (_status.Stage2.Stage2Ready && !_status.Stage2.Stage2Stale)
                    {
                        <span class="badge bg-success">ready</span>
                    }
                    else if (_status.Stage2.Stage2Stale)
                    {
                        <span class="badge bg-warning text-dark">stale</span>
                    }
                </div>
                <div class="card-body">
                    @if (_status.Stage2.Stage2Stale)
                    {
                        <div class="alert alert-warning py-2 small">
                            Stage 1 is newer than the blueprint — re-plan before generating video so prompts match the bible.
                        </div>
                    }
                    else if (_status.Stage2.Stage2Ready)
                    {
                        <div class="alert alert-success py-2 small">
                            Stage 2 ready — <strong>@_status.Stage2.Stage2Scenes</strong> scenes ·
                            <strong>@_status.Stage2.Stage2Clips</strong> clips
                            @if (!string.IsNullOrEmpty(_status.Stage2.LastCompletedAt))
                            {
                                <span>· last @_status.Stage2.LastCompletedAt</span>
                            }
                        </div>
                    }
                    else if (_status.Stage2.Stage1Exists)
                    {
                        <div class="alert alert-warning py-2 small">
                            Stage 1 has @_status.Stage2.Stage1Scenes scene(s) but no clip plan yet.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary py-2 small">Finish Stage 1 first.</div>
                    }

                    <p class="small text-muted">
                        Blueprint: <code>@(_status.Stage2.BlueprintFileName ?? "—")</code>
                        @if (!string.IsNullOrEmpty(_status.Stage2.LastRunMessage))
                        {
                            <span>· @_status.Stage2.LastRunMessage</span>
                        }
                        @if (_status.Stage2.ValidationIssueCount > 0)
                        {
                            <span>· @_status.Stage2.ValidationIssueCount validation note(s)</span>
                        }
                    </p>

                    <div class="d-flex flex-wrap gap-2 align-items-end">
                        <div>
                            <label class="form-label small mb-0">Resolution tag</label>
                            <select class="form-select form-select-sm" style="width:auto" @bind="_s2Resolution" disabled="@_busy">
                                <option value="480p">480p</option>
                                <option value="720p">720p</option>
                            </select>
                        </div>
                        <button class="btn btn-primary"
                                disabled="@(_busy || JobRunning || !_status.Stage2.Stage1Exists)"
                                @onclick="RunStage2Async">
                            @(_status.Stage2.Stage2Ready
                                ? (_status.Stage2.Stage2Stale ? "▶ Re-plan Stage 2" : "🔁 Re-generate Stage 2")
                                : "▶ Generate Stage 2 plan")
                        </button>
                        <a class="btn btn-outline-primary" href="scenes">Open Scenes →</a>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        Deterministic C# planner — no API key. Backs up existing blueprint before write.
                    </p>
                </div>
            </div>
        </div>

        @* ---- Stage 1 scene list ---- *@
        @if (_status.Stage1.Scenes.Count > 0)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header">Stage 1 scenes preview</div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:4rem">#</th>
                                        <th>Setting</th>
                                        <th style="width:5rem">Beats</th>
                                        <th style="width:5rem">Dur</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in _status.Stage1.Scenes)
                                    {
                                        <tr>
                                            <td><code>S@s.SceneNumber.ToString("D2")</code></td>
                                            <td class="small">@(string.IsNullOrEmpty(s.Setting) ? "—" : s.Setting)</td>
                                            <td class="small">@s.BeatCount</td>
                                            <td class="small text-muted">@(s.DurationSeconds is double d ? $"{d:0}s" : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "Buster";
    private List<string> _projectIds = new();
    private AdaptationStatus? _status;
    private JobSnapshot? _job;
    private IBrowserFile? _pendingFile;

    private int _totalMinutes = 15;
    private int _chunkPages = 10;
    private string _model = "grok-4.5";
    private bool _resume;
    private string _s2Resolution = "720p";
    private CancellationTokenSource? _pollCts;
    /// <summary>Parsed from log lines when SignalR/API snapshot omits Index/Total.</summary>
    private int _progressIndex;
    private int _progressTotal;

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string> { "Buster" };
            if (projs?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];

            try { await Hub.StartAsync(); } catch { /* optional */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        AbsorbProgressFromSnapshot(snap);
        AbsorbProgressFromLine(snap.Message);
        if (snap.Status is "done" or "error" or "cancelled")
        {
            _pollCts?.Cancel();
            if (snap.Status == "done" && _progressTotal > 0)
                _progressIndex = _progressTotal;
            _ = InvokeAsync(async () =>
            {
                await SoftLoadAsync();
                if (snap.Status == "done")
                    _message = snap.Message ?? "Job finished";
                else if (snap.Status == "error")
                    _error = snap.Error ?? snap.Message ?? "Job failed";
                StateHasChanged();
            });
        }
        else
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void OnJobLog(string line)
    {
        if (_job is null)
        {
            _job = new JobSnapshot
            {
                Status = "running",
                Message = line,
                Log = new List<string> { line },
            };
        }
        else
        {
            _job.Message = line;
            if (_job.Log.Count == 0 || _job.Log[^1] != line)
            {
                _job.Log.Add(line);
                if (_job.Log.Count > 120)
                    _job.Log = _job.Log.TakeLast(120).ToList();
            }
        }
        AbsorbProgressFromLine(line);
        // Keep snapshot Index/Total in sync for display when only log events arrive
        if (_job is not null && _progressTotal > 0)
        {
            _job.Index = Math.Max(_job.Index, _progressIndex);
            _job.Total = Math.Max(_job.Total, _progressTotal);
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private void AbsorbProgressFromSnapshot(JobSnapshot snap)
    {
        if (snap.Total > 0)
            _progressTotal = Math.Max(_progressTotal, snap.Total);
        if (snap.Index > 0)
            _progressIndex = Math.Max(_progressIndex, snap.Index);
    }

    /// <summary>
    /// Parse "chunk 2/5", "Stage 1: 3 book chunk(s)", "Grok vision 4/16" from live lines.
    /// </summary>
    private void AbsorbProgressFromLine(string? line)
    {
        if (string.IsNullOrWhiteSpace(line)) return;

        var mChunks = System.Text.RegularExpressions.Regex.Match(
            line, @"Stage 1:\s+(\d+)\s+book chunk", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (mChunks.Success && int.TryParse(mChunks.Groups[1].Value, out var n) && n > 0)
        {
            _progressTotal = Math.Max(_progressTotal, n);
            return;
        }

        var m = System.Text.RegularExpressions.Regex.Match(
            line, @"(?:chunk|vision)\s+(\d+)\s*/\s*(\d+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (!m.Success)
            m = System.Text.RegularExpressions.Regex.Match(
                line, @"(\d+)\s*/\s*(\d+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (m.Success &&
            int.TryParse(m.Groups[1].Value, out var idx) &&
            int.TryParse(m.Groups[2].Value, out var tot) &&
            tot > 0 && idx <= tot + 2)
        {
            _progressIndex = Math.Max(_progressIndex, idx);
            _progressTotal = Math.Max(_progressTotal, tot);
        }
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetAdaptationAsync(_projectId);
            _status = dto?.Adaptation;
            ApplyDefaultsFromStatus();
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = null;
        }
        finally { _busy = false; }
    }

    private async Task SoftLoadAsync()
    {
        try
        {
            var dto = await Engine.GetAdaptationAsync(_projectId);
            _status = dto?.Adaptation;
            ApplyDefaultsFromStatus();
        }
        catch { /* ignore */ }
    }

    private void ApplyDefaultsFromStatus()
    {
        if (_status?.Book.SuggestedTotalMinutes is int m && m > 0)
            _totalMinutes = Math.Clamp(m, 3, 180);
        if (_status?.Book.SuggestedChunkPages is int c && c > 0)
            _chunkPages = Math.Clamp(c, 5, 30);
    }

    /// <summary>
    /// First-run needs ReadyForStage1; re-run allowed when bible + book text already exist
    /// (API status also flips ReadyForStage1 in that case).
    /// </summary>
    private bool CanRunStage1 =>
        _status is not null &&
        (_status.Book.ReadyForStage1 ||
         (_status.Stage1.Present &&
          _status.Stage1.SceneCount > 0 &&
          _status.Book.BookTextExists));

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingFile = e.File;
        _message = $"Selected {e.File.Name} ({e.File.Size:N0} bytes)";
    }

    private async Task UploadAsync()
    {
        if (_pendingFile is null) return;
        _busy = true;
        _error = null;
        try
        {
            const long max = 80 * 1024 * 1024;
            await using var stream = _pendingFile.OpenReadStream(max);
            await Engine.UploadBookAsync(_projectId, _pendingFile.Name, stream);
            _message = $"Saved {_pendingFile.Name}";
            _pendingFile = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task PrepareBookAsync(bool forceVision)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await EnsureHubAsync();
            await Engine.StartBookPrepareAsync(
                _projectId,
                forceExtract: true,
                forceVision: forceVision,
                autoVision: true);
            _message = forceVision
                ? "Book prepare started (force Grok vision OCR) — watch the job log"
                : "Book prepare started (PdfPig extract + auto vision) — watch the job log";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            StartJobPolling();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RunStage1Async()
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            // Connect SignalR BEFORE starting so chunk progress is not missed
            await EnsureHubAsync();
            _progressIndex = 0;
            _progressTotal = 0;
            await Engine.StartStage1Async(new StartStage1Request
            {
                ProjectId = _projectId,
                ChunkPages = _chunkPages,
                TotalMinutes = _totalMinutes,
                Model = _model,
                Resume = _resume,
            });
            _message = "Stage 1 started — live log below (Grok can take minutes per chunk)";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            AbsorbProgressFromSnapshot(_job ?? new JobSnapshot());
            StartJobPolling();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RunStage2Async()
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await EnsureHubAsync();
            await Engine.StartStage2Async(new StartStage2Request
            {
                ProjectId = _projectId,
                Resolution = _s2Resolution,
                Scenes = "all",
            });
            _message = "Stage 2 planner started — live log below";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            StartJobPolling();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    /// <summary>Poll /api/jobs while running so progress still updates if SignalR drops.</summary>
    private void StartJobPolling()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!ct.IsCancellationRequested)
                {
                    await Task.Delay(1500, ct);
                    var jobs = await Engine.GetJobAsync(ct);
                    var snap = jobs?.Job;
                    if (snap is null) continue;
                    await InvokeAsync(() =>
                    {
                        _job = snap;
                        AbsorbProgressFromSnapshot(snap);
                        AbsorbProgressFromLine(snap.Message);
                        if (_job is not null && _progressTotal > 0)
                        {
                            _job.Index = Math.Max(_job.Index, _progressIndex);
                            _job.Total = Math.Max(_job.Total, _progressTotal);
                        }
                        StateHasChanged();
                    });
                    if (snap.Status is "done" or "error" or "cancelled" or "idle")
                    {
                        if (snap.Status is "done" or "error" or "cancelled")
                            await InvokeAsync(async () => { await SoftLoadAsync(); StateHasChanged(); });
                        break;
                    }
                }
            }
            catch (OperationCanceledException) { /* expected */ }
            catch { /* ignore poll errors */ }
        }, CancellationToken.None);
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task EnsureHubAsync()
    {
        if (Hub.IsConnected) return;
        try { await Hub.StartAsync(); } catch { /* ignore */ }
    }

    private static string NextStepLabel(string step) => step switch
    {
        "import_book" => "Import a PDF or TXT into the project source folder",
        "fix_book_text" => "Prepare book (extract + Grok vision OCR) or paste a clean book_full.txt",
        "run_stage1" => "Run Stage 1 to build the scene bible",
        "run_stage2" => "Generate Stage 2 clip plan",
        "replan_stage2" => "Re-plan Stage 2 (Stage 1 changed)",
        "generate_clips" => "Open Scenes and generate video clips",
        _ => "Pipeline looks complete — refine on Scenes / Characters",
    };

    private static string NextStepAlertClass(string step) => step switch
    {
        "generate_clips" or "done" => "alert-success",
        "replan_stage2" or "fix_book_text" => "alert-warning",
        _ => "alert-info",
    };

    public async ValueTask DisposeAsync()
    {
        _pollCts?.Cancel();
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Task.CompletedTask;
    }
}
