@page "/admin/login"
@rendermode InteractiveServer
@inject EngineApiClient Api
@inject AdminSessionService Session
@inject NavigationManager Nav

<PageTitle>Admin login — Film Studio</PageTitle>

<div class="container py-4" style="max-width: 28rem;">
    <h1 class="h3 mb-3">Admin login</h1>
    <p class="text-muted small">
        Signs in against the API (<code>POST /api/auth/login</code>). JWT is stored in browser session storage.
        Dev default: username <code>admin</code>, password <code>admin</code>.
    </p>

    @if (_redirecting)
    {
        <p class="text-muted">Signed in as <strong>@Session.UserId</strong>. Opening dashboard…</p>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input class="form-control" @bind="_username" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="_password" autocomplete="current-password"
                   @onkeydown="OnKeyDown" />
        </div>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }
        <button type="button" class="btn btn-primary" @onclick="LoginAsync" disabled="@_busy">
            @(_busy ? "Signing in…" : "Sign in")
        </button>
        <p class="small text-muted mt-3 mb-0">
            Use Web launch profile <strong>http</strong> (<code>http://localhost:5079</code>).
        </p>
    }
</div>

@code {
    private string _username = "admin";
    private string _password = "admin";
    private string? _error;
    private bool _busy;
    private bool _redirecting;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Session.EnsureHydratedAsync();
        if (Session.IsAdmin)
        {
            _redirecting = true;
            StateHasChanged();
            Nav.NavigateTo("/admin", forceLoad: false);
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginAsync();
    }

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var resp = await Api.LoginAsync(_username ?? "", _password ?? "");
            if (resp is null || !resp.Ok || string.IsNullOrWhiteSpace(resp.Token))
            {
                _error = resp?.Error
                         ?? "Login failed — is FilmStudio.Api running on http://127.0.0.1:5088?";
                return;
            }

            Session.SetSession(resp.Token!, resp.UserId, resp.Roles, resp.ExpiresAt);
            if (!Session.IsAdmin)
            {
                try
                {
                    var me = await Api.GetMeAsync();
                    if (me?.IsAdmin == true)
                        Session.SetSession(resp.Token!, me.UserId ?? resp.UserId, me.Roles, resp.ExpiresAt);
                }
                catch { /* ignore */ }
            }

            if (!Session.IsAdmin)
            {
                Session.Clear();
                _error = "Account is not admin. Check FilmStudio:Auth settings.";
                return;
            }

            _redirecting = true;
            Nav.NavigateTo("/admin");
        }
        catch (HttpRequestException ex)
        {
            _error = $"Cannot reach API: {ex.Message}. Start FilmStudio.Api (port 5088).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
