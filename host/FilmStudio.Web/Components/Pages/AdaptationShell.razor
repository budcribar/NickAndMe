@* Shared header + step strip + job log for Adaptation step pages *@
@inject AdminSessionService Session

@if (Host is null)
{
    return;
}

<div class="d-flex flex-wrap align-items-baseline justify-content-between gap-2 mb-1">
    <h1 class="mb-0">Adaptation</h1>
    @if (!string.IsNullOrEmpty(Host.ProjectLabel))
    {
        <span class="text-muted small">@Host.ProjectLabel</span>
    }
</div>
<p class="text-muted mb-3">Import → screenplay → characters → shot plan → scenes.</p>

@* ---- Step strip ---- *@
<nav class="nav nav-pills flex-wrap gap-1 mb-3" aria-label="Adaptation steps">
    <a class="nav-link @(Step == "import" || Step == "book" ? "active" : "")"
       href="adaptation/import">1 · Import</a>
    <a class="nav-link @(Step == "screenplay" ? "active" : "") @(!OutlineEnabled ? "disabled" : "")"
       href="@(OutlineEnabled ? "adaptation/screenplay" : "adaptation/import")"
       @onclick:preventDefault="@(!OutlineEnabled)"
       title="@(OutlineEnabled ? null : "Import a source first")">2 · Screenplay</a>
    <a class="nav-link @(Step == "characters" ? "active" : "") @(!ShotsEnabled ? "disabled" : "")"
       href="@(ShotsEnabled ? "characters" : "adaptation/screenplay")"
       @onclick:preventDefault="@(!ShotsEnabled)"
       title="@(ShotsEnabled ? "Pin cast likeness before clips" : "Approve a screenplay first")">3 · Characters</a>
    <a class="nav-link @(Step == "shots" ? "active" : "") @(!ShotsEnabled ? "disabled" : "")"
       href="@(ShotsEnabled ? "adaptation/shots" : "adaptation/screenplay")"
       @onclick:preventDefault="@(!ShotsEnabled)"
       title="@(ShotsEnabled ? null : "Approve a screenplay first")">4 · Shot plan</a>
</nav>

@if (!string.IsNullOrEmpty(Host.Error))
{
    <div class="alert alert-danger">@Host.Error</div>
}
@* Hide completion/status noise while Import or a job is still running *@
@if (!string.IsNullOrEmpty(Host.Message) && !Host.SuppressGuidanceBanners)
{
    <div class="alert alert-info">@Host.Message</div>
}

@* Job panel: skip on Import (progress lives in the Import card). Show on screenplay/shots. *@
@if (ShowJobPanel)
{
    <div class="card mb-3 border-@(Host.Job!.Status == "running" ? "primary" : Host.Job.Status == "error" ? "danger" : "secondary")"
         data-testid="job-panel"
         data-job-status="@Host.Job.Status"
         data-job-kind="@(Host.Job.Kind ?? "")"
         data-job-running="@(Host.JobRunning ? "true" : "false")">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between flex-wrap gap-2 align-items-center">
                <div>
                    <span class="badge bg-secondary" data-testid="job-status">@Host.Job.Status</span>
                    @if (Host.Job.Kind is { Length: > 0 } k)
                    {
                        <span class="badge bg-info text-dark ms-1">@AdaptationPageBase.JobKindLabel(k)</span>
                    }
                    @{
                        var jobIdx = Math.Max(Host.Job.Index, Host.ProgressIndex);
                        var jobTot = Math.Max(Host.Job.Total, Host.ProgressTotal);
                        var waiting = Host.JobRunning && AdaptationPageBase.IsJobInFlightMessage(Host.Job.Message);
                        var displayIdx = waiting && jobIdx >= jobTot && jobTot > 0
                            ? Math.Max(0, jobTot - 1)
                            : jobIdx;
                    }
                    @if (jobTot > 0)
                    {
                        <span class="small text-muted ms-1">
                            @displayIdx / @jobTot completed
                            @if (waiting)
                            {
                                <text> · in progress</text>
                            }
                        </span>
                    }
                    <span class="ms-2 small">@Host.Job.Message</span>
                </div>
                @if (Host.JobRunning)
                {
                    <button class="btn btn-sm btn-outline-danger" disabled="@Host.Busy" @onclick="Host.CancelAsync">Cancel</button>
                }
            </div>
            @if (Host.JobRunning)
            {
                int pct;
                if (jobTot <= 0)
                    pct = 35;
                else if (waiting)
                    pct = (int)Math.Round(100.0 * (displayIdx + 0.35) / jobTot);
                else
                    pct = (int)Math.Round(100.0 * Math.Clamp(displayIdx, 0, jobTot) / jobTot);
                pct = Math.Clamp(pct, jobTot > 0 ? 5 : 8, Host.JobRunning ? 92 : 100);
                <div class="progress mt-2" style="height: 0.85rem;" role="progressbar"
                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         style="width: @pct%">
                        <span class="small">@pct%</span>
                    </div>
                </div>
            }
            @if (Host.Job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 200px; overflow: auto;">@string.Join("\n", Host.Job.Log.TakeLast(40))</pre>
            }
        </div>
    </div>
}

@if (Host.Status is null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @* Skip “Next” when it only restates the step you’re already on *@
    @if (ShowNextBanner)
    {
        <div class="alert @AdaptationPageBase.NextStepAlertClass(Host.Status.NextStep) py-2">
            <strong>Next:</strong> @AdaptationPageBase.NextStepLabel(Host.Status.NextStep)
            @if (!Host.Status.XaiConfigured && Host.Status.NextStep is "draft_screenplay" or "run_stage1" or "run_stage2" or "replan_stage2")
            {
                <span class="ms-2">· <a href="configuration">Connect service</a></span>
            }
        </div>
    }

    @ChildContent
}

@code {
    [Parameter, EditorRequired] public AdaptationPageBase Host { get; set; } = null!;
    [Parameter, EditorRequired] public string Step { get; set; } = "book";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool OutlineEnabled =>
        Host.Status is not null &&
        (Host.Status.Screenplay.DraftExists ||
         Host.Status.Book.ReadyForStage1 ||
         Host.Status.Book.BookTextExists ||
         Host.Status.Book.PdfExists ||
         (Host.Status.Stage1.Present && Host.Status.Stage1.SceneCount > 0));

    private bool ShotsEnabled =>
        Host.Status is not null &&
        Host.Status.Screenplay.ReadyForShots;

    /// <summary>
    /// Technical job log is admin-only. Operators use Import progress / simple status.
    /// Import page never shows this card (progress lives in the Import card).
    /// </summary>
    private bool ShowJobPanel =>
        Session.IsAdmin &&
        Host.Job is not null &&
        Step is not ("import" or "book") &&
        (Host.Job.Status is "running" or "error" or "cancelled" ||
         (Host.Job.Status == "done" && Host.Job.Kind is "stage1" or "stage2" or "book_prepare"));

    protected override async Task OnInitializedAsync()
    {
        try { await Session.EnsureHydratedAsync(); } catch { /* optional */ }
    }

    /// <summary>
    /// Hide the banner when the current step already is the next action
    /// (avoids “Next: import…” on the Import page).
    /// </summary>
    private bool ShowNextBanner
    {
        get
        {
            if (Host.Status is null) return false;
            // Never show “Next: approve…” while a draft is still being written
            if (Host.SuppressGuidanceBanners) return false;

            var next = Host.Status.NextStep ?? "";
            var step = Step ?? "";
            if (step is "import" or "book")
            {
                // On import: only after the pipeline is idle and they should leave Import
                // (draft exists → continue to screenplay). Don't say “approve” mid-import.
                if (next is "sign_screenplay" or "generate_clips" or "run_stage2" or "replan_stage2"
                    or "pin_characters")
                    return Host.Status.Screenplay.DraftExists;
                return next is "draft_screenplay" or "run_stage1";
            }
            if (step == "screenplay")
            {
                // Hide when the action is already “edit/approve screenplay”
                return next is not ("sign_screenplay" or "draft_screenplay" or "run_stage1");
            }
            if (step == "shots")
            {
                // Hide plain “build shot plan”; keep replan / go elsewhere / generate
                return next is not ("run_stage2" or "pin_characters");
            }
            return true;
        }
    }

}
