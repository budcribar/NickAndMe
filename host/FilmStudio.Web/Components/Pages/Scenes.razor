@page "/scenes"
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@inject ActiveProjectState ActiveProject
@inject AdminSessionService Session
@using FilmStudio.Core.Models

<PageTitle>Scenes &amp; Clips</PageTitle>

<h1>Scenes &amp; Clips</h1>

@if (_gateChecked && !ActiveProject.CanScenes)
{
    <p class="text-muted mb-3">
        @(string.IsNullOrWhiteSpace(ActiveProject.ScenesBlockedReason)
            ? "Finish the shot plan first."
            : ActiveProject.ScenesBlockedReason)
        <a href="adaptation/shots">Open shot plan →</a>
    </p>
}
else
{

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}
@if (_castChecked && !CastReady)
{
    <div class="alert alert-warning" data-testid="scenes-cast-gate">
        <strong>Cast not approved yet</strong> — video generation is blocked so you do not waste API spend.
        Every character needs an approved <em>voice</em> and (for on-screen roles) a <em>locked image</em>.
        @if (_castReadyCount is int cr && _castTotal is int ct)
        {
            <span> Progress: @cr/@ct ready.</span>
        }
        @if (_castMissing.Count > 0)
        {
            <span> Still missing: @string.Join(", ", _castMissing.Take(8))@(_castMissing.Count > 8 ? "…" : "").</span>
        }
        <a class="alert-link ms-1" href="characters">Open Characters →</a>
    </div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label">Character</label>
        <select class="form-select" @bind="_filterCharacter" disabled="@_busy">
            <option value="">All characters</option>
            @foreach (var c in CharacterOptions)
            {
                <option value="@c">@ShortChar(c)</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Location</label>
        <select class="form-select" @bind="_filterLocation" disabled="@_busy">
            <option value="">All locations</option>
            @foreach (var loc in LocationOptions)
            {
                <option value="@loc">@ShortLoc(loc)</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Setting text</label>
        <input class="form-control" @bind="_filter" @bind:event="oninput" disabled="@_busy" placeholder="e.g. pajamas" />
    </div>
    <div class="col-md-3 d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" data-testid="scenes-reload" disabled="@_busy" @onclick="ReloadListAsync">Reload</button>
        <button class="btn btn-success" data-testid="scenes-play-wip" disabled="@(_busy || JobRunning || (!_wipExists && !_wipCanBuild))"
                @onclick="PlayWipAsync"
                title="@WipPlayTitle">
            @(_showWipPlayer && _wipExists && !_wipStale ? "Hide WIP" : _wipStale || !_wipExists ? "▶ Play WIP (refresh)" : "▶ Play WIP")
        </button>
        @if (HasActiveFilters)
        {
            <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="ClearFilters">Clear filters</button>
        }
        @if (_selectedScene is int)
        {
            <button class="btn btn-outline-primary" disabled="@_busy" @onclick="BackToListAsync">← All scenes</button>
        }
    </div>
</div>

@if (_showWipPlayer && _wipExists)
{
    <div class="card mb-3 border-success">
        <div class="card-header d-flex justify-content-between align-items-center py-2 flex-wrap gap-2">
            <span>
                WIP movie <code class="small">@(_wipPath ?? "assets/movie_wip.mp4")</code>
                @if (_wipStale)
                {
                    <span class="badge bg-warning text-dark ms-1">stale</span>
                }
            </span>
            @if (!string.IsNullOrEmpty(_wipUpdatedAt))
            {
                <span class="small text-muted">@_wipUpdatedAt · @FormatBytes(_wipBytes)</span>
            }
        </div>
        <div class="card-body py-2">
            @if (!string.IsNullOrEmpty(_wipReason) && _wipStale)
            {
                <p class="small text-warning mb-2">@_wipReason</p>
            }
            <video controls playsinline autoplay
                   style="width:100%;max-height:70vh;background:#000;border-radius:0.35rem;"
                   src="@CacheBust(Engine.WipMovieUrl(_projectId))"
                   @key="_wipVideoKey"
                   onloadeddata="this.play().catch(function(){})">
                Your browser does not support HTML5 video.
            </video>
            <p class="small text-muted mb-0 mt-2">
                <strong>Play WIP</strong> auto-refreshes if out of date (mux only — no clip re-gen).
                <a href="@Engine.WipMovieUrl(_projectId)" target="_blank" rel="noopener">Open in new tab</a>
            </p>
        </div>
    </div>
}

@if (_showScenePlayer && _playingScene is int playSn && !IsSceneGenBusy(playSn))
{
    <div class="card mb-3 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center py-2">
            <span>Scene composite <code class="small">S@(playSn.ToString("D2"))</code></span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="HideScenePlayer">Hide</button>
        </div>
        <div class="card-body py-2">
            <video controls playsinline autoplay
                   style="width:100%;max-height:70vh;background:#000;border-radius:0.35rem;"
                   src="@CacheBust(Engine.CompositeVideoUrl(_projectId, playSn))"
                   @key="_sceneVideoKey"
                   onloadeddata="this.play().catch(function(){})">
                Your browser does not support HTML5 video.
            </video>
            <p class="small text-muted mb-0 mt-2">
                If empty/404, use <strong>Rebuild scene</strong> (needs clips on disk).
                <a href="@Engine.CompositeVideoUrl(_projectId, playSn)" target="_blank" rel="noopener">Open in new tab</a>
            </p>
        </div>
    </div>
}
else if (_showScenePlayer && _playingScene is int busySn && IsSceneGenBusy(busySn))
{
    <div class="card mb-3 border-secondary">
        <div class="card-body py-2 small text-muted">
            Scene composite hidden while generating <code>S@(busySn.ToString("D2"))</code>.
            <button type="button" class="btn btn-link btn-sm p-0 align-baseline ms-1" @onclick="HideScenePlayer">Dismiss</button>
        </div>
    </div>
}

@* Operator: short gen progress only. Admin: full job card + log + My jobs. *@
@if (ShowOperatorGenProgress && _job is not null)
{
    <div class="card mb-3 border-primary">
        <div class="card-body py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="small">
                @OperatorGenStatusText(_job)
                @if (_job.Total > 0)
                {
                    <span class="text-muted">· @_job.Index / @_job.Total</span>
                    @if (KeyFormatting.EstimateTimeRemaining(_job.StartedAt, _job.Index, _job.Total) is { } eta)
                    {
                        <span class="text-muted">· @eta</span>
                    }
                }
            </span>
            <div class="d-flex gap-2">
                @if (JobRunning)
                {
                    <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel</button>
                }
                <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Refresh</button>
            </div>
        </div>
    </div>
}
else if (ShowOperatorGenPartial && _job is not null)
{
    <div class="alert alert-warning py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="small">@(_job.Message ?? "Some clips finished; others failed.")</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Refresh</button>
    </div>
}
else if (ShowOperatorGenError && _job is not null)
{
    <div class="alert alert-danger py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="small">@(_job.Error ?? _job.Message ?? "Generation failed")</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Refresh</button>
    </div>
}
else if (Session.IsAdmin && _job is not null &&
         (_job.Status is "running" or "queued" or "done" or "partial" or "error" or "cancelled"))
{
    <div class="card mb-3 border-@(_job.Status is "running" or "queued" ? "primary" : _job.Status == "error" ? "danger" : _job.Status == "partial" ? "warning" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <span class="badge bg-secondary">@_job.Status</span>
                    @if (_job.Kind is { Length: > 0 } k)
                    {
                        <span class="badge bg-info text-dark ms-1">@k</span>
                    }
                    @if (_job.Scene is int sn)
                    {
                        <span class="ms-1">S@(sn.ToString("D2"))</span>
                    }
                    @if (_job.Clip is int cn)
                    {
                        <span>C@cn</span>
                    }
                    @if (_job.Total > 0)
                    {
                        <span class="ms-1 text-muted">@_job.Index / @_job.Total</span>
                        @if (KeyFormatting.EstimateTimeRemaining(_job.StartedAt, _job.Index, _job.Total) is { } eta)
                        {
                            <span class="ms-1 text-muted">· @eta</span>
                        }
                    }
                    <span class="ms-2 small">@_job.Message</span>
                </div>
                <div class="d-flex gap-2">
                    @if (_job.Status is "running" or "queued")
                    {
                        <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel</button>
                    }
                    <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Refresh list</button>
                </div>
            </div>
            @if (_job.Status is "running" or "queued" && _job.Total > 0)
            {
                var pct = (int)Math.Round(_job.Index * 100.0 / Math.Max(1, _job.Total));
                <div class="progress mt-2" style="height: 0.85rem;" role="progressbar"
                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         style="width: @(Math.Clamp(pct, 5, 100))%"></div>
                </div>
            }
            @* Technical job log — admin only; operators get the terse status line above. *@
            @if (Session.IsAdmin && _job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 120px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(20))</pre>
            }
        </div>
    </div>
}

@if (_selectedScene is null)
{
    @* ---- Scene list ---- *@
    @if (_scenes is null)
    {
        <p class="text-muted">Loading scenes…</p>
    }
    else if (_scenes.Count == 0)
    {
        <p class="text-muted">
            No scenes in the shot plan yet.
            <a href="adaptation/shots">Open shot plan →</a>
        </p>
    }
    else
    {
        <div class="batch-panel mb-3">
            <div class="batch-panel__head">
                <div class="batch-panel__title">
                    <span class="batch-panel__icon" aria-hidden="true">▶</span>
                    <div>
                        <div class="batch-panel__heading">Batch generate</div>
                        <div class="batch-panel__sub">
                            @FilteredScenes.Count scene@(FilteredScenes.Count == 1 ? "" : "s") shown
                            @if (HasActiveFilters)
                            {
                                <span> of @_scenes.Count</span>
                            }
                            · @_scenes.Sum(s => s.ClipsOnDisk)/@_scenes.Sum(s => s.ClipCount) clips on disk
                            @if (IncompleteCount > 0)
                            {
                                <span class="batch-panel__warn"> · @IncompleteCount incomplete</span>
                            }
                            @if (Session.IsAdmin && _myJobs.Count > 0)
                            {
                                <span> · <strong>@_myJobs.Count</strong> job@(_myJobs.Count == 1 ? "" : "s")</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="batch-panel__stats">
                    <div class="batch-stat @(_selected.Count > 0 ? "batch-stat--active" : "")">
                        <span class="batch-stat__value">@_selected.Count</span>
                        <span class="batch-stat__label">selected</span>
                    </div>
                    <div class="batch-stat @(_selected.Count > 0 ? "batch-stat--clips" : "")">
                        <span class="batch-stat__value">~@EstimateSelectedClips()</span>
                        <span class="batch-stat__label">clips</span>
                    </div>
                </div>
            </div>

            <div class="batch-panel__body">
                <div class="batch-panel__select">
                    <span class="batch-panel__select-label">Select</span>
                    <div class="batch-chip-group" role="group" aria-label="Selection shortcuts">
                        <button type="button"
                                class="batch-chip @(SelectionMode == "incomplete" ? "batch-chip--on" : "")"
                                disabled="@(_busy || IncompleteCount == 0)"
                                @onclick="SelectIncomplete"
                                title="Scenes with missing clips in the current filter">
                            Incomplete
                            @if (IncompleteCount > 0)
                            {
                                <span class="batch-chip__count">@IncompleteCount</span>
                            }
                        </button>
                        <button type="button"
                                class="batch-chip @(SelectionMode == "all" ? "batch-chip--on" : "")"
                                disabled="@(_busy || FilteredScenes.Count == 0)"
                                @onclick="SelectAll"
                                title="All scenes in the current filter">
                            All shown
                            <span class="batch-chip__count">@FilteredScenes.Count</span>
                        </button>
                        <button type="button"
                                class="batch-chip batch-chip--muted @(_selected.Count == 0 ? "batch-chip--disabled" : "")"
                                disabled="@(_busy || _selected.Count == 0)"
                                @onclick="ClearSelection"
                                title="Clear selection">
                            Clear
                        </button>
                    </div>
                </div>

                <div class="batch-panel__actions">
                    <label class="batch-toggle" title="Skip clips already on disk">
                        <input type="checkbox" class="form-check-input" @bind="_onlyMissing" disabled="@_busy" />
                        <span>Only missing clips</span>
                    </label>

                    <div class="d-flex align-items-center gap-1">
                        <label class="small text-muted mb-0" for="genResBatch">Resolution</label>
                        <select id="genResBatch"
                                data-testid="scenes-resolution"
                                class="form-select form-select-sm"
                                style="width:auto"
                                @bind="_genResolution"
                                @bind:after="RefreshCostEstimateAsync"
                                disabled="@_busy">
                            <option value="480p">480p</option>
                            <option value="720p">720p</option>
                            <option value="1080p">1080p</option>
                        </select>
                    </div>

                    <button type="button"
                            data-testid="scenes-generate-batch"
                            class="btn batch-go @(_selected.Count > 0 && !JobRunning && CastReady ? "batch-go--ready" : "")"
                            disabled="@(_busy || _selected.Count == 0 || JobRunning || !CastReady || (_onlyMissing && EstimateSelectedClips() == 0) || SelectedLockedByOther)"
                            title="@(!CastReady ? CastBlockedTitle : SelectedLockedByOther ? "Selection includes scenes locked by another user" : null)"
                            @onclick="StartBatchAsync">
                        @if (JobRunning)
                        {
                            <span class="batch-go__spin" aria-hidden="true"></span>
                            <span>Generating…</span>
                        }
                        else if (_selected.Count == 0)
                        {
                            <span class="batch-go__play" aria-hidden="true">▶</span>
                            <span>Select scenes to generate</span>
                        }
                        else if (_onlyMissing && EstimateSelectedClips() == 0)
                        {
                            <span>Nothing missing in selection</span>
                        }
                        else
                        {
                            <span class="batch-go__play" aria-hidden="true">▶</span>
                            <span>
                                Generate @_selected.Count scene@(_selected.Count == 1 ? "" : "s")
                                <span class="batch-go__meta">
                                    · ~@EstimateSelectedClips() clip@((EstimateSelectedClips() == 1) ? "" : "s")
                                    @if (_costReport is not null)
                                    {
                                        <text> · ~$@(EstimateSelectedCostUsd().ToString("0.00"))</text>
                                    }
                                </span>
                            </span>
                        }
                    </button>
                </div>
            </div>

            <div class="batch-panel__foot">
                Selection respects character, location, and setting filters.
                Video gen is blocked until <strong>every</strong> character has an approved voice and (for on-screen roles) a locked image — approve them under Characters first so you do not waste API spend.
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th style="width:2.5rem;"></th>
                        <th style="width:4rem;">#</th>
                        <th>Setting</th>
                        <th>Cast / location</th>
                        <th style="width:6rem;">Clips</th>
                        <th style="width:7rem;" title="Actual media length (plan in muted)">Dur</th>
                        <th style="width:5rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in FilteredScenes)
                    {
                        var sn = s.SceneNumber;
                        var isSel = _selected.Contains(sn);
                        <tr class="@(isSel ? "table-active" : "")" style="cursor:pointer;">
                            <td @onclick:stopPropagation="true">
                                <input class="form-check-input" type="checkbox"
                                       checked="@isSel"
                                       disabled="@_busy"
                                       @onchange="e => ToggleSelect(sn, (bool)(e.Value ?? false))" />
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                <span class="badge @StatusBadge(s.Status)">S@(sn.ToString("D2"))</span>
                                @if (s.LockedByOther)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Locked by @s.LockOwnerUserId">🔒 @s.LockOwnerUserId</span>
                                }
                                else if (!string.IsNullOrEmpty(s.LockOwnerUserId))
                                {
                                    <span class="badge bg-info text-dark ms-1" title="You hold this lock">you</span>
                                }
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                @(s.Setting is { Length: > 0 } set ? Trunc(set, 56) : "—")
                                @if (s.CompositeExists)
                                {
                                    <span class="badge bg-light text-dark border ms-1">mux</span>
                                }
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)" class="small">
                                @if (s.CharactersOnScreen.Count > 0)
                                {
                                    <span class="text-muted">@string.Join(", ", s.CharactersOnScreen.Select(ShortChar).Take(4))</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                                @if (!string.IsNullOrEmpty(s.PrimaryLocationId) || s.LocationIds.Count > 0)
                                {
                                    <div class="text-muted">
                                        <code>@ShortLoc(s.PrimaryLocationId ?? s.LocationIds.FirstOrDefault() ?? "")</code>
                                    </div>
                                }
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                <span class="@(s.ClipsComplete ? "text-success" : s.ClipsOnDisk > 0 ? "text-warning" : "text-muted")">
                                    @s.ClipsOnDisk/@s.ClipCount
                                </span>
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)" class="small">
                                @if (s.ActualDurationSeconds is double act)
                                {
                                    <span title="Measured from composite or clips">@FormatClock(act)</span>
                                    @if (s.PlannedDurationSeconds is double plan && Math.Abs(plan - act) > 1.5)
                                    {
                                        <div class="text-muted" style="font-size:0.75rem;" title="Planned length">plan @FormatClock(plan)</div>
                                    }
                                }
                                else if (s.PlannedDurationSeconds is double planOnly)
                                {
                                    <span class="text-muted" title="Plan only — no media measured">~@FormatClock(planOnly)</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td @onclick:stopPropagation="true">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button class="btn btn-sm btn-success"
                                            disabled="@(_busy || JobRunning || (s.ClipsOnDisk == 0 && !s.CompositeExists))"
                                            title="@(s.CompositeExists ? "Play (auto-remux if stale)" : s.ClipsOnDisk > 0 ? "Remux then play" : "No clips")"
                                            @onclick="() => PlaySceneCompositeAsync(sn)">
                                        ▶
                                    </button>
                                    <button class="btn btn-sm batch-row-gen"
                                            data-testid="@($"scenes-gen-{sn}")"
                                            data-scene="@sn"
                                            disabled="@(_busy || JobRunning || !CastReady || s.LockedByOther)"
                                            title="@(!CastReady ? CastBlockedTitle : s.LockedByOther ? $"Locked by {s.LockOwnerUserId}" : EstimateSceneCostUsd(sn) is double c ? $"Generate this scene (~${c:0.00})" : "Generate this scene")"
                                            @onclick="() => GenOneSceneAsync(sn)">
                                        Gen
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
else if (_detail is null)
{
    <p class="text-muted">Loading scene…</p>
}
else
{
    @* ---- Scene detail ---- *@
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <strong>Scene @(_detail.SceneNumber.ToString("D2"))</strong>
                — @(_detail.Setting is { Length: > 0 } st ? st : "—")
            </span>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="onlyMissingDetail" @bind="_onlyMissing" disabled="@_busy" />
                    <label class="form-check-label" for="onlyMissingDetail">Only missing</label>
                </div>
                <div class="d-flex align-items-center gap-1">
                    <label class="small text-muted mb-0" for="genResDetail">Res</label>
                    <select id="genResDetail"
                            class="form-select form-select-sm"
                            style="width:auto"
                            @bind="_genResolution"
                            @bind:after="RefreshCostEstimateAsync"
                            disabled="@_busy">
                        <option value="480p">480p</option>
                        <option value="720p">720p</option>
                        <option value="1080p">1080p</option>
                    </select>
                </div>
                <button class="btn btn-sm btn-success"
                        disabled="@(_busy || JobRunning || (_detail.ClipsOnDisk == 0 && !_detail.CompositeExists))"
                        title="Play scene (auto-remux if missing or clips newer)"
                        @onclick="() => PlaySceneCompositeAsync(_detail.SceneNumber)">
                    ▶ Play scene
                </button>
                <button class="btn btn-sm btn-outline-primary"
                        disabled="@(_busy || JobRunning || _detail.ClipsOnDisk == 0)"
                        title="FFmpeg: concat this scene’s clips → composite (does not rebuild WIP)"
                        @onclick="() => RebuildSceneAsync(_detail.SceneNumber)">
                    Rebuild scene
                </button>
                <button class="btn btn-sm btn-primary"
                        disabled="@(_busy || JobRunning || !CastReady || DetailLockedByOther)"
                        title="@(!CastReady
                            ? CastBlockedTitle
                            : DetailLockedByOther
                            ? $"Locked by {_detailLockOwner}"
                            : EstimateSceneCostUsd(_detail.SceneNumber) is double dc
                            ? $"Generate missing clips in order (C01 → C02 → …) (~${dc:0.00})"
                            : "Generate missing clips in order (C01 → C02 → …)")"
                        @onclick="() => GenOneSceneAsync(_detail.SceneNumber)">
                    Generate scene
                </button>
                @if (DetailLockedByOther)
                {
                    <span class="badge bg-warning text-dark">🔒 @_detailLockOwner</span>
                }
            </div>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-2">
                @_detail.ClipsOnDisk/@_detail.ClipCount clips on disk
                @if (_detail.ActualDurationSeconds is double actD)
                {
                    <span>· <strong class="text-body">@FormatClock(actD)</strong> actual</span>
                    @if (_detail.PlannedDurationSeconds is double planD)
                    {
                        <span>· plan @FormatClock(planD)</span>
                    }
                }
                else if (_detail.PlannedDurationSeconds is double planOnly)
                {
                    <span>· plan ~@FormatClock(planOnly)</span>
                }
                @if (_detail.CompositeExists)
                {
                    <span class="badge bg-success ms-1">composite ready</span>
                }
                else if (_detail.ClipsOnDisk > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">composite needs rebuild</span>
                }
                @if (_detail.CharactersOnScreen.Count > 0)
                {
                    <span>· cast: @string.Join(", ", _detail.CharactersOnScreen.Select(ShortChar))</span>
                }
                @if (!string.IsNullOrEmpty(_detail.PrimaryLocationId))
                {
                    <span>· loc: <code>@_detail.PrimaryLocationId</code></span>
                }
            </p>

            @* Full scene composite — hide while clip selected, remux/gen busy, or full player open *@
            @if (IsSceneGenBusy(_detail.SceneNumber))
            {
                <p class="small text-muted mb-2">
                    Scene composite hidden while combining…
                </p>
            }
            else if (_showScenePlayer && _playingScene == _detail.SceneNumber)
            {
                <p class="small text-muted mb-2">
                    Playing full scene above.
                    <button type="button" class="btn btn-link btn-sm p-0 align-baseline" @onclick="HideScenePlayer">Show inline preview</button>
                </p>
            }
            else if (_detail.CompositeExists && _selectedClip is null)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <h6 class="text-muted mb-0">Scene composite <span class="small fw-normal">(all clips · full scene)</span></h6>
                        <button class="btn btn-sm btn-link" type="button"
                                @onclick="() => PlaySceneCompositeAsync(_detail.SceneNumber)">
                            Play full scene
                        </button>
                    </div>
                    <video controls playsinline
                           style="max-width:100%; max-height:280px; background:#111; border-radius:0.35rem;"
                           src="@CacheBust(Engine.CompositeVideoUrl(_projectId, _detail.SceneNumber))"
                           @key="_inlineCompositeKey"
                           poster=""></video>
                    <p class="small text-muted mb-0 mt-1">
                        This is the remuxed scene (~@(_detail.ActualDurationSeconds is double ad ? FormatClock(ad) : "?")).
                        Select a clip row below to play one clip only.
                    </p>
                </div>
            }
            else if (_detail.CompositeExists && _selectedClip is int)
            {
                <p class="small text-muted mb-2">
                    Viewing single clip — full scene composite hidden.
                    <button type="button" class="btn btn-link btn-sm p-0 align-baseline" @onclick="() => SelectClip(null)">Show scene composite</button>
                </p>
            }

            @if (_selectedClips.Count > 0)
            {
                <div class="d-flex align-items-center gap-2 mb-2 p-2 border rounded bg-light" data-testid="clip-batch-bar">
                    <span class="small">
                        <strong>@_selectedClips.Count</strong> clip@(_selectedClips.Count == 1 ? "" : "s") selected
                        @if (EstimateSelectedClipsCostUsd() is { } scc)
                        {
                            <span class="text-muted">· ~$@(scc.ToString("0.00"))</span>
                        }
                    </span>
                    <button type="button" class="btn btn-sm btn-warning"
                            data-testid="clip-batch-regen"
                            disabled="@(_busy || JobRunning || !CastReady)"
                            title="@(!CastReady ? CastBlockedTitle : "Force re-generate every selected clip")"
                            @onclick="RegenSelectedClipsAsync">
                        Regen @_selectedClips.Count selected
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ClearClipSelection">
                        Clear
                    </button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:2rem;"></th>
                            <th>Clip</th>
                            <th>Dur</th>
                            <th>Subject</th>
                            <th>Dialogue</th>
                            <th>Disk</th>
                            <th style="width:8rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _detail.Clips)
                        {
                            var active = _selectedClip == c.ClipNumber;
                            var cn = c.ClipNumber;
                            var isChecked = _selectedClips.Contains(cn);
                            <tr class="@(active ? "table-primary" : isChecked ? "table-warning" : "")" style="cursor:pointer;"
                                @onclick="() => SelectClip(cn)">
                                <td @onclick:stopPropagation="true">
                                    <input class="form-check-input" type="checkbox"
                                           data-testid="@($"clip-select-{cn}")"
                                           checked="@isChecked"
                                           disabled="@_busy"
                                           @onchange="e => ToggleClipSelect(cn, (bool)(e.Value ?? false))" />
                                </td>
                                <td><code>C@(cn.ToString("D2"))</code></td>
                                <td class="small">
                                    @if (c.ActualDurationSeconds is double ca)
                                    {
                                        <span>@FormatClock(ca)</span>
                                        @if (c.DurationSeconds > 0 && Math.Abs(c.DurationSeconds - ca) > 1.5)
                                        {
                                            <span class="text-muted"> · plan @c.DurationSeconds s</span>
                                        }
                                    }
                                    else if (c.DurationSeconds > 0)
                                    {
                                        <span class="text-muted">~@c.DurationSeconds s</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="small">@Trunc(c.PrimarySubject, 28)</td>
                                <td class="small"
                                    title="@(string.IsNullOrWhiteSpace(c.Dialogue) ? null : c.Dialogue)"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ShowDialoguePopup(c)">
                                    @if (string.IsNullOrWhiteSpace(c.Dialogue))
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span class="text-decoration-underline" style="text-decoration-style:dotted;cursor:pointer;">@Trunc(c.Dialogue, 40)</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var clipBusy = IsClipGenBusy(cn);
                                    }
                                    @if (clipBusy)
                                    {
                                        <span class="badge bg-warning text-dark">regenerating…</span>
                                    }
                                    else if (c.OnDisk)
                                    {
                                        <span class="badge bg-success">on disk</span>
                                        <span class="small text-muted">@FormatSize(c.SizeBytes)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">missing</span>
                                    }
                                </td>
                                <td @onclick:stopPropagation="true">
                                    @{
                                        var needPrev = PreviousClipMissing(cn);
                                    }
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-dark"
                                                disabled="@(_busy || !c.OnDisk || clipBusy)"
                                                title="@(clipBusy ? "Regenerating — file is about to change" : "Play clip")"
                                                @onclick="() => SelectClip(cn)">
                                            ▶
                                        </button>
                                        <button class="btn btn-outline-warning"
                                                disabled="@(_busy || JobRunning || !CastReady || needPrev)"
                                                title="@(!CastReady
                                                    ? CastBlockedTitle
                                                    : needPrev
                                                    ? $"Generate C{(cn - 1):D2} first — clips continue from the previous video"
                                                    : "Force re-generate this clip")"
                                                @onclick="() => RegenClipAsync(_detail.SceneNumber, cn)">
                                            Regen
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (_clip is not null)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span>
                    Clip <code>S@(_detail.SceneNumber.ToString("D2"))C@(_clip.ClipNumber.ToString("D2"))</code>
                    @if (!string.IsNullOrEmpty(_clip.Timestamp))
                    {
                        <span class="text-muted ms-2">@_clip.Timestamp</span>
                    }
                </span>
                <div class="d-flex gap-1">
                    @{
                        var clipNeedsPrev = PreviousClipMissing(_clip.ClipNumber);
                    }
                    <button class="btn btn-sm btn-outline-warning"
                            disabled="@(_busy || JobRunning || !CastReady || clipNeedsPrev)"
                            title="@(!CastReady
                                ? CastBlockedTitle
                                : clipNeedsPrev
                                ? $"Generate C{(_clip.ClipNumber - 1):D2} first — continues from previous video"
                                : "Force re-generate this clip (overwrites if present)")"
                            @onclick="() => RegenClipAsync(_detail.SceneNumber, _clip.ClipNumber)">
                        Regen clip
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectClip(null)">Close</button>
                </div>
            </div>
            <div class="card-body row">
                <div class="col-md-5 mb-3">
                    @if (_clip.OnDisk)
                    {
                        <div class="small text-success mb-1">
                            Single clip only
                            @if (_clip.ActualDurationSeconds is double cad)
                            {
                                <span>· @FormatClock(cad)</span>
                            }
                            · not the full scene
                        </div>
                        <video controls playsinline autoplay
                               style="width:100%; max-height:320px; background:#111; border-radius:0.35rem;"
                               src="@CacheBust(Engine.ClipVideoUrl(_projectId, _detail.SceneNumber, _clip.ClipNumber))"
                               @key="@($"clip-{_detail.SceneNumber}-{_clip.ClipNumber}-{_clipVideoKey}")"
                               onloadeddata="this.play().catch(function(){})"></video>
                        <div class="small text-muted mt-1">
                            @_clip.FileName · @FormatSize(_clip.SizeBytes)
                            · <a href="@Engine.ClipVideoUrl(_projectId, _detail.SceneNumber, _clip.ClipNumber)" target="_blank" rel="noopener">open clip URL</a>
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-4 text-center text-muted">
                            No video on disk
                            @if (PreviousClipMissing(_clip.ClipNumber))
                            {
                                <div class="small text-warning mt-2">
                                    Generate C@((_clip.ClipNumber - 1).ToString("D2")) first — this clip continues from the previous video.
                                </div>
                            }
                            <div class="mt-2">
                                <button class="btn btn-sm btn-warning"
                                        disabled="@(_busy || JobRunning || !CastReady || PreviousClipMissing(_clip.ClipNumber))"
                                        title="@(!CastReady
                                            ? CastBlockedTitle
                                            : PreviousClipMissing(_clip.ClipNumber)
                                            ? $"Need C{(_clip.ClipNumber - 1):D2} on disk"
                                            : null)"
                                        @onclick="() => RegenClipAsync(_detail.SceneNumber, _clip.ClipNumber)">
                                    Generate this clip
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <h6>Visual prompt</h6>
                    <pre class="small bg-light border rounded p-2" style="max-height:200px; overflow:auto; white-space:pre-wrap;">@(_clip.VisualPrompt is { Length: > 0 } vp ? vp : "—")</pre>
                    @if (!string.IsNullOrWhiteSpace(_clip.NegativePrompt))
                    {
                        <h6>Negative</h6>
                        <pre class="small bg-light border rounded p-2" style="max-height:80px; overflow:auto; white-space:pre-wrap;">@_clip.NegativePrompt</pre>
                    }
                    <h6>Audio</h6>
                    <p class="small mb-1">
                        <strong>@(_clip.Speaker ?? "—")</strong>
                        @if (!string.IsNullOrEmpty(_clip.Delivery))
                        {
                            <span class="text-muted">· @_clip.Delivery</span>
                        }
                    </p>
                    @if (_clip.Dialogue is { Length: > 0 } fullDlg)
                    {
                        <pre class="small bg-light border rounded p-2 mb-2"
                             style="max-height:160px; overflow:auto; white-space:pre-wrap; word-break:break-word;">@fullDlg</pre>
                        <button type="button" class="btn btn-link btn-sm p-0 mb-2"
                                @onclick="() => ShowDialoguePopup(_clip)">Full dialogue</button>
                    }
                    else
                    {
                        <p class="small text-muted">—</p>
                    }
                    <p class="small text-muted mb-0">
                        subject: @(_clip.PrimarySubject is { Length: > 0 } ps ? ps : "—")
                        · continuation: @_clip.Continuation
                        · @_clip.DurationSeconds s
                    </p>
                </div>
            </div>
            <div class="card-footer small text-muted">
                After <strong>Regen</strong>, use <strong>Rebuild scene</strong> so the composite includes the new clip.
                Pass/fail: <a href="review">Review</a>. Full movie: rebuild WIP on Review.
            </div>
        </div>
    }
}
} @* end CanScenes gate *@

@if (_dialoguePopup is { Length: > 0 })
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45);" @onclick="CloseDialoguePopup">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title">@_dialoguePopupTitle</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDialoguePopup"></button>
                </div>
                <div class="modal-body">
                    <pre class="small mb-0" style="white-space:pre-wrap; word-break:break-word;">@_dialoguePopup</pre>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="CloseDialoguePopup">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _busy;
    private bool _gateChecked;
    private string? _error;
    private string? _message;
    private string? _dialoguePopup;
    private string _dialoguePopupTitle = "Dialogue";
    private string _projectId = "";
    private List<string> _projectIds = new();
    private string _filter = "";
    private string _filterCharacter = "";
    private string _filterLocation = "";
    private bool _onlyMissing = true;
    /// <summary>Video gen resolution (defaults from Configuration).</summary>
    private string _genResolution = "720p";
    /// <summary>Cost estimate at the current resolution, refreshed on load and resolution change.</summary>
    private CostReport? _costReport;
    /// <summary>Project-wide cast gate: every character voice + locked image before video spend.</summary>
    private bool _castChecked;
    private bool _castReady;
    private int? _castReadyCount;
    private int? _castTotal;
    private List<string> _castMissing = new();
    private List<SceneSummary>? _scenes;
    private HashSet<int> _selected = new();
    private string _selectionMode = ""; // "" | incomplete | all
    private int? _selectedScene;
    private SceneDetail? _detail;
    private int? _selectedClip;
    private ClipSummary? _clip;
    /// <summary>Multi-select clip numbers within the currently open scene's clip table, for batch regen.</summary>
    private readonly HashSet<int> _selectedClips = new();
    private JobSnapshot? _job;
    private List<JobSnapshot> _myJobs = new();
    private bool _wipExists;
    private bool _wipStale;
    private bool _wipCanBuild;
    private string? _wipReason;
    private bool _showWipPlayer;
    private bool _playWipAfterRemux;
    private int? _playSceneAfterRemux;
    private string? _wipPath;
    private string? _wipUpdatedAt;
    private long _wipBytes;
    private long _wipVideoKey;
    private bool _showScenePlayer;
    private int? _playingScene;
    private long _sceneVideoKey;
    private long _inlineCompositeKey;
    private long _clipVideoKey;

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_job?.Status, "queued", StringComparison.OrdinalIgnoreCase) ||
        _myJobs.Any(j =>
            string.Equals(j.Status, "running", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(j.Status, "queued", StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Set for the brief window between kicking off a regen and the job snapshot round-trip
    /// confirming it server-side — closes the gap where <see cref="IsSceneGenBusy"/> would
    /// otherwise still see the previous (already-finished) job and let a stale composite show.
    /// </summary>
    private int? _pendingRegenScene;

    /// <summary>
    /// True when a clip/scene/remux job is active for this scene — hide stale composite player.
    /// </summary>
    private bool IsSceneGenBusy(int sceneNumber)
    {
        if (sceneNumber <= 0) return false;
        if (_pendingRegenScene == sceneNumber) return true;

        static bool Active(string? status) =>
            string.Equals(status, "running", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "queued", StringComparison.OrdinalIgnoreCase);

        bool Affects(JobSnapshot j)
        {
            if (!Active(j.Status) || !IsScenesWorkflowJob(j.Kind))
                return false;
            // Batch may include this scene; hide composite to avoid playing stale mux
            if (string.Equals(j.Kind, "batch", StringComparison.OrdinalIgnoreCase))
                return true;
            return j.Scene is int sn && sn == sceneNumber;
        }

        if (_job is not null && Affects(_job))
            return true;
        return _myJobs.Any(Affects);
    }

    /// <summary>
    /// True when this exact clip is the one currently being (re)generated — the server updates
    /// the job's Scene/Clip to whichever item it's actively working on, for both single-clip
    /// regen (kind "scene") and multi-select batch regen (kind "batch"). Used to avoid showing
    /// a stale "on disk" pill or letting Play open the file mid-overwrite.
    /// </summary>
    private bool IsClipGenBusy(int clipNumber)
    {
        if (_detail is null) return false;
        var sn = _detail.SceneNumber;
        if (_pendingRegenScene == sn) return true;

        bool Affects(JobSnapshot j) =>
            (string.Equals(j.Status, "running", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(j.Status, "queued", StringComparison.OrdinalIgnoreCase)) &&
            IsScenesWorkflowJob(j.Kind) &&
            j.Scene == sn && j.Clip == clipNumber;

        if (_job is not null && Affects(_job))
            return true;
        return _myJobs.Any(Affects);
    }

    /// <summary>True when every cast member has approved voice + locked look (or voice-only + voice).</summary>
    private bool CastReady => _castReady;

    private string CastBlockedTitle =>
        _castMissing.Count > 0
            ? $"Approve voice + locked image first: {string.Join(", ", _castMissing.Take(4))}{(_castMissing.Count > 4 ? "…" : "")}"
            : "Approve voice + locked image for every character before generating video";

    /// <summary>
    /// Clip N (N&gt;1) needs clip N-1 on disk — Imagine continues from the previous video.
    /// </summary>
    private bool PreviousClipMissing(int clipNumber)
    {
        if (clipNumber <= 1 || _detail is null) return false;
        var prev = _detail.Clips.FirstOrDefault(c => c.ClipNumber == clipNumber - 1);
        return prev is null || !prev.OnDisk;
    }

    /// <summary>Jobs that belong on Scenes (not leftover stage2 / character jobs).</summary>
    private static bool IsScenesWorkflowJob(string? kind) =>
        kind is "scene" or "batch" or "remux";

    private bool ShowOperatorGenProgress =>
        !Session.IsAdmin &&
        _job is not null &&
        IsScenesWorkflowJob(_job.Kind) &&
        (_job.Status is "running" or "queued");

    private bool ShowOperatorGenError =>
        !Session.IsAdmin &&
        _job is not null &&
        IsScenesWorkflowJob(_job.Kind) &&
        string.Equals(_job.Status, "error", StringComparison.OrdinalIgnoreCase);

    private bool ShowOperatorGenPartial =>
        !Session.IsAdmin &&
        _job is not null &&
        IsScenesWorkflowJob(_job.Kind) &&
        string.Equals(_job.Status, "partial", StringComparison.OrdinalIgnoreCase);

    private static string OperatorGenStatusText(JobSnapshot job) => job.Kind switch
    {
        "remux" => "Combining video…",
        "batch" => "Generating clips…",
        "scene" when job.Clip is int => "Generating clip…",
        "scene" => "Generating scene…",
        _ => "Working…",
    };

    private bool SelectedLockedByOther =>
        _scenes is not null &&
        _selected.Any(sn => _scenes.Any(s => s.SceneNumber == sn && s.LockedByOther));

    private bool DetailLockedByOther =>
        _detail is not null &&
        (_scenes?.FirstOrDefault(s => s.SceneNumber == _detail.SceneNumber)?.LockedByOther ?? false);

    private string? _detailLockOwner =>
        _detail is null
            ? null
            : _scenes?.FirstOrDefault(s => s.SceneNumber == _detail.SceneNumber)?.LockOwnerUserId;

    private string WipPlayTitle =>
        !_wipCanBuild && !_wipExists
            ? "No scene/clip videos to build WIP"
            : _wipStale || !_wipExists
                ? $"Refresh then play: {_wipReason ?? "out of date"}"
                : "Play streamed movie_wip.mp4 (up to date)";

    private string SelectionMode => _selectionMode;

    private int IncompleteCount =>
        FilteredScenes.Count(s => s.ClipsOnDisk < s.ClipCount);

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filter) ||
        !string.IsNullOrWhiteSpace(_filterCharacter) ||
        !string.IsNullOrWhiteSpace(_filterLocation);

    private List<string> CharacterOptions =>
        _scenes is null
            ? new List<string>()
            : _scenes
                .SelectMany(s => s.CharactersOnScreen)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(c => ShortChar(c), StringComparer.OrdinalIgnoreCase)
                .ToList();

    private List<string> LocationOptions =>
        _scenes is null
            ? new List<string>()
            : _scenes
                .SelectMany(s =>
                {
                    var list = new List<string>(s.LocationIds);
                    if (!string.IsNullOrWhiteSpace(s.PrimaryLocationId))
                        list.Add(s.PrimaryLocationId!);
                    return list;
                })
                .Where(l => !string.IsNullOrWhiteSpace(l))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(ShortLoc, StringComparer.OrdinalIgnoreCase)
                .ToList();

    private List<SceneSummary> FilteredScenes
    {
        get
        {
            if (_scenes is null)
                return new List<SceneSummary>();

            IEnumerable<SceneSummary> q = _scenes;
            if (!string.IsNullOrWhiteSpace(_filter))
            {
                q = q.Where(s =>
                    (s.Setting ?? "").Contains(_filter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_filterCharacter))
            {
                q = q.Where(s =>
                    s.CharactersOnScreen.Any(c =>
                        string.Equals(c, _filterCharacter, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(_filterLocation))
            {
                q = q.Where(s =>
                    string.Equals(s.PrimaryLocationId, _filterLocation, StringComparison.OrdinalIgnoreCase) ||
                    s.LocationIds.Any(l =>
                        string.Equals(l, _filterLocation, StringComparison.OrdinalIgnoreCase)));
            }

            return q.ToList();
        }
    }

    private void ClearFilters()
    {
        _filter = "";
        _filterCharacter = "";
        _filterLocation = "";
    }

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            try { await Session.EnsureHydratedAsync(); } catch { /* optional */ }

            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string>();
            if (projs?.Active?.Id is { Length: > 0 } aid &&
                _projectIds.Exists(id => string.Equals(id, aid, StringComparison.OrdinalIgnoreCase)))
            {
                _projectId = aid;
                ActiveProject.Set(aid, projs.Active?.Label ?? projs.Active?.Title ?? aid);
            }
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];
            else
                _projectId = "";

            await ActiveProject.RefreshReadinessAsync(Engine);
            _gateChecked = true;
            if (string.IsNullOrEmpty(_projectId) || !ActiveProject.CanScenes)
                return;

            await LoadGenResolutionFromConfigAsync();

            try
            {
                await Hub.StartAsync();
            }
            catch { /* SignalR optional for browse */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            if (Session.IsAdmin)
                await RefreshMyJobsAsync();

            await ReloadListAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _gateChecked = true;
        }
    }

    private async Task LoadGenResolutionFromConfigAsync()
    {
        try
        {
            var dto = await Engine.GetConfigAsync(_projectId);
            if (dto?.Config is { } cfg &&
                cfg.TryGetValue("resolution", out var el) &&
                el.ValueKind == JsonValueKind.String &&
                el.GetString() is { Length: > 0 } res)
            {
                _genResolution = res.Trim().ToLowerInvariant() switch
                {
                    "480" or "480p" => "480p",
                    "720" or "720p" => "720p",
                    "1080" or "1080p" => "1080p",
                    _ => res.Trim(),
                };
            }
        }
        catch { /* keep default */ }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        _ = InvokeAsync(RefreshMyJobsAsync);
        if (snap.Status is "done" or "partial" or "error" or "cancelled")
            _ = InvokeAsync(async () =>
            {
                await SoftReloadAsync();
                if (snap.Status == "done" &&
                    string.Equals(snap.Kind, "remux", StringComparison.OrdinalIgnoreCase))
                {
                    await RefreshWipMetaAsync();
                    // Bust cache so next manual play / inline preview loads the new file.
                    var bust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                    _sceneVideoKey = bust;
                    _inlineCompositeKey = bust;

                    if (_playWipAfterRemux)
                    {
                        _playWipAfterRemux = false;
                        if (_wipExists)
                        {
                            _showWipPlayer = true;
                            _wipVideoKey = bust;
                            _message = "WIP ready — player below";
                        }
                    }
                    else if (_playSceneAfterRemux is int playSn)
                    {
                        // Explicit Play scene (auto-remux) — open player once.
                        _playSceneAfterRemux = null;
                        _playingScene = playSn;
                        _showScenePlayer = true;
                        _message = $"Scene S{playSn:D2} ready — playing";
                    }
                    else if (snap.Scene is int sn && sn > 0)
                    {
                        // Rebuild scene: progress only — do not auto-open a second player.
                        _message = $"Scene S{sn:D2} composite rebuilt";
                    }
                }
                else if (snap.Status == "done" &&
                         string.Equals(snap.Kind, "scene", StringComparison.OrdinalIgnoreCase) &&
                         snap.Clip is int cn &&
                         snap.Scene is int gsn)
                {
                    _clipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                    _message = $"Clip S{gsn:D2}C{cn:D2} finished — rebuild scene composite if you want it in the cut";
                    if (_selectedClip == cn)
                        SelectClip(cn);
                }
                StateHasChanged();
            });
        else
            _ = InvokeAsync(StateHasChanged);
    }

    private void OnJobLog(string line)
    {
        if (_job is not null)
            _job.Message = line;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnProjectChangedAsync()
    {
        _selectedScene = null;
        _detail = null;
        _selectedClip = null;
        _clip = null;
        _selected.Clear();
        ClearFilters();
        await LoadGenResolutionFromConfigAsync();
        await ReloadListAsync();
    }

    private async Task ReloadListAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetScenesAsync(_projectId);
            _scenes = dto?.Scenes ?? new List<SceneSummary>();
            // Drop selections that no longer exist
            _selected.RemoveWhere(sn => _scenes.All(s => s.SceneNumber != sn));
            if (_selectedScene is int sn)
                await LoadDetailAsync(sn);
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            await RefreshMyJobsAsync();
            await RefreshWipMetaAsync();
            await RefreshCastGateAsync();
            await RefreshCostEstimateAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _scenes = null;
        }
        finally { _busy = false; }
    }

    /// <summary>Refreshes the per-scene cost report at the currently selected generation resolution.</summary>
    private async Task RefreshCostEstimateAsync()
    {
        if (string.IsNullOrEmpty(_projectId)) return;
        try
        {
            var dto = await Engine.GetCostAsync(_projectId, draftResolution: _genResolution, heroResolution: _genResolution);
            _costReport = dto?.Cost;
        }
        catch { _costReport = null; }
    }

    private double EstimateSelectedCostUsd()
    {
        if (_costReport is null) return 0;
        var sum = 0.0;
        foreach (var row in _costReport.Scenes.Where(r => _selected.Contains(r.Scene)))
            sum += _onlyMissing ? row.RemainingDraftUsd : row.AllDraftUsd;
        return sum;
    }

    private double? EstimateSceneCostUsd(int sceneNumber)
    {
        var row = _costReport?.Scenes.FirstOrDefault(r => r.Scene == sceneNumber);
        if (row is null) return null;
        return _onlyMissing ? row.RemainingDraftUsd : row.AllDraftUsd;
    }

    /// <summary>
    /// Refresh project-wide cast readiness (voice + locked image for every character).
    /// Soft-fails: if adaptation cannot load, keep previous gate state.
    /// </summary>
    private async Task RefreshCastGateAsync()
    {
        try
        {
            var adapt = await Engine.GetAdaptationAsync(_projectId);
            var cast = adapt?.Adaptation?.Cast;
            if (cast is null)
            {
                _castChecked = true;
                _castReady = false;
                _castReadyCount = null;
                _castTotal = null;
                _castMissing = new List<string>();
                return;
            }

            _castChecked = true;
            _castReady = cast.ReadyForShots;
            _castReadyCount = cast.Ready;
            _castTotal = cast.Total;
            _castMissing = cast.Missing?.Count > 0
                ? cast.Missing.ToList()
                : new List<string>();
        }
        catch
        {
            // Keep last known; mark checked so UI does not hang open forever
            _castChecked = true;
        }
    }

    private async Task SoftReloadAsync()
    {
        try
        {
            var dto = await Engine.GetScenesAsync(_projectId);
            _scenes = dto?.Scenes ?? new List<SceneSummary>();
            await RefreshMyJobsAsync();
            await RefreshWipMetaAsync();
            await RefreshCastGateAsync();
            if (_selectedScene is int sn)
            {
                var detail = await Engine.GetSceneDetailAsync(_projectId, sn);
                _detail = detail?.Scene;
                if (_selectedClip is int cn && _detail is not null)
                    _clip = _detail.Clips.FirstOrDefault(c => c.ClipNumber == cn);
            }
        }
        catch { /* ignore soft reload errors */ }
    }

    private async Task RefreshMyJobsAsync()
    {
        try
        {
            var list = await Engine.GetJobsAsync(mine: true);
            _myJobs = list?.Jobs?
                .Where(j =>
                    string.Equals(j.Status, "running", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(j.Status, "queued", StringComparison.OrdinalIgnoreCase) ||
                    (j.FinishedAt is DateTimeOffset f && f > DateTimeOffset.UtcNow.AddMinutes(-5)))
                .OrderByDescending(j => j.StartedAt ?? j.QueuedAt)
                .Take(12)
                .ToList()
                ?? new List<JobSnapshot>();
        }
        catch
        {
            // keep previous
        }
    }

    private async Task OpenSceneAsync(int sn)
    {
        _busy = true;
        _error = null;
        try
        {
            await LoadDetailAsync(sn);
            _selectedScene = sn;
            _selectedClip = null;
            _clip = null;
            _selectedClips.Clear();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LoadDetailAsync(int sn)
    {
        var dto = await Engine.GetSceneDetailAsync(_projectId, sn);
        _detail = dto?.Scene
            ?? throw new InvalidOperationException($"Scene {sn} not found");
    }

    private async Task BackToListAsync()
    {
        _selectedScene = null;
        _detail = null;
        _selectedClip = null;
        _clip = null;
        _selectedClips.Clear();
        await ReloadListAsync();
    }

    private void ToggleClipSelect(int cn, bool on)
    {
        if (on) _selectedClips.Add(cn);
        else _selectedClips.Remove(cn);
    }

    private void ClearClipSelection() => _selectedClips.Clear();

    private double? EstimateSelectedClipsCostUsd()
    {
        if (_costReport is null || _detail is null) return null;
        var row = _costReport.Scenes.FirstOrDefault(r => r.Scene == _detail.SceneNumber);
        if (row is null || row.ClipsTotal <= 0) return null;
        // Approximate: whole-scene draft cost spread evenly per clip (force-regen ignores on-disk state).
        return row.AllDraftUsd / row.ClipsTotal * _selectedClips.Count;
    }

    private async Task RegenSelectedClipsAsync()
    {
        if (_detail is null || _selectedClips.Count == 0) return;
        var sn = _detail.SceneNumber;
        _busy = true;
        _error = null;
        _message = null;
        _pendingRegenScene = sn;
        try
        {
            var targets = _selectedClips.OrderBy(c => c).Select(c => (Scene: sn, Clip: c)).ToList();
            await EnsureHubAsync();
            await Engine.StartClipBatchGenAsync(_projectId, targets, resolution: _genResolution);
            _message = $"Regenerating {targets.Count} clip(s) in S{sn:D2} @ {_genResolution}";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            _selectedClips.Clear();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _pendingRegenScene = null; }
    }

    private void SelectClip(int? cn)
    {
        _selectedClip = cn;
        _clip = cn is int n
            ? _detail?.Clips.FirstOrDefault(c => c.ClipNumber == n)
            : null;
        if (cn is int)
        {
            // Force new <video> mount so we never keep a previous composite/clip stream
            _clipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            // Stop full-scene autoplay panel if open
            if (_showScenePlayer && _playingScene == _detail?.SceneNumber)
            {
                _showScenePlayer = false;
                _playingScene = null;
            }
        }
    }

    private async Task PlaySceneCompositeAsync(int sn)
    {
        var meta = await Engine.GetWipMovieMetaAsync(_projectId);
        var summary = _scenes?.FirstOrDefault(s => s.SceneNumber == sn);
        var compositeOk = summary?.CompositeExists == true
                          || (_detail is { SceneNumber: var dsn, CompositeExists: true } && dsn == sn);
        var clipsOnDisk = summary?.ClipsOnDisk
                          ?? (_detail is { SceneNumber: var d2 } && d2 == sn ? _detail.ClipsOnDisk : 0);
        var needsRemux = !compositeOk || meta?.StaleScenes?.Contains(sn) == true;

        if (needsRemux && clipsOnDisk > 0 && !JobRunning)
        {
            _busy = true;
            _error = null;
            try
            {
                await EnsureHubAsync();
                _playSceneAfterRemux = sn;
                await Engine.StartRemuxAsync(_projectId, sn, rebuildWip: false);
                _message = $"Rebuilding S{sn:D2} composite then play…";
                var jobs = await Engine.GetJobAsync();
                _job = jobs?.Job;
            }
            catch (Exception ex) { _error = ex.Message; _playSceneAfterRemux = null; }
            finally { _busy = false; }
            return;
        }

        if (!compositeOk)
        {
            _error = $"No composite for S{sn:D2} — generate clips or rebuild scene first";
            return;
        }

        _playingScene = sn;
        _showScenePlayer = true;
        _sceneVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _inlineCompositeKey = _sceneVideoKey;
        _message = $"Playing S{sn:D2} composite";
    }

    private void HideScenePlayer()
    {
        _showScenePlayer = false;
        _playingScene = null;
    }

    /// <summary>FFmpeg concat clips → scene composite only (not WIP). Progress only — no auto-play.</summary>
    private async Task RebuildSceneAsync(int sn)
    {
        _busy = true;
        _error = null;
        _message = null;
        // Hide any open scene player so rebuild shows progress, not dual/stale playback.
        _playSceneAfterRemux = null;
        if (_playingScene == sn || _showScenePlayer)
        {
            _showScenePlayer = false;
            _playingScene = null;
        }
        try
        {
            await EnsureHubAsync();
            await Engine.StartRemuxAsync(_projectId, sn, rebuildWip: false);
            _message = $"Rebuilding S{sn:D2} scene composite…";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    /// <summary>Force re-generate a single clip (onlyMissing: false).</summary>
    private async Task RegenClipAsync(int sn, int cn)
    {
        if (!CastReady)
        {
            _error = CastBlockedTitle;
            return;
        }

        _busy = true;
        _error = null;
        _message = null;
        _pendingRegenScene = sn;
        try
        {
            await EnsureHubAsync();
            await Engine.StartSceneGenAsync(_projectId, sn, onlyMissing: false, clip: cn, resolution: _genResolution);
            _message = $"Regenerating S{sn:D2}C{cn:D2} @ {_genResolution}…";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _pendingRegenScene = null; }
    }

    private void ToggleSelect(int sn, bool on)
    {
        if (on) _selected.Add(sn);
        else _selected.Remove(sn);
        _selectionMode = "";
    }

    private void SelectIncomplete()
    {
        _selected = FilteredScenes
            .Where(s => s.ClipsOnDisk < s.ClipCount)
            .Select(s => s.SceneNumber)
            .ToHashSet();
        _selectionMode = "incomplete";
    }

    private void SelectAll()
    {
        _selected = FilteredScenes.Select(s => s.SceneNumber).ToHashSet();
        _selectionMode = "all";
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _selectionMode = "";
    }

    private int EstimateSelectedClips()
    {
        if (_scenes is null) return 0;
        var sum = 0;
        foreach (var s in _scenes.Where(x => _selected.Contains(x.SceneNumber)))
        {
            if (_onlyMissing)
                sum += Math.Max(0, s.ClipCount - s.ClipsOnDisk);
            else
                sum += s.ClipCount;
        }
        return sum;
    }

    private async Task GenOneSceneAsync(int sn)
    {
        if (!CastReady)
        {
            _error = CastBlockedTitle;
            return;
        }

        _busy = true;
        _error = null;
        _message = null;
        _pendingRegenScene = sn;
        try
        {
            await Engine.StartSceneGenAsync(_projectId, sn, _onlyMissing, resolution: _genResolution);
            _message = $"Started scene {sn} @ {_genResolution}";
            await EnsureHubAsync();
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _pendingRegenScene = null; }
    }

    private async Task StartBatchAsync()
    {
        if (_selected.Count == 0) return;
        if (!CastReady)
        {
            _error = CastBlockedTitle;
            return;
        }

        _busy = true;
        _error = null;
        _message = null;
        try
        {
            var list = _selected.OrderBy(x => x).ToList();
            await Engine.StartBatchGenAsync(_projectId, list, _onlyMissing, resolution: _genResolution);
            _message = $"Started batch for {list.Count} scene(s) @ {_genResolution}";
            await EnsureHubAsync();
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
