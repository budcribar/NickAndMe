@page "/scenes"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models

<PageTitle>Scenes &amp; Clips</PageTitle>

<h1>Scenes &amp; Clips</h1>
<p class="text-muted mb-1">
    Stage 2 blueprint browse + generate via the C# engine.
    Pass/fail on <a href="review">Review</a>; replan Stage 2 from <a href="adaptation">Adaptation</a>.
</p>
<p class="small text-muted">
    <strong>Rebuild scene</strong> = ffmpeg concat of this scene’s clips → composite (not full WIP).
    Clip <strong>Regen</strong> force-regenerates one clip; rebuild the scene after to update the composite.
</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="OnProjectChangedAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Character</label>
        <select class="form-select" @bind="_filterCharacter" disabled="@_busy">
            <option value="">All characters</option>
            @foreach (var c in CharacterOptions)
            {
                <option value="@c">@ShortChar(c)</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Location</label>
        <select class="form-select" @bind="_filterLocation" disabled="@_busy">
            <option value="">All locations</option>
            @foreach (var loc in LocationOptions)
            {
                <option value="@loc">@ShortLoc(loc)</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Setting text</label>
        <input class="form-control" @bind="_filter" @bind:event="oninput" disabled="@_busy" placeholder="e.g. pajamas" />
    </div>
    <div class="col-md-3 d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Reload</button>
        <button class="btn btn-success" disabled="@(_busy || JobRunning || (!_wipExists && !_wipCanBuild))"
                @onclick="PlayWipAsync"
                title="@WipPlayTitle">
            @(_showWipPlayer && _wipExists && !_wipStale ? "Hide WIP" : _wipStale || !_wipExists ? "▶ Play WIP (refresh)" : "▶ Play WIP")
        </button>
        @if (HasActiveFilters)
        {
            <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="ClearFilters">Clear filters</button>
        }
        @if (_selectedScene is int)
        {
            <button class="btn btn-outline-primary" disabled="@_busy" @onclick="BackToListAsync">← All scenes</button>
        }
    </div>
</div>

@if (_showWipPlayer && _wipExists)
{
    <div class="card mb-3 border-success">
        <div class="card-header d-flex justify-content-between align-items-center py-2 flex-wrap gap-2">
            <span>
                WIP movie <code class="small">@(_wipPath ?? "assets/movie_wip.mp4")</code>
                @if (_wipStale)
                {
                    <span class="badge bg-warning text-dark ms-1">stale</span>
                }
            </span>
            @if (!string.IsNullOrEmpty(_wipUpdatedAt))
            {
                <span class="small text-muted">@_wipUpdatedAt · @FormatBytes(_wipBytes)</span>
            }
        </div>
        <div class="card-body py-2">
            @if (!string.IsNullOrEmpty(_wipReason) && _wipStale)
            {
                <p class="small text-warning mb-2">@_wipReason</p>
            }
            <video controls playsinline autoplay
                   style="width:100%;max-height:70vh;background:#000;border-radius:0.35rem;"
                   src="@CacheBust(Engine.WipMovieUrl(_projectId))"
                   @key="_wipVideoKey"
                   onloadeddata="this.play().catch(function(){})">
                Your browser does not support HTML5 video.
            </video>
            <p class="small text-muted mb-0 mt-2">
                <strong>Play WIP</strong> auto-refreshes if out of date (mux only — no clip re-gen).
                <a href="@Engine.WipMovieUrl(_projectId)" target="_blank" rel="noopener">Open in new tab</a>
            </p>
        </div>
    </div>
}

@if (_showScenePlayer && _playingScene is int playSn)
{
    <div class="card mb-3 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center py-2">
            <span>Scene composite <code class="small">S@(playSn.ToString("D2"))</code></span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="HideScenePlayer">Hide</button>
        </div>
        <div class="card-body py-2">
            <video controls playsinline autoplay
                   style="width:100%;max-height:70vh;background:#000;border-radius:0.35rem;"
                   src="@CacheBust(Engine.CompositeVideoUrl(_projectId, playSn))"
                   @key="_sceneVideoKey"
                   onloadeddata="this.play().catch(function(){})">
                Your browser does not support HTML5 video.
            </video>
            <p class="small text-muted mb-0 mt-2">
                If empty/404, use <strong>Rebuild scene</strong> (needs clips on disk).
                <a href="@Engine.CompositeVideoUrl(_projectId, playSn)" target="_blank" rel="noopener">Open in new tab</a>
            </p>
        </div>
    </div>
}

@* ---- Live job banner ---- *@
@if (_job is not null && (_job.Status is "running" or "done" or "error" or "cancelled"))
{
    <div class="card mb-3 border-@(_job.Status == "running" ? "primary" : _job.Status == "error" ? "danger" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <span class="badge bg-secondary">@_job.Status</span>
                    @if (_job.Kind is { Length: > 0 } k)
                    {
                        <span class="badge bg-info text-dark ms-1">@k</span>
                    }
                    @if (_job.Scene is int sn)
                    {
                        <span class="ms-1">S@(sn.ToString("D2"))</span>
                    }
                    @if (_job.Clip is int cn)
                    {
                        <span>C@cn</span>
                    }
                    @if (_job.Total > 0)
                    {
                        <span class="ms-1 text-muted">@_job.Index / @_job.Total</span>
                    }
                    <span class="ms-2 small">@_job.Message</span>
                </div>
                <div class="d-flex gap-2">
                    @if (_job.Status == "running")
                    {
                        <button class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel</button>
                    }
                    <button class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ReloadListAsync">Refresh list</button>
                </div>
            </div>
            @if (_job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 120px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(20))</pre>
            }
        </div>
    </div>
}

@if (_selectedScene is null)
{
    @* ---- Scene list ---- *@
    @if (_scenes is null)
    {
        <p class="text-muted">Loading scenes…</p>
    }
    else if (_scenes.Count == 0)
    {
        <div class="alert alert-warning">
            No Stage 2 scenes. Open <strong>Adaptation</strong> and run Stage 2 first.
        </div>
    }
    else
    {
        <div class="batch-panel mb-3">
            <div class="batch-panel__head">
                <div class="batch-panel__title">
                    <span class="batch-panel__icon" aria-hidden="true">▶</span>
                    <div>
                        <div class="batch-panel__heading">Batch generate</div>
                        <div class="batch-panel__sub">
                            @FilteredScenes.Count scene@(FilteredScenes.Count == 1 ? "" : "s") shown
                            @if (HasActiveFilters)
                            {
                                <span> of @_scenes.Count</span>
                            }
                            · @_scenes.Sum(s => s.ClipsOnDisk)/@_scenes.Sum(s => s.ClipCount) clips on disk
                            @if (IncompleteCount > 0)
                            {
                                <span class="batch-panel__warn"> · @IncompleteCount incomplete</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="batch-panel__stats">
                    <div class="batch-stat @(_selected.Count > 0 ? "batch-stat--active" : "")">
                        <span class="batch-stat__value">@_selected.Count</span>
                        <span class="batch-stat__label">selected</span>
                    </div>
                    <div class="batch-stat @(_selected.Count > 0 ? "batch-stat--clips" : "")">
                        <span class="batch-stat__value">~@EstimateSelectedClips()</span>
                        <span class="batch-stat__label">clips</span>
                    </div>
                </div>
            </div>

            <div class="batch-panel__body">
                <div class="batch-panel__select">
                    <span class="batch-panel__select-label">Select</span>
                    <div class="batch-chip-group" role="group" aria-label="Selection shortcuts">
                        <button type="button"
                                class="batch-chip @(SelectionMode == "incomplete" ? "batch-chip--on" : "")"
                                disabled="@(_busy || IncompleteCount == 0)"
                                @onclick="SelectIncomplete"
                                title="Scenes with missing clips in the current filter">
                            Incomplete
                            @if (IncompleteCount > 0)
                            {
                                <span class="batch-chip__count">@IncompleteCount</span>
                            }
                        </button>
                        <button type="button"
                                class="batch-chip @(SelectionMode == "all" ? "batch-chip--on" : "")"
                                disabled="@(_busy || FilteredScenes.Count == 0)"
                                @onclick="SelectAll"
                                title="All scenes in the current filter">
                            All shown
                            <span class="batch-chip__count">@FilteredScenes.Count</span>
                        </button>
                        <button type="button"
                                class="batch-chip batch-chip--muted @(_selected.Count == 0 ? "batch-chip--disabled" : "")"
                                disabled="@(_busy || _selected.Count == 0)"
                                @onclick="ClearSelection"
                                title="Clear selection">
                            Clear
                        </button>
                    </div>
                </div>

                <div class="batch-panel__actions">
                    <label class="batch-toggle" title="Skip clips already on disk">
                        <input type="checkbox" class="form-check-input" @bind="_onlyMissing" disabled="@_busy" />
                        <span>Only missing clips</span>
                    </label>

                    <button type="button"
                            class="btn batch-go @(_selected.Count > 0 && !JobRunning ? "batch-go--ready" : "")"
                            disabled="@(_busy || _selected.Count == 0 || JobRunning || (_onlyMissing && EstimateSelectedClips() == 0))"
                            @onclick="StartBatchAsync">
                        @if (JobRunning)
                        {
                            <span class="batch-go__spin" aria-hidden="true"></span>
                            <span>Generating…</span>
                        }
                        else if (_selected.Count == 0)
                        {
                            <span class="batch-go__play" aria-hidden="true">▶</span>
                            <span>Select scenes to generate</span>
                        }
                        else if (_onlyMissing && EstimateSelectedClips() == 0)
                        {
                            <span>Nothing missing in selection</span>
                        }
                        else
                        {
                            <span class="batch-go__play" aria-hidden="true">▶</span>
                            <span>
                                Generate @_selected.Count scene@(_selected.Count == 1 ? "" : "s")
                                <span class="batch-go__meta">· ~@EstimateSelectedClips() clip@((EstimateSelectedClips() == 1) ? "" : "s")</span>
                            </span>
                        }
                    </button>
                </div>
            </div>

            <div class="batch-panel__foot">
                Uses <code>XAI_API_KEY</code> on the API process · selection respects character/location/setting filters.
                Video gen is blocked until on-screen cast (non-narrator) has locked character refs — lock them under Characters.
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th style="width:2.5rem;"></th>
                        <th style="width:4rem;">#</th>
                        <th>Setting</th>
                        <th>Cast / location</th>
                        <th style="width:6rem;">Clips</th>
                        <th style="width:7rem;" title="Actual media length (plan in muted)">Dur</th>
                        <th style="width:5rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in FilteredScenes)
                    {
                        var sn = s.SceneNumber;
                        var isSel = _selected.Contains(sn);
                        <tr class="@(isSel ? "table-active" : "")" style="cursor:pointer;">
                            <td @onclick:stopPropagation="true">
                                <input class="form-check-input" type="checkbox"
                                       checked="@isSel"
                                       disabled="@_busy"
                                       @onchange="e => ToggleSelect(sn, (bool)(e.Value ?? false))" />
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                <span class="badge @StatusBadge(s.Status)">S@(sn.ToString("D2"))</span>
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                @(s.Setting is { Length: > 0 } set ? Trunc(set, 56) : "—")
                                @if (s.CompositeExists)
                                {
                                    <span class="badge bg-light text-dark border ms-1">mux</span>
                                }
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)" class="small">
                                @if (s.CharactersOnScreen.Count > 0)
                                {
                                    <span class="text-muted">@string.Join(", ", s.CharactersOnScreen.Select(ShortChar).Take(4))</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                                @if (!string.IsNullOrEmpty(s.PrimaryLocationId) || s.LocationIds.Count > 0)
                                {
                                    <div class="text-muted">
                                        <code>@ShortLoc(s.PrimaryLocationId ?? s.LocationIds.FirstOrDefault() ?? "")</code>
                                    </div>
                                }
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)">
                                <span class="@(s.ClipsComplete ? "text-success" : s.ClipsOnDisk > 0 ? "text-warning" : "text-muted")">
                                    @s.ClipsOnDisk/@s.ClipCount
                                </span>
                            </td>
                            <td @onclick="() => OpenSceneAsync(sn)" class="small">
                                @if (s.ActualDurationSeconds is double act)
                                {
                                    <span title="Measured from composite or clips">@FormatClock(act)</span>
                                    @if (s.PlannedDurationSeconds is double plan && Math.Abs(plan - act) > 1.5)
                                    {
                                        <div class="text-muted" style="font-size:0.75rem;" title="Stage 2 plan">plan @FormatClock(plan)</div>
                                    }
                                }
                                else if (s.PlannedDurationSeconds is double planOnly)
                                {
                                    <span class="text-muted" title="Plan only — no media measured">~@FormatClock(planOnly)</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td @onclick:stopPropagation="true">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button class="btn btn-sm btn-success"
                                            disabled="@(_busy || JobRunning || (s.ClipsOnDisk == 0 && !s.CompositeExists))"
                                            title="@(s.CompositeExists ? "Play (auto-remux if stale)" : s.ClipsOnDisk > 0 ? "Remux then play" : "No clips")"
                                            @onclick="() => PlaySceneCompositeAsync(sn)">
                                        ▶
                                    </button>
                                    <button class="btn btn-sm batch-row-gen"
                                            disabled="@(_busy || JobRunning)"
                                            title="Generate this scene"
                                            @onclick="() => GenOneSceneAsync(sn)">
                                        Gen
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
else if (_detail is null)
{
    <p class="text-muted">Loading scene…</p>
}
else
{
    @* ---- Scene detail ---- *@
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                <strong>Scene @(_detail.SceneNumber.ToString("D2"))</strong>
                — @(_detail.Setting is { Length: > 0 } st ? st : "—")
            </span>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="onlyMissingDetail" @bind="_onlyMissing" disabled="@_busy" />
                    <label class="form-check-label" for="onlyMissingDetail">Only missing</label>
                </div>
                <button class="btn btn-sm btn-success"
                        disabled="@(_busy || JobRunning || (_detail.ClipsOnDisk == 0 && !_detail.CompositeExists))"
                        title="Play scene (auto-remux if missing or clips newer)"
                        @onclick="() => PlaySceneCompositeAsync(_detail.SceneNumber)">
                    ▶ Play scene
                </button>
                <button class="btn btn-sm btn-outline-primary"
                        disabled="@(_busy || JobRunning || _detail.ClipsOnDisk == 0)"
                        title="FFmpeg: concat this scene’s clips → composite (does not rebuild WIP)"
                        @onclick="() => RebuildSceneAsync(_detail.SceneNumber)">
                    Rebuild scene
                </button>
                <button class="btn btn-sm btn-primary"
                        disabled="@(_busy || JobRunning)"
                        @onclick="() => GenOneSceneAsync(_detail.SceneNumber)">
                    Generate scene
                </button>
            </div>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-2">
                @_detail.ClipsOnDisk/@_detail.ClipCount clips on disk
                @if (_detail.ActualDurationSeconds is double actD)
                {
                    <span>· <strong class="text-body">@FormatClock(actD)</strong> actual</span>
                    @if (_detail.PlannedDurationSeconds is double planD)
                    {
                        <span>· plan @FormatClock(planD)</span>
                    }
                }
                else if (_detail.PlannedDurationSeconds is double planOnly)
                {
                    <span>· plan ~@FormatClock(planOnly)</span>
                }
                @if (_detail.CompositeExists)
                {
                    <span class="badge bg-success ms-1">composite ready</span>
                }
                else if (_detail.ClipsOnDisk > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">composite needs rebuild</span>
                }
                @if (_detail.CharactersOnScreen.Count > 0)
                {
                    <span>· cast: @string.Join(", ", _detail.CharactersOnScreen.Select(ShortChar))</span>
                }
                @if (!string.IsNullOrEmpty(_detail.PrimaryLocationId))
                {
                    <span>· loc: <code>@_detail.PrimaryLocationId</code></span>
                }
            </p>

            @* Full scene composite — hide while inspecting a single clip so play isn't confused with C3 *@
            @if (_detail.CompositeExists && _selectedClip is null)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <h6 class="text-muted mb-0">Scene composite <span class="small fw-normal">(all clips · full scene)</span></h6>
                        <button class="btn btn-sm btn-link" type="button"
                                @onclick="() => PlaySceneCompositeAsync(_detail.SceneNumber)">
                            Play full scene
                        </button>
                    </div>
                    <video controls playsinline
                           style="max-width:100%; max-height:280px; background:#111; border-radius:0.35rem;"
                           src="@CacheBust(Engine.CompositeVideoUrl(_projectId, _detail.SceneNumber))"
                           @key="_inlineCompositeKey"
                           poster=""></video>
                    <p class="small text-muted mb-0 mt-1">
                        This is the remuxed scene (~@(_detail.ActualDurationSeconds is double ad ? FormatClock(ad) : "?")).
                        Select a clip row below to play one clip only.
                    </p>
                </div>
            }
            else if (_detail.CompositeExists && _selectedClip is int)
            {
                <p class="small text-muted mb-2">
                    Viewing single clip — full scene composite hidden.
                    <button type="button" class="btn btn-link btn-sm p-0 align-baseline" @onclick="() => SelectClip(null)">Show scene composite</button>
                </p>
            }

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Clip</th>
                            <th>Dur</th>
                            <th>Subject</th>
                            <th>Dialogue</th>
                            <th>Disk</th>
                            <th style="width:8rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _detail.Clips)
                        {
                            var active = _selectedClip == c.ClipNumber;
                            var cn = c.ClipNumber;
                            <tr class="@(active ? "table-primary" : "")" style="cursor:pointer;"
                                @onclick="() => SelectClip(cn)">
                                <td><code>C@(cn.ToString("D2"))</code></td>
                                <td class="small">
                                    @if (c.ActualDurationSeconds is double ca)
                                    {
                                        <span>@FormatClock(ca)</span>
                                        @if (c.DurationSeconds > 0 && Math.Abs(c.DurationSeconds - ca) > 1.5)
                                        {
                                            <span class="text-muted"> · plan @c.DurationSeconds s</span>
                                        }
                                    }
                                    else if (c.DurationSeconds > 0)
                                    {
                                        <span class="text-muted">~@c.DurationSeconds s</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="small">@Trunc(c.PrimarySubject, 28)</td>
                                <td class="small">@Trunc(c.Dialogue, 40)</td>
                                <td>
                                    @if (c.OnDisk)
                                    {
                                        <span class="badge bg-success">on disk</span>
                                        <span class="small text-muted">@FormatSize(c.SizeBytes)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">missing</span>
                                    }
                                </td>
                                <td @onclick:stopPropagation="true">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-dark"
                                                disabled="@(_busy || !c.OnDisk)"
                                                title="Play clip"
                                                @onclick="() => SelectClip(cn)">
                                            ▶
                                        </button>
                                        <button class="btn btn-outline-warning"
                                                disabled="@(_busy || JobRunning)"
                                                title="Force re-generate this clip"
                                                @onclick="() => RegenClipAsync(_detail.SceneNumber, cn)">
                                            Regen
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (_clip is not null)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span>
                    Clip <code>S@(_detail.SceneNumber.ToString("D2"))C@(_clip.ClipNumber.ToString("D2"))</code>
                    @if (!string.IsNullOrEmpty(_clip.Timestamp))
                    {
                        <span class="text-muted ms-2">@_clip.Timestamp</span>
                    }
                </span>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-warning"
                            disabled="@(_busy || JobRunning)"
                            title="Force re-generate this clip (overwrites if present)"
                            @onclick="() => RegenClipAsync(_detail.SceneNumber, _clip.ClipNumber)">
                        Regen clip
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => SelectClip(null)">Close</button>
                </div>
            </div>
            <div class="card-body row">
                <div class="col-md-5 mb-3">
                    @if (_clip.OnDisk)
                    {
                        <div class="small text-success mb-1">
                            Single clip only
                            @if (_clip.ActualDurationSeconds is double cad)
                            {
                                <span>· @FormatClock(cad)</span>
                            }
                            · not the full scene
                        </div>
                        <video controls playsinline autoplay
                               style="width:100%; max-height:320px; background:#111; border-radius:0.35rem;"
                               src="@CacheBust(Engine.ClipVideoUrl(_projectId, _detail.SceneNumber, _clip.ClipNumber))"
                               @key="@($"clip-{_detail.SceneNumber}-{_clip.ClipNumber}-{_clipVideoKey}")"
                               onloadeddata="this.play().catch(function(){})"></video>
                        <div class="small text-muted mt-1">
                            @_clip.FileName · @FormatSize(_clip.SizeBytes)
                            · <a href="@Engine.ClipVideoUrl(_projectId, _detail.SceneNumber, _clip.ClipNumber)" target="_blank" rel="noopener">open clip URL</a>
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-4 text-center text-muted">
                            No video on disk
                            <div class="mt-2">
                                <button class="btn btn-sm btn-warning"
                                        disabled="@(_busy || JobRunning)"
                                        @onclick="() => RegenClipAsync(_detail.SceneNumber, _clip.ClipNumber)">
                                    Generate this clip
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <h6>Visual prompt</h6>
                    <pre class="small bg-light border rounded p-2" style="max-height:200px; overflow:auto; white-space:pre-wrap;">@(_clip.VisualPrompt is { Length: > 0 } vp ? vp : "—")</pre>
                    @if (!string.IsNullOrWhiteSpace(_clip.NegativePrompt))
                    {
                        <h6>Negative</h6>
                        <pre class="small bg-light border rounded p-2" style="max-height:80px; overflow:auto; white-space:pre-wrap;">@_clip.NegativePrompt</pre>
                    }
                    <h6>Audio</h6>
                    <p class="small mb-1">
                        <strong>@(_clip.Speaker ?? "—")</strong>
                        @if (!string.IsNullOrEmpty(_clip.Delivery))
                        {
                            <span class="text-muted">· @_clip.Delivery</span>
                        }
                    </p>
                    <p class="small">@(_clip.Dialogue is { Length: > 0 } dlg ? dlg : "—")</p>
                    <p class="small text-muted mb-0">
                        subject: @(_clip.PrimarySubject is { Length: > 0 } ps ? ps : "—")
                        · continuation: @_clip.Continuation
                        · @_clip.DurationSeconds s
                    </p>
                </div>
            </div>
            <div class="card-footer small text-muted">
                After <strong>Regen</strong>, use <strong>Rebuild scene</strong> so the composite includes the new clip.
                Pass/fail: <a href="review">Review</a>. Full movie: rebuild WIP on Review.
            </div>
        </div>
    }
}

@code {
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "Buster";
    private List<string> _projectIds = new();
    private string _filter = "";
    private string _filterCharacter = "";
    private string _filterLocation = "";
    private bool _onlyMissing = true;
    private List<SceneSummary>? _scenes;
    private HashSet<int> _selected = new();
    private string _selectionMode = ""; // "" | incomplete | all
    private int? _selectedScene;
    private SceneDetail? _detail;
    private int? _selectedClip;
    private ClipSummary? _clip;
    private JobSnapshot? _job;
    private bool _wipExists;
    private bool _wipStale;
    private bool _wipCanBuild;
    private string? _wipReason;
    private bool _showWipPlayer;
    private bool _playWipAfterRemux;
    private int? _playSceneAfterRemux;
    private string? _wipPath;
    private string? _wipUpdatedAt;
    private long _wipBytes;
    private long _wipVideoKey;
    private bool _showScenePlayer;
    private int? _playingScene;
    private long _sceneVideoKey;
    private long _inlineCompositeKey;
    private long _clipVideoKey;

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase);

    private string WipPlayTitle =>
        !_wipCanBuild && !_wipExists
            ? "No scene/clip videos to build WIP"
            : _wipStale || !_wipExists
                ? $"Refresh then play: {_wipReason ?? "out of date"}"
                : "Play streamed movie_wip.mp4 (up to date)";

    private string SelectionMode => _selectionMode;

    private int IncompleteCount =>
        FilteredScenes.Count(s => s.ClipsOnDisk < s.ClipCount);

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filter) ||
        !string.IsNullOrWhiteSpace(_filterCharacter) ||
        !string.IsNullOrWhiteSpace(_filterLocation);

    private List<string> CharacterOptions =>
        _scenes is null
            ? new List<string>()
            : _scenes
                .SelectMany(s => s.CharactersOnScreen)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(c => ShortChar(c), StringComparer.OrdinalIgnoreCase)
                .ToList();

    private List<string> LocationOptions =>
        _scenes is null
            ? new List<string>()
            : _scenes
                .SelectMany(s =>
                {
                    var list = new List<string>(s.LocationIds);
                    if (!string.IsNullOrWhiteSpace(s.PrimaryLocationId))
                        list.Add(s.PrimaryLocationId!);
                    return list;
                })
                .Where(l => !string.IsNullOrWhiteSpace(l))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(ShortLoc, StringComparer.OrdinalIgnoreCase)
                .ToList();

    private List<SceneSummary> FilteredScenes
    {
        get
        {
            if (_scenes is null)
                return new List<SceneSummary>();

            IEnumerable<SceneSummary> q = _scenes;
            if (!string.IsNullOrWhiteSpace(_filter))
            {
                q = q.Where(s =>
                    (s.Setting ?? "").Contains(_filter, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_filterCharacter))
            {
                q = q.Where(s =>
                    s.CharactersOnScreen.Any(c =>
                        string.Equals(c, _filterCharacter, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(_filterLocation))
            {
                q = q.Where(s =>
                    string.Equals(s.PrimaryLocationId, _filterLocation, StringComparison.OrdinalIgnoreCase) ||
                    s.LocationIds.Any(l =>
                        string.Equals(l, _filterLocation, StringComparison.OrdinalIgnoreCase)));
            }

            return q.ToList();
        }
    }

    private void ClearFilters()
    {
        _filter = "";
        _filterCharacter = "";
        _filterLocation = "";
    }

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string> { "Buster" };
            if (projs?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];

            try
            {
                await Hub.StartAsync();
            }
            catch { /* SignalR optional for browse */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;

            await ReloadListAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        if (snap.Status is "done" or "error" or "cancelled")
            _ = InvokeAsync(async () =>
            {
                await SoftReloadAsync();
                if (snap.Status == "done" &&
                    string.Equals(snap.Kind, "remux", StringComparison.OrdinalIgnoreCase))
                {
                    await RefreshWipMetaAsync();
                    if (_playWipAfterRemux)
                    {
                        _playWipAfterRemux = false;
                        if (_wipExists)
                        {
                            _showWipPlayer = true;
                            _wipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                            _message = "WIP ready — player below";
                        }
                    }
                    else if (_playSceneAfterRemux is int playSn)
                    {
                        _playSceneAfterRemux = null;
                        _playingScene = playSn;
                        _showScenePlayer = true;
                        _sceneVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                        _inlineCompositeKey = _sceneVideoKey;
                        _message = $"Scene S{playSn:D2} ready — playing";
                    }
                    else if (snap.Scene is int sn && sn > 0)
                    {
                        _playingScene = sn;
                        _showScenePlayer = true;
                        _sceneVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                        _inlineCompositeKey = _sceneVideoKey;
                        _message = $"Scene S{sn:D2} composite rebuilt";
                    }
                }
                else if (snap.Status == "done" &&
                         string.Equals(snap.Kind, "scene", StringComparison.OrdinalIgnoreCase) &&
                         snap.Clip is int cn &&
                         snap.Scene is int gsn)
                {
                    _clipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                    _message = $"Clip S{gsn:D2}C{cn:D2} finished — rebuild scene composite if you want it in the cut";
                    if (_selectedClip == cn)
                        SelectClip(cn);
                }
                StateHasChanged();
            });
        else
            _ = InvokeAsync(StateHasChanged);
    }

    private void OnJobLog(string line)
    {
        if (_job is not null)
            _job.Message = line;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnProjectChangedAsync()
    {
        _selectedScene = null;
        _detail = null;
        _selectedClip = null;
        _clip = null;
        _selected.Clear();
        ClearFilters();
        await ReloadListAsync();
    }

    private async Task ReloadListAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetScenesAsync(_projectId);
            _scenes = dto?.Scenes ?? new List<SceneSummary>();
            // Drop selections that no longer exist
            _selected.RemoveWhere(sn => _scenes.All(s => s.SceneNumber != sn));
            if (_selectedScene is int sn)
                await LoadDetailAsync(sn);
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            await RefreshWipMetaAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _scenes = null;
        }
        finally { _busy = false; }
    }

    private async Task SoftReloadAsync()
    {
        try
        {
            var dto = await Engine.GetScenesAsync(_projectId);
            _scenes = dto?.Scenes ?? new List<SceneSummary>();
            await RefreshWipMetaAsync();
            if (_selectedScene is int sn)
            {
                var detail = await Engine.GetSceneDetailAsync(_projectId, sn);
                _detail = detail?.Scene;
                if (_selectedClip is int cn && _detail is not null)
                    _clip = _detail.Clips.FirstOrDefault(c => c.ClipNumber == cn);
            }
        }
        catch { /* ignore soft reload errors */ }
    }

    private async Task OpenSceneAsync(int sn)
    {
        _busy = true;
        _error = null;
        try
        {
            await LoadDetailAsync(sn);
            _selectedScene = sn;
            _selectedClip = null;
            _clip = null;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LoadDetailAsync(int sn)
    {
        var dto = await Engine.GetSceneDetailAsync(_projectId, sn);
        _detail = dto?.Scene
            ?? throw new InvalidOperationException($"Scene {sn} not found");
    }

    private async Task BackToListAsync()
    {
        _selectedScene = null;
        _detail = null;
        _selectedClip = null;
        _clip = null;
        await ReloadListAsync();
    }

    private void SelectClip(int? cn)
    {
        _selectedClip = cn;
        _clip = cn is int n
            ? _detail?.Clips.FirstOrDefault(c => c.ClipNumber == n)
            : null;
        if (cn is int)
        {
            // Force new <video> mount so we never keep a previous composite/clip stream
            _clipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            // Stop full-scene autoplay panel if open
            if (_showScenePlayer && _playingScene == _detail?.SceneNumber)
            {
                _showScenePlayer = false;
                _playingScene = null;
            }
        }
    }

    private async Task PlaySceneCompositeAsync(int sn)
    {
        var meta = await Engine.GetWipMovieMetaAsync(_projectId);
        var summary = _scenes?.FirstOrDefault(s => s.SceneNumber == sn);
        var compositeOk = summary?.CompositeExists == true
                          || (_detail is { SceneNumber: var dsn, CompositeExists: true } && dsn == sn);
        var clipsOnDisk = summary?.ClipsOnDisk
                          ?? (_detail is { SceneNumber: var d2 } && d2 == sn ? _detail.ClipsOnDisk : 0);
        var needsRemux = !compositeOk || meta?.StaleScenes?.Contains(sn) == true;

        if (needsRemux && clipsOnDisk > 0 && !JobRunning)
        {
            _busy = true;
            _error = null;
            try
            {
                await EnsureHubAsync();
                _playSceneAfterRemux = sn;
                await Engine.StartRemuxAsync(_projectId, sn, rebuildWip: false);
                _message = $"Rebuilding S{sn:D2} composite then play…";
                var jobs = await Engine.GetJobAsync();
                _job = jobs?.Job;
            }
            catch (Exception ex) { _error = ex.Message; _playSceneAfterRemux = null; }
            finally { _busy = false; }
            return;
        }

        if (!compositeOk)
        {
            _error = $"No composite for S{sn:D2} — generate clips or rebuild scene first";
            return;
        }

        _playingScene = sn;
        _showScenePlayer = true;
        _sceneVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _inlineCompositeKey = _sceneVideoKey;
        _message = $"Playing S{sn:D2} composite";
    }

    private void HideScenePlayer()
    {
        _showScenePlayer = false;
        _playingScene = null;
    }

    /// <summary>FFmpeg concat clips → scene composite only (not WIP).</summary>
    private async Task RebuildSceneAsync(int sn)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await EnsureHubAsync();
            await Engine.StartRemuxAsync(_projectId, sn, rebuildWip: false);
            _message = $"Rebuilding S{sn:D2} scene composite (clips → composite; WIP unchanged)";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    /// <summary>Force re-generate a single clip (onlyMissing: false).</summary>
    private async Task RegenClipAsync(int sn, int cn)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await EnsureHubAsync();
            await Engine.StartSceneGenAsync(_projectId, sn, onlyMissing: false, clip: cn);
            _message = $"Regenerating S{sn:D2}C{cn:D2}…";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private void ToggleSelect(int sn, bool on)
    {
        if (on) _selected.Add(sn);
        else _selected.Remove(sn);
        _selectionMode = "";
    }

    private void SelectIncomplete()
    {
        _selected = FilteredScenes
            .Where(s => s.ClipsOnDisk < s.ClipCount)
            .Select(s => s.SceneNumber)
            .ToHashSet();
        _selectionMode = "incomplete";
    }

    private void SelectAll()
    {
        _selected = FilteredScenes.Select(s => s.SceneNumber).ToHashSet();
        _selectionMode = "all";
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _selectionMode = "";
    }

    private int EstimateSelectedClips()
    {
        if (_scenes is null) return 0;
        var sum = 0;
        foreach (var s in _scenes.Where(x => _selected.Contains(x.SceneNumber)))
        {
            if (_onlyMissing)
                sum += Math.Max(0, s.ClipCount - s.ClipsOnDisk);
            else
                sum += s.ClipCount;
        }
        return sum;
    }

    private async Task GenOneSceneAsync(int sn)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await Engine.StartSceneGenAsync(_projectId, sn, _onlyMissing);
            _message = $"Started scene {sn}";
            await EnsureHubAsync();
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task StartBatchAsync()
    {
        if (_selected.Count == 0) return;
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            var list = _selected.OrderBy(x => x).ToList();
            await Engine.StartBatchGenAsync(_projectId, list, _onlyMissing);
            _message = $"Started batch for {list.Count} scene(s)";
            await EnsureHubAsync();
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task EnsureHubAsync()
    {
        if (Hub.IsConnected) return;
        try { await Hub.StartAsync(); } catch { /* ignore */ }
    }

    private static string StatusBadge(string status) => status switch
    {
        "complete" => "bg-success",
        "partial" => "bg-warning text-dark",
        _ => "bg-secondary",
    };

    private static string Trunc(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= n ? s : s[..(n - 1)] + "…";
    }

    private static string ShortChar(string key) =>
        key.Replace("Character_", "", StringComparison.OrdinalIgnoreCase).Replace('_', ' ');

    private static string ShortLoc(string key)
    {
        if (string.IsNullOrEmpty(key)) return "—";
        return key
            .Replace("Location_", "", StringComparison.OrdinalIgnoreCase)
            .Replace("Loc_", "", StringComparison.OrdinalIgnoreCase)
            .Replace('_', ' ');
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024):0.#} MB";
    }

    private async Task RefreshWipMetaAsync()
    {
        try
        {
            var meta = await Engine.GetWipMovieMetaAsync(_projectId);
            _wipExists = meta?.Exists == true;
            _wipStale = meta?.Stale == true || !_wipExists;
            _wipCanBuild = meta?.CanBuild == true;
            _wipReason = meta?.Reason;
            _wipPath = meta?.Path;
            _wipUpdatedAt = meta?.UpdatedAt;
            _wipBytes = meta?.Bytes ?? 0;
            if (!_wipExists)
                _showWipPlayer = false;
        }
        catch
        {
            _wipExists = false;
            _wipStale = true;
            _wipCanBuild = false;
        }
    }

    private async Task PlayWipAsync()
    {
        if (_showWipPlayer && _wipExists && !_wipStale)
        {
            await RefreshWipMetaAsync();
            if (_wipExists && !_wipStale)
            {
                _showWipPlayer = false;
                return;
            }
        }

        // Always re-check: scenes added/removed/out-of-date trigger auto-remux
        await RefreshWipMetaAsync();
        if (_wipExists && !_wipStale)
        {
            _showWipPlayer = true;
            _wipVideoKey = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            _message = "Playing WIP (up to date)";
            return;
        }

        if (!_wipCanBuild && !_wipExists)
        {
            _error = _wipReason ?? "Nothing on disk to build WIP";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            await EnsureHubAsync();
            _playWipAfterRemux = true;
            await Engine.StartRemuxAsync(_projectId, scene: null, rebuildWip: true, refreshStaleScenes: true);
            _message = $"Auto-remux then play… {_wipReason}";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; _playWipAfterRemux = false; }
        finally { _busy = false; }
    }

    private static string CacheBust(string url) =>
        url + (url.Contains('?') ? "&" : "?") + "v=" + DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    private static string FormatBytes(long n) => FormatSize(n);

    /// <summary>Format seconds as m:ss or plain seconds when under a minute.</summary>
    private static string FormatClock(double seconds)
    {
        if (seconds < 0) seconds = 0;
        var whole = (int)Math.Round(seconds);
        if (whole < 60) return $"{whole}s";
        var m = whole / 60;
        var s = whole % 60;
        return $"{m}:{s:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        // Don't dispose shared hub if Studio also uses it — JobHubClient is scoped per circuit usually.
        // Safe to leave connection; Studio page owns its own instance if scoped.
        await Task.CompletedTask;
    }
}
