@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models

<PageTitle>Film Studio</PageTitle>

<h1>Film Studio</h1>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (_healthOk == false)
{
    <div class="alert alert-warning">
        API not reachable. Start backend:
        <pre class="mb-0 mt-2">cd host/FilmStudio.Api
dotnet run</pre>
        Set <code>XAI_API_KEY</code> in that shell for generation.
    </div>
}

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">Projects</div>
            <div class="card-body">
                @if (_projects is null)
                {
                    <p class="text-muted">Loading…</p>
                }
                else
                {
                    <ul class="list-group mb-3">
                        @foreach (var p in _projects.Projects)
                        {
                            var id = p.Id ?? "";
                            var active = string.Equals(id, _projects.Active?.Id, StringComparison.OrdinalIgnoreCase);
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    <strong>@(p.Label ?? p.Title ?? id)</strong>
                                    @if (active) { <span class="badge bg-primary ms-1">active</span> }
                                </span>
                                <button class="btn btn-sm btn-outline-secondary" disabled="@(active || _busy)"
                                        @onclick="() => ActivateAsync(id)">Activate</button>
                            </li>
                        }
                    </ul>
                }
                <button class="btn btn-outline-primary btn-sm" disabled="@_busy" @onclick="RefreshAsync">Refresh</button>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header">Start generation (C# engine)</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">Project id</label>
                    <input class="form-control" @bind="_projectId" disabled="@_busy" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Scene number</label>
                    <input type="number" class="form-control" min="1" @bind="_scene" disabled="@_busy" />
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="onlyMissing" @bind="_onlyMissing" disabled="@_busy" />
                    <label class="form-check-label" for="onlyMissing">Only missing clips</label>
                </div>
                <button class="btn btn-primary me-2" disabled="@_busy" @onclick="StartGenAsync">Start scene gen</button>
                <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel</button>
                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="alert alert-info mt-3 mb-0">@_message</div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">Live job</div>
            <div class="card-body">
                @if (_job is null)
                {
                    <p class="text-muted mb-0">No job yet.</p>
                }
                else
                {
                    <p class="mb-1">
                        <span class="badge bg-secondary">@_job.Status</span>
                        @if (_job.Scene is int sn && _job.Clip is int cn)
                        {
                            <span class="ms-1">S@(sn.ToString("D2")) C@(cn.ToString("D2"))</span>
                        }
                        @if (_job.Total > 0)
                        {
                            <span class="ms-1">@_job.Index / @_job.Total</span>
                        }
                    </p>
                    <p class="small">@_job.Message</p>
                    @if (!string.IsNullOrEmpty(_job.Error))
                    {
                        <div class="alert alert-danger py-1 small">@_job.Error</div>
                    }
                    <pre class="small mb-0" style="max-height: 220px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(40))</pre>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool? _healthOk;
    private bool _busy;
    private string? _error;
    private string? _message;
    private ProjectsDto? _projects;
    private JobSnapshot? _job;
    private string _projectId = "Buster";
    private int _scene = 2;
    private bool _onlyMissing = true;

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        await RefreshAsync();
        try
        {
            await Hub.StartAsync();
        }
        catch
        {
            // SignalR optional for browse; job progress still works via poll/refresh
        }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnJobLog(string line)
    {
        // Snapshot usually already includes log; keep message fresh
        if (_job is not null)
            _job.Message = line;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            try
            {
                await Engine.EnsureHealthyAsync();
                _healthOk = true;
            }
            catch
            {
                _healthOk = false;
                _projects = null;
                return;
            }

            _projects = await Engine.GetProjectsAsync();
            if (_projects?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ActivateAsync(string id)
    {
        _busy = true;
        try
        {
            await Engine.ActivateProjectAsync(id);
            _projectId = id;
            await RefreshAsync();
            _message = $"Activated {id}";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task StartGenAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            await Engine.StartSceneGenAsync(_projectId, _scene, _onlyMissing);
            _message = $"Started scene {_scene}";
            if (!Hub.IsConnected)
            {
                try { await Hub.StartAsync(); } catch { /* ignore */ }
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Hub.DisposeAsync();
    }
}
