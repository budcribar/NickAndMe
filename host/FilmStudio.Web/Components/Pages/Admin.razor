@page "/admin"
@implements IAsyncDisposable
@inject EngineApiClient Api
@inject AdminSessionService Session
@inject JobHubClient Hub
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Admin — Film Studio</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h1 class="h3 mb-0">Admin dashboard</h1>
            <div class="text-muted small">
                Live ops · SignalR <code>admin:ops</code>
                @if (_hubLive)
                {
                    <span class="badge text-bg-success ms-1">live</span>
                }
                else
                {
                    <span class="badge text-bg-secondary ms-1">poll 5s</span>
                }
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            @if (Session.IsAuthenticated)
            {
                <span class="badge text-bg-secondary">@Session.UserId</span>
                <a class="btn btn-sm btn-outline-primary" href="/admin/config">Config</a>
                <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="LogoutAsync">Log out</button>
            }
        </div>
    </div>

    @if (!_started)
    {
        <p class="text-muted">Loading admin session…</p>
    }
    else if (!Session.IsAdmin)
    {
        <div class="alert alert-warning">
            Admin session required. <a href="/admin/login">Sign in</a>
        </div>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshAsync">Retry</button>
    }
    else if (_state is null)
    {
        <p class="text-muted">Loading server state…</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_actionMsg))
        {
            <div class="alert alert-info py-2">@_actionMsg</div>
        }

        @if (_state.Http is { } http)
        {
            <div class="alert @(http.NonAdminLast5Sec > 5 ? "alert-success" : "alert-warning") py-2 small">
                <strong>HTTP traffic</strong>
                · last 5s: <strong>@http.RequestsLast5Sec</strong> total
                · <strong>@http.NonAdminLast5Sec</strong> non-admin
                · last 30s non-admin: <strong>@http.NonAdminLast30Sec</strong>
                @if (http.NonAdminLast5Sec <= 2)
                {
                    <span class="ms-1">
                        — LoadSim does not appear to be hitting this API (only admin poll).
                        Check LoadSim console: “running…”, baseUrl <code>http://127.0.0.1:5088</code>, project <code>LoadSimBuster</code>.
                    </span>
                }
                @if (http.ByPrefixLast5Sec is { Count: > 0 } pref)
                {
                    <div class="mt-1 font-monospace" style="font-size:0.75rem;">
                        @foreach (var kv in pref.OrderByDescending(k => k.Value).Take(8))
                        {
                            <span class="me-2">@kv.Key=@(kv.Value)</span>
                        }
                    </div>
                }
            </div>
        }

        @* ── LoadSim live panel ─────────────────────────────────────────── *@
        <div class="card mb-3 border-0 shadow-sm loadsim-panel">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2"
                 style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); color: #e2e8f0;">
                <div>
                    <strong>LoadSim</strong>
                    @if (_loadSim?.Active == true)
                    {
                        <span class="badge bg-success ms-2">LIVE</span>
                    }
                    else if (_loadSim?.Latest is not null)
                    {
                        <span class="badge bg-secondary ms-2">@(_loadSim.Latest.Status ?? "idle")</span>
                    }
                    else
                    {
                        <span class="badge bg-dark ms-2">idle</span>
                    }
                </div>
                @if (_loadSim?.Latest is { } ls)
                {
                    <div class="small" style="opacity:0.9;">
                        run <code class="text-info">@ls.RunId</code>
                        · @ls.Users VU · @ls.Scenario · @ls.ProjectId
                        · @ls.ElapsedSec.ToString("0")s / @ls.DurationSec s
                        @if (ls.Passed == true) { <span class="badge bg-success ms-1">PASS</span> }
                        else if (ls.Passed == false) { <span class="badge bg-danger ms-1">FAIL</span> }
                    </div>
                }
            </div>
            <div class="card-body" style="background:#0b1220; color:#cbd5e1;">
                @if (_loadSim?.Latest is null)
                {
                    <p class="small mb-0" style="opacity:0.7;">
                        No LoadSim telemetry yet. Start LoadSim — it posts every 2s to
                        <code class="text-info">POST /api/loadsim/progress</code>.
                    </p>
                }
                else
                {
                    var L = _loadSim.Latest;
                    <div class="row g-2 mb-3 text-center">
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.ActionsTotal.ToString("N0")</div>
                                <div class="loadsim-kpi__lbl">actions</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.ActionsPerSec.ToString("0.0")</div>
                                <div class="loadsim-kpi__lbl">actions/s</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val @(L.ErrorRate > 0.01 ? "text-warning" : "text-success")">
                                    @((L.ErrorRate * 100).ToString("0.00"))%
                                </div>
                                <div class="loadsim-kpi__lbl">error rate</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.BrowseP95Ms<span class="fs-6">ms</span></div>
                                <div class="loadsim-kpi__lbl">browse p95</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.P50Ms<span class="fs-6">ms</span></div>
                                <div class="loadsim-kpi__lbl">p50 latency</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.JobsSubmitted</div>
                                <div class="loadsim-kpi__lbl">jobs ok</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val">@L.JobsRejected</div>
                                <div class="loadsim-kpi__lbl">409 rejects</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="loadsim-kpi">
                                <div class="loadsim-kpi__val @(L.Jobs5xx > 0 ? "text-danger" : "")">@L.Jobs5xx</div>
                                <div class="loadsim-kpi__lbl">5xx</div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <div class="loadsim-chart-wrap">
                                <div class="loadsim-chart-title">Throughput</div>
                                <canvas id="chartLoadSimThroughput"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="loadsim-chart-wrap">
                                <div class="loadsim-chart-title">Latency &amp; errors</div>
                                <canvas id="chartLoadSimLatency"></canvas>
                            </div>
                        </div>
                    </div>
                    @if (L.ActionsByType is { Count: > 0 } acts)
                    {
                        <div class="mt-2 small font-monospace" style="opacity:0.8;">
                            @foreach (var kv in acts.OrderByDescending(a => a.Value).Take(10))
                            {
                                <span class="me-2">@kv.Key=@(kv.Value)</span>
                            }
                        </div>
                    }
                }

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <div class="loadsim-chart-wrap loadsim-chart-wrap--tall">
                            <div class="loadsim-chart-title">
                                Process memory
                                @if (_state.Process is { } proc)
                                {
                                    <span class="ms-2" style="font-weight:400; opacity:0.85;">
                                        WS <strong>@proc.WorkingSetMb</strong> MB · GC <strong>@proc.GcHeapMb</strong> MB · threads @proc.ThreadCount
                                    </span>
                                }
                            </div>
                            <canvas id="chartProcessMemory"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header">Process</div>
                    <div class="card-body small">
                        <div>Uptime: <strong>@FormatUptime(_state.Process?.UptimeSec ?? 0)</strong></div>
                        <div>Working set: <strong>@(_state.Process?.WorkingSetMb ?? 0) MB</strong></div>
                        <div>GC heap: <strong>@(_state.Process?.GcHeapMb ?? 0) MB</strong></div>
                        <div>Threads: <strong>@(_state.Process?.ThreadCount ?? 0)</strong></div>
                        <div>Env: <strong>@(_state.Process?.Environment ?? "?")</strong></div>
                        <div>Fakes: <strong>@((_state.Process?.UseFakes ?? false) ? "ON" : "off")</strong></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header">Capacity</div>
                    <div class="card-body small">
                        @if (_state.Capacity is { } c)
                        {
                            <div>MaxVideoInFlight: <strong>@c.MaxVideoInFlight</strong></div>
                            <div>MaxVideoInFlightPerUser: <strong>@c.MaxVideoInFlightPerUser</strong></div>
                            <div>MaxFfmpegInFlight: <strong>@c.MaxFfmpegInFlight</strong></div>
                            <div>MaxQueuePerUser: <strong>@c.MaxQueuePerUser</strong></div>
                        }
                        <div class="mt-2">
                            API in-flight: <strong>@_apiInFlight</strong> · FFmpeg: <strong>@_ffmpegInFlight</strong>
                        </div>
                        <div>Rejects: <strong>@_capacityRejects</strong> · Lock conflicts: <strong>@_lockConflicts</strong></div>
                        <a class="btn btn-sm btn-link px-0" href="/admin/config">Edit capacity…</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header">Projects</div>
                    <div class="card-body small">
                        <div>Active: <strong>@(_state.Projects?.Active ?? "—")</strong></div>
                        <div class="text-truncate" title="@_state.Projects?.Workspace">
                            Workspace: <code class="small">@(_state.Projects?.Workspace ?? "—")</code>
                        </div>
                        <div class="mt-2 text-muted">
                            Snapshot @(_state.GeneratedAt?.ToLocalTime().ToString("HH:mm:ss") ?? "—")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header d-flex justify-content-between">
                        <span>Jobs (running / queued)</span>
                        <span class="badge text-bg-primary">@(_state.Jobs?.Count ?? 0)</span>
                    </div>
                    <div class="card-body p-0">
                        @if (_state.Jobs?.Items is { Count: > 0 } items)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0">
                                    <thead>
                                    <tr>
                                        <th>Job</th>
                                        <th>User</th>
                                        <th>Kind</th>
                                        <th>Scene</th>
                                        <th>Status</th>
                                        <th>Progress</th>
                                        <th>Age</th>
                                        <th></th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var j in items)
                                    {
                                        <tr>
                                            <td class="font-monospace small">@(ShortId(j.JobId))</td>
                                            <td>@(j.UserId ?? "—")</td>
                                            <td>@(j.Kind ?? "—")</td>
                                            <td>@(j.Scene?.ToString() ?? "—")</td>
                                            <td>@(j.Status ?? "—")</td>
                                            <td>@(j.Total > 0 ? $"{j.Index}/{j.Total}" : "—")</td>
                                            <td>@FormatAge(j.AgeMs)</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        disabled="@_busy || string.IsNullOrEmpty(j.JobId)"
                                                        @onclick="() => CancelJobAsync(j.JobId!)">
                                                    Cancel
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted p-3 mb-0">No active jobs.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card">
                    <div class="card-header d-flex justify-content-between">
                        <span>Locks</span>
                        <span class="badge text-bg-secondary">@_locks.Count</span>
                    </div>
                    <div class="card-body p-0">
                        @if (_locks.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0 small">No active locks.</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush small">
                                @foreach (var l in _locks.Take(20))
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-start py-2">
                                        <div>
                                            <code>@l.Resource</code>
                                            <div>@l.UserId
                                                @if (!string.IsNullOrEmpty(l.Reason))
                                                {
                                                    <span class="text-muted"> · @l.Reason</span>
                                                }
                                            </div>
                                        </div>
                                        <button class="btn btn-sm btn-outline-warning"
                                                disabled="@_busy || string.IsNullOrEmpty(l.Resource)"
                                                @onclick="() => ReleaseLockAsync(l.Resource!)">
                                            Force release
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private AdminStateDto? _state;
    private string? _error;
    private string? _actionMsg;
    private bool _busy;
    private bool _hubLive;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _pollCts;
    private int _apiInFlight;
    private int _ffmpegInFlight;
    private int _capacityRejects;
    private int _lockConflicts;
    private List<AdminLockDto> _locks = new();
    private LoadSimLiveStateDto? _loadSim;
    private List<ProcessSampleDto> _processHistory = new();

    private bool _started;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        await Session.EnsureHydratedAsync();
        if (!Session.IsAdmin)
        {
            Nav.NavigateTo("/admin/login", forceLoad: true);
            return;
        }

        StateHasChanged();

        Hub.AdminState += OnAdminState;
        // Do not block UI on SignalR
        _ = ConnectHubAsync();
        await RefreshAsync();
        StateHasChanged();

        _pollCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = PollLoopAsync(_pollCts.Token);
    }

    private async Task ConnectHubAsync()
    {
        try
        {
            await Hub.StartAsync();
            _hubLive = Hub.IsConnected;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _hubLive = false;
        }
    }

    private void OnAdminState(object? _)
    {
        _hubLive = true;
        _ = InvokeAsync(RefreshAsync);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            while (_timer is not null && await _timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    await RefreshAsync();
                    await InvokeAsync(StateHasChanged);
                }
                catch { /* keep polling */ }
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task RefreshAsync()
    {
        if (!Session.IsAdmin) return;
        _busy = true;
        try
        {
            _state = await Api.GetAdminStateAsync();
            if (_state is not null)
            {
                _apiInFlight = _state.ApiInFlight;
                _ffmpegInFlight = _state.FfmpegInFlight;
                _capacityRejects = _state.CapacityRejects;
                _lockConflicts = _state.LockConflicts;
                _locks = _state.Locks ?? new();
                _loadSim = _state.LoadSim;
                _processHistory = _state.ProcessHistory ?? new();
            }
            _error = null;
            await UpdateChartsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            // Only hard-logout on clear auth failures (not every message containing "admin")
            var msg = ex.Message;
            if (msg.Contains("403", StringComparison.Ordinal) ||
                msg.Contains("401", StringComparison.Ordinal) ||
                msg.Contains("admin role required", StringComparison.OrdinalIgnoreCase) ||
                msg.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase))
            {
                Session.Clear();
                Nav.NavigateTo("/admin/login", forceLoad: true);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CancelJobAsync(string jobId)
    {
        _busy = true;
        _actionMsg = null;
        try
        {
            await Api.AdminCancelJobAsync(jobId);
            _actionMsg = $"Cancel requested for {jobId}";
            await RefreshAsync();
        }
        catch (Exception ex) { _actionMsg = ex.Message; }
        finally { _busy = false; }
    }

    private async Task ReleaseLockAsync(string resource)
    {
        _busy = true;
        _actionMsg = null;
        try
        {
            await Api.AdminReleaseLockAsync(resource, force: true);
            _actionMsg = $"Released {resource}";
            await RefreshAsync();
        }
        catch (Exception ex) { _actionMsg = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LogoutAsync()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/admin/login");
    }

    private async Task UpdateChartsAsync()
    {
        try
        {
            if (_loadSim?.History is { Count: > 0 } hist)
            {
                var labels = hist.Select(h =>
                    TimeSpan.FromSeconds(Math.Max(0, h.ElapsedSec)).ToString(@"m\:ss")).ToArray();
                var actionsPerSec = hist.Select(h => h.ActionsPerSec).ToArray();
                var actionsTotal = hist.Select(h => (double)h.ActionsTotal).ToArray();
                var p50 = hist.Select(h => (double)h.P50Ms).ToArray();
                var browseP95 = hist.Select(h => (double)h.BrowseP95Ms).ToArray();
                var errPct = hist.Select(h => h.ErrorRate * 100.0).ToArray();

                await Js.InvokeVoidAsync("filmStudioCharts.upsertLine",
                    "chartLoadSimThroughput",
                    labels,
                    new object[]
                    {
                        new { label = "actions/s", data = actionsPerSec, color = "#38bdf8", yAxisID = "y" },
                        new { label = "total actions", data = actionsTotal, color = "#a78bfa", yAxisID = "y1" },
                    },
                    new { dualY = true, yTitle = "actions/s", y2Title = "total" });

                await Js.InvokeVoidAsync("filmStudioCharts.upsertLine",
                    "chartLoadSimLatency",
                    labels,
                    new object[]
                    {
                        new { label = "p50 ms", data = p50, color = "#34d399", yAxisID = "y" },
                        new { label = "browse p95 ms", data = browseP95, color = "#fbbf24", yAxisID = "y" },
                        new { label = "error %", data = errPct, color = "#f87171", yAxisID = "y1" },
                    },
                    new { dualY = true, yTitle = "latency ms", y2Title = "error %" });
            }

            if (_processHistory is { Count: > 0 } mem)
            {
                var memLabels = mem.Select(s => s.At.ToLocalTime().ToString("HH:mm:ss")).ToArray();
                var ws = mem.Select(s => s.WorkingSetMb).ToArray();
                var gc = mem.Select(s => s.GcHeapMb).ToArray();
                var threads = mem.Select(s => (double)s.ThreadCount).ToArray();

                await Js.InvokeVoidAsync("filmStudioCharts.upsertLine",
                    "chartProcessMemory",
                    memLabels,
                    new object[]
                    {
                        new { label = "Working set (MB)", data = ws, color = "#22d3ee", yAxisID = "y" },
                        new { label = "GC heap (MB)", data = gc, color = "#c084fc", yAxisID = "y" },
                        new { label = "Threads", data = threads, color = "#fb7185", yAxisID = "y1" },
                    },
                    new { dualY = true, yTitle = "MB", y2Title = "threads" });
            }
        }
        catch
        {
            // Chart.js not ready
        }
    }

    private static string FormatUptime(long sec)
    {
        if (sec < 60) return $"{sec}s";
        if (sec < 3600) return $"{sec / 60}m {sec % 60}s";
        return $"{sec / 3600}h {(sec % 3600) / 60}m";
    }

    private static string FormatAge(long? ms)
    {
        if (ms is null or < 0) return "—";
        var s = ms.Value / 1000.0;
        if (s < 60) return $"{s:0}s";
        if (s < 3600) return $"{s / 60:0.0}m";
        return $"{s / 3600:0.0}h";
    }

    private static string ShortId(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "—";
        return id.Length <= 10 ? id : id[..8] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        Hub.AdminState -= OnAdminState;
        _pollCts?.Cancel();
        _timer?.Dispose();
        _pollCts?.Dispose();
        await Hub.DisposeAsync();
    }
}
