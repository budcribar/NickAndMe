@page "/characters"
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models

<PageTitle>Characters</PageTitle>

<h1>Characters</h1>
<p class="text-muted">
    Click a character → set their look. Your <strong>preferred picture</strong> and
    <strong>description</strong> are used when creating new portraits.
    <strong>Book pictures</strong> from the story can help if you’ve matched them.
</p>
@if (_plates is not null && !_plates.SortedByCharacter)
{
    <div class="alert alert-warning d-flex flex-wrap align-items-center justify-content-between gap-2 py-2 mb-3">
        <div>
            <strong>Book pictures aren’t matched to the cast yet.</strong>
            <span class="small d-block text-muted">
                Match each book picture to the right character. Text-only pages are skipped.
            </span>
        </div>
        <div class="d-flex gap-2">
            @if (PlateSortRunning)
            {
                <button type="button" class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">
                    Cancel
                </button>
            }
            else
            {
                <button type="button" class="btn btn-warning"
                        disabled="@(_busy || JobRunning)"
                        @onclick="() => StartSortCharacterPlatesAsync(useGrok: true)">
                    Find characters
                </button>
            }
        </div>
    </div>
}
else if (_plates is not null && _plates.SortedByCharacter)
{
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <span class="badge text-bg-success">Book pictures matched</span>
        <span class="small text-muted">
            @_plates.SortedAt
        </span>
        @if (PlateSortRunning)
        {
            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">
                Cancel
            </button>
        }
        else
        {
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    disabled="@(_busy || JobRunning)"
                    @onclick="() => StartSortCharacterPlatesAsync(useGrok: true)"
                    title="Match book pictures to cast again">
                Find characters again
            </button>
        }
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="OnProjectChangedAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-outline-primary" disabled="@_busy" @onclick="LoadAsync">Reload</button>
        @if (JobRunning)
        {
            <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel job</button>
        }
    </div>
</div>

@* Show progress / failure only — hide the card after a successful done *@
@if (_job is not null &&
     (_job.Kind is "character" or "character-plates") &&
     _job.Status is "running" or "error" or "cancelled")
{
    <div class="card mb-3 border-@(_job.Status == "running" ? "primary" : _job.Status == "error" ? "danger" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <span class="badge bg-secondary">@_job.Status</span>
                <span class="badge bg-info text-dark">@_job.Kind</span>
                @if (!string.IsNullOrEmpty(_job.CharKey))
                {
                    <code class="small">@_job.CharKey</code>
                }
                @if (_job.Total > 0)
                {
                    <span class="small text-muted">@_job.Index / @_job.Total</span>
                }
                <span class="small">@_job.Message</span>
                @if (_job.Status == "running")
                {
                    <button type="button" class="btn btn-sm btn-outline-danger ms-auto" disabled="@_busy" @onclick="CancelAsync">
                        Cancel
                    </button>
                }
            </div>
            @if (_job.Status == "running" && _job.Total > 0)
            {
                var pct = (int)Math.Round(100.0 * Math.Clamp(_job.Index, 0, _job.Total) / Math.Max(1, _job.Total));
                <div class="progress mt-2" style="height: 0.5rem;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: @(Math.Max(8, pct))%"></div>
                </div>
            }
            @if (_job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 120px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(16))</pre>
            }
        </div>
    </div>
}

@if (_chars is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_chars.Count == 0)
{
    <div class="alert alert-warning">
        No cast yet. Finish the <strong>story outline</strong> in Adaptation first.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                @foreach (var c in _chars)
                {
                    var active = c.Key == _selectedKey;
                    <button type="button"
                            class="list-group-item list-group-item-action @(active ? "active" : "")"
                            @onclick="() => Select(c.Key)">
                        @(c.DisplayName)
                        @if (c.VoiceOnly)
                        {
                            <span class="badge bg-secondary ms-1">voice</span>
                        }
                        else if (c.Locked)
                        {
                            <span class="badge bg-success ms-1">locked</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-1">no ref</span>
                        }
                    </button>
                }
            </div>
        </div>
        <div class="col-md-9">
            @if (_selected is null)
            {
                <p class="text-muted">Click a character on the left to set a preferred look and choose how to generate.</p>
            }
            else if (_selected.VoiceOnly)
            {
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><code>@_selected.Key</code> — @_selected.DisplayName</span>
                        <span class="badge bg-secondary">voice-only (no image)</span>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">
                            <strong>Voice style</strong> — used when this character speaks (for example narrator voice-over).
                        </p>
                        @RenderVoiceEditor()
                    </div>
                </div>
            }
            else
            {
                @* ---- Character summary (compact) ---- *@
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span><code>@_selected.Key</code> — @_selected.DisplayName</span>
                        @if (_selected.Locked)
                        {
                            <span class="badge bg-success">locked</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">needs lock</span>
                        }
                    </div>
                    <div class="card-body row g-3 align-items-start">
                        <div class="col-auto">
                            @if (PreferredImageUrl is { Length: > 0 } prefUrl)
                            {
                                <img src="@prefUrl"
                                     alt="Preferred"
                                     class="rounded border"
                                     style="width: 120px; height: 120px; object-fit: contain; background: #f8f9fa;" />
                                <div class="small text-muted mt-1">@PreferredImageLabel</div>
                            }
                            else
                            {
                                <div class="rounded border d-flex align-items-center justify-content-center text-muted small"
                                     style="width: 120px; height: 120px; background: #f8f9fa;">No preferred image</div>
                            }
                        </div>
                        <div class="col char-meta">
                            @if (_mode != Mode.PickSource)
                            {
                                <div class="small"><strong>Description</strong> — @Trunc(_selected.Description, 160)</div>
                                <div class="small mt-1"><strong>Visual</strong> — @Trunc(_selected.VisualLock, 120)</div>
                                <div class="small mt-1">
                                    <strong>Book pictures</strong>
                                    (@(_selected.BookRefs.Count(b => b.Exists)) picture(s))
                                </div>
                                <button type="button" class="btn btn-sm btn-link px-0 mt-1" @onclick="BackToSource">← Back to regenerate</button>
                            }
                            @if (_selected.Locked)
                            {
                                <button type="button" class="btn btn-sm btn-outline-warning mt-1" disabled="@_busy"
                                        title="Clear official lock for video gen; keep the image as preferred (variant 1)"
                                        @onclick="UnlockAsync">
                                    Unlock (keep as best)
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header py-2">Voice (video gen)</div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">
                            <strong>Voice style</strong> when this character speaks. Save stores it for this project.
                        </p>
                        @RenderVoiceEditor()
                    </div>
                </div>

                @if (_mode == Mode.PickSource)
                {
                    <div class="card mb-3 border-primary">
                        <div class="card-header py-2 d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <strong>1) Pick pictures → edit description → generate → compare</strong>
                                <span class="small text-muted ms-2">
                                    select any · use top @ApiMaxSeedRefs
                                </span>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <div class="form-check form-check-inline mb-0">
                                    <input class="form-check-input" type="checkbox" id="hideUnsel"
                                           @bind="_hideUnselectedSeeds" disabled="@(_busy || JobRunning)" />
                                    <label class="form-check-label small" for="hideUnsel">Hide unselected</label>
                                </div>
                                @if (_hiddenSeedKeys.Count > 0)
                                {
                                    <button type="button" class="btn btn-sm btn-link py-0"
                                            disabled="@(_busy || JobRunning)"
                                            @onclick="() => { _hiddenSeedKeys.Clear(); }">
                                        Show @_hiddenSeedKeys.Count hidden
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-2 small fw-semibold">
                                Reference pictures — click to use (order = priority)
                            </div>
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                @* Preferred *@
                                @if (_selected.HasPreferred && SeedTileVisible("p", isOn: SeedRank("p") > 0))
                                {
                                    var prefKey = "p";
                                    var prefOn = SeedRank(prefKey) > 0;
                                    var prefRank = SeedRank(prefKey);
                                    var prefSend = prefRank > 0 && prefRank <= ApiMaxSeedRefs;
                                    <div class="char-seed-tile-wrap">
                                        <button type="button"
                                                class="char-seed-tile @(prefOn ? "char-seed-tile--on" : "") @(prefSend ? "char-seed-tile--send" : "")"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => ToggleSeedKey(prefKey))"
                                                title="@(_selected.PreferredLabel ?? "Preferred")">
                                            @if (prefRank > 0)
                                            {
                                                <span class="char-seed-tile__rank @(prefSend ? "char-seed-tile__rank--send" : "")">@prefRank</span>
                                            }
                                            @if (PreferredImageUrl is { Length: > 0 } pu)
                                            {
                                                <img src="@pu" alt="Preferred" />
                                            }
                                            <span class="char-seed-tile__label">Preferred</span>
                                        </button>
                                        <button type="button" class="char-seed-hide" title="Hide this picture"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => HideSeedKey(prefKey))">×</button>
                                    </div>
                                }
                                @foreach (var v in _selected.Variants.Where(x => x.Exists))
                                {
                                    var idx = v.Index ?? 0;
                                    var key = $"v{idx}";
                                    if (!SeedTileVisible(key, isOn: SeedRank(key) > 0)) continue;
                                    var on = SeedRank(key) > 0;
                                    var rank = SeedRank(key);
                                    var send = rank > 0 && rank <= ApiMaxSeedRefs;
                                    var vsrc = !string.IsNullOrEmpty(v.Url)
                                        ? CacheBust(v.Url!)
                                        : CacheBust(Engine.CharacterVariantUrl(_projectId, _selected.Key, idx));
                                    <div class="char-seed-tile-wrap">
                                        <button type="button"
                                                class="char-seed-tile @(on ? "char-seed-tile--on" : "") @(send ? "char-seed-tile--send" : "")"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => ToggleSeedKey(key))"
                                                title="Variant @idx">
                                            @if (rank > 0)
                                            {
                                                <span class="char-seed-tile__rank @(send ? "char-seed-tile__rank--send" : "")">@rank</span>
                                            }
                                            <img src="@vsrc" alt="V@(idx)" />
                                            <span class="char-seed-tile__label">V@(idx)</span>
                                        </button>
                                        <button type="button" class="char-seed-hide" title="Hide this picture"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => HideSeedKey(key))">×</button>
                                    </div>
                                }
                                @foreach (var b in _selected.BookRefs.Where(x => x.Exists))
                                {
                                    var bi = b.Index ?? 0;
                                    var key = $"b{bi}";
                                    if (!SeedTileVisible(key, isOn: SeedRank(key) > 0)) continue;
                                    var on = SeedRank(key) > 0;
                                    var rank = SeedRank(key);
                                    var send = rank > 0 && rank <= ApiMaxSeedRefs;
                                    var src = !string.IsNullOrEmpty(b.Url)
                                        ? CacheBust(b.Url!)
                                        : CacheBust(Engine.CharacterBookRefUrl(_projectId, _selected.Key, bi));
                                    <div class="char-seed-tile-wrap">
                                        <button type="button"
                                                class="char-seed-tile @(on ? "char-seed-tile--on" : "") @(send ? "char-seed-tile--send" : "")"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => ToggleSeedKey(key))"
                                                title="@b.FileName">
                                            @if (rank > 0)
                                            {
                                                <span class="char-seed-tile__rank @(send ? "char-seed-tile__rank--send" : "")">@rank</span>
                                            }
                                            <img src="@src" alt="B@(bi)" />
                                            <span class="char-seed-tile__label">B@(bi)</span>
                                        </button>
                                        <button type="button" class="char-seed-hide" title="Hide this picture"
                                                disabled="@(_busy || JobRunning)"
                                                @onclick="@(() => HideSeedKey(key))">×</button>
                                    </div>
                                }
                                @if (!_selected.HasPreferred &&
                                     !_selected.Variants.Any(v => v.Exists) &&
                                     !_selected.BookRefs.Any(b => b.Exists))
                                {
                                    <span class="small text-muted">No images yet — generate from description only, or find characters again.</span>
                                }
                            </div>
                            <div class="small text-muted mb-3">
                                Selected: <strong>@SelectedSeedCount</strong>
                                @if (SelectedSeedCount > 0)
                                {
                                    <text>
                                        · using <strong>@Math.Min(SelectedSeedCount, ApiMaxSeedRefs)</strong>
                                        (max @ApiMaxSeedRefs)
                                    </text>
                                }
                                @if (SelectedSeedCount > ApiMaxSeedRefs)
                                {
                                    <span class="text-muted"> — lower ranks kept for ordering only</span>
                                }
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-semibold mb-1">Description</label>
                                <textarea class="form-control form-control-sm" rows="3"
                                          @bind="_editDescription" @bind:event="oninput"
                                          disabled="@(_busy || JobRunning)"
                                          placeholder="How this character looks for portrait continuity…"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold mb-1">Visual lock (optional)</label>
                                <textarea class="form-control form-control-sm" rows="2"
                                          @bind="_editVisualLock" @bind:event="oninput"
                                          disabled="@(_busy || JobRunning)"
                                          placeholder="Hard constraints: coat color, markings…"></textarea>
                            </div>

                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <button type="button" class="btn btn-primary"
                                        disabled="@(_busy || JobRunning || string.IsNullOrWhiteSpace(_editDescription) && SelectedSeedCount == 0)"
                                        @onclick="StartRegenerateAsync">
                                    Regenerate → compare
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                        disabled="@(_busy || JobRunning)"
                                        @onclick="StartGeneratePreferred"
                                        title="Preferred image only + description">
                                    Preferred only
                                </button>
                                <span class="small text-muted">
                                    @(_selected.Locked || _selected.HasPreferred ? "1 refine" : "3 variants") then left/right compare
                                </span>
                            </div>
                        </div>
                    </div>

                    <p class="small text-muted mb-0">
                        After generate finishes, pick a champion and lock for video.
                    </p>
                }
                else if (_mode == Mode.WaitingGenerate)
                {
                    <div class="alert alert-info mb-0">
                        Generating portraits with preferred image + description
                        @if (_selected.BookRefs.Any(b => b.Exists))
                        {
                            <text> + book hints</text>
                        }
                        … left/right comparison starts when ready.
                    </div>
                }
                else if (_mode == Mode.Compare && _champion is not null)
                {
                    <div class="char-compare">
                        <div class="char-compare__head">
                            <div class="char-compare__title">2) Pick the better look</div>
                            <div class="char-compare__step">
                                @if (_challenger is null)
                                {
                                    <text>Champion ready · no more candidates</text>
                                }
                                else
                                {
                                    <text>Round @_round of @_totalRounds · @_remainingAfter challenger(s) left after this</text>
                                }
                            </div>
                        </div>

                        <div class="char-compare__pair">
                            <div class="char-compare__side @(_highlight == Side.Left ? "char-compare__side--pick" : "")">
                                <div class="char-compare__label">Left — current best</div>
                                <div class="char-compare__img-wrap">
                                    <img src="@_champion.Url" alt="@_champion.Label" />
                                </div>
                                <div class="char-compare__caption">@_champion.Label</div>
                            </div>
                            <div class="char-compare__vs">VS</div>
                            <div class="char-compare__side @(_highlight == Side.Right ? "char-compare__side--pick" : "")">
                                <div class="char-compare__label">Right — candidate</div>
                                <div class="char-compare__img-wrap">
                                    @if (_challenger is not null)
                                    {
                                        <img src="@_challenger.Url" alt="@_challenger.Label" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No more candidates</span>
                                    }
                                </div>
                                <div class="char-compare__caption">@(_challenger?.Label ?? "—")</div>
                            </div>
                        </div>

                        <div class="char-compare__actions">
                            @if (_challenger is not null)
                            {
                                <button type="button" class="btn btn-outline-primary btn-lg"
                                        disabled="@(_busy || JobRunning)" @onclick="PreferLeft">
                                    ◀ Left better
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-lg"
                                        disabled="@(_busy || JobRunning)" @onclick="PreferRight">
                                    Right better ▶
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-primary btn-lg"
                                        disabled="@(_busy || JobRunning)"
                                        @onclick="TryRegenFromCompareAsync"
                                        title="Generate new options using the same references / description">
                                    ↻ Try regen again
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-lg"
                                        disabled="@(_busy || JobRunning)"
                                        @onclick="BackToSource"
                                        title="Change references or description first">
                                    Change references
                                </button>
                            }
                            <button type="button" class="btn btn-success btn-lg"
                                    disabled="@(_busy || JobRunning)" @onclick="LockChampionAsync">
                                ✓ Lock left as final
                            </button>
                        </div>
                        <div class="char-compare__hint">
                            @if (_challenger is null)
                            {
                                <text>
                                    Happy with the left? Lock it. Want another round? <strong>Try regen again</strong>
                                    uses the same references, or <strong>Change references</strong> to pick different pictures.
                                </text>
                            }
                            else
                            {
                                <text>
                                    Like an eye exam: keep the better image on the left until you’re happy, then lock.
                                    Keyboard: <kbd>L</kbd> left · <kbd>R</kbd> right · <kbd>Enter</kbd> lock
                                </text>
                            }
                        </div>

                        @if (_allCandidates.Count > 0)
                        {
                            <div class="char-thumb-strip" title="Candidate queue">
                                @for (var i = 0; i < _allCandidates.Count; i++)
                                {
                                    var c = _allCandidates[i];
                                    var cls = i < _queueIndex
                                        ? "char-thumb char-thumb--done"
                                        : i == _queueIndex && _challenger is not null
                                            ? "char-thumb char-thumb--current"
                                            : "char-thumb";
                                    <img src="@c.Url" alt="@c.Label" class="@cls" />
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private enum Mode { PickSource, WaitingGenerate, Compare }
    private enum Side { None, Left, Right }

    private sealed class Candidate
    {
        public string Kind { get; init; } = ""; // book | variant | locked | preferred
        public int Index { get; init; }
        public string Label { get; init; } = "";
        public string Url { get; init; } = "";
    }

    private string? PreferredImageUrl
    {
        get
        {
            if (_selected is null || !_selected.HasPreferred) return null;
            // Always go through Engine API base (not Blazor host) — relative /api/... 404s on :7206
            if (_selected.Locked)
                return CacheBust(Engine.CharacterRefUrl(_projectId, _selected.Key));
            if (_selected.Variants.Any(v => v.Index == 1 && v.Exists))
                return CacheBust(Engine.CharacterVariantUrl(_projectId, _selected.Key, 1));
            if (_selected.PreferredUrl is { Length: > 0 } u)
                return CacheBust(Engine.AbsolutizeMediaUrl(u) ?? u);
            return null;
        }
    }

    private string PreferredImageLabel =>
        _selected is null ? ""
        : _selected.HasPreferred
            ? $"Preferred · {_selected.PreferredLabel}"
            : "No preferred image";

    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "Buster";
    private List<string> _projectIds = new();
    private List<CharacterSummary>? _chars;
    private CharacterPlatesState? _plates;
    private string? _selectedKey;
    private CharacterSummary? _selected;
    private JobSnapshot? _job;
    private long _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    private Mode _mode = Mode.PickSource;
    private Candidate? _champion;
    private Candidate? _challenger;
    private List<Candidate> _allCandidates = new();
    private int _queueIndex; // next challenger index into _allCandidates (champion may be locked not in list)
    private int _round;
    private int _totalRounds;
    private Side _highlight = Side.None;

    // Multi-seed (ordered) + hide + editable description
    /// <summary>Active image API max refs (Grok 3 / Gemini 14). From API imageSeedLimits.</summary>
    private int ApiMaxSeedRefs => Math.Max(1, _imageSeedLimits?.MaxReferenceImages ?? 3);
    private ImageSeedLimits? _imageSeedLimits;
    private readonly List<string> _seedOrder = new(); // "p", "v1", "b0"… click order = priority
    private readonly HashSet<string> _hiddenSeedKeys = new(StringComparer.OrdinalIgnoreCase);
    private bool _hideUnselectedSeeds;
    private string _editDescription = "";
    private string _editVisualLock = "";
    private string _editVoiceLabel = "";
    private string _editVoiceProfile = "";

    private int SelectedSeedCount => _seedOrder.Count;

    private RenderFragment RenderVoiceEditor() => __builder =>
    {
        <div class="mb-2">
            <label class="form-label small mb-0">Voice label</label>
            <input class="form-control form-control-sm" @bind="_editVoiceLabel" disabled="@_busy"
                   placeholder="e.g. Narrator_WarmStoryteller" />
        </div>
        <div class="mb-2">
            <label class="form-label small mb-0">Voice profile</label>
            <textarea class="form-control form-control-sm" rows="4" @bind="_editVoiceProfile" disabled="@_busy"
                      placeholder="Pitch, pace, accent, energy — for spoken lines"></textarea>
        </div>
        <button type="button" class="btn btn-sm btn-primary" disabled="@_busy" @onclick="SaveVoiceAsync">
            Save voice
        </button>
    };

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase);

    private bool PlateSortRunning =>
        JobRunning &&
        string.Equals(_job?.Kind, "character-plates", StringComparison.OrdinalIgnoreCase);

    private int _remainingAfter =>
        Math.Max(0, _allCandidates.Count - _queueIndex - 1);

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string> { "Buster" };
            if (projs?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];

            try { await Hub.StartAsync(); } catch { /* optional */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Optional: could wire JS keyboard; L/R handled via buttons for now
        await Task.CompletedTask;
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        if ((snap.Status is "done" or "error" or "cancelled") &&
            string.Equals(snap.Kind, "character-plates", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                await SoftReloadAsync();
                if (snap.Status == "done")
                    _message = snap.Message ?? "Matching complete.";
                else if (snap.Status == "error")
                    _error = snap.Error ?? snap.Message ?? "Plate sort failed";
                else if (snap.Status == "cancelled")
                    _message = "Plate sort cancelled.";
                StateHasChanged();
            });
        }
        else if ((snap.Status is "done" or "error" or "cancelled") &&
            string.Equals(snap.Kind, "character", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                await SoftReloadAsync();
                if (snap.Status == "done" &&
                    string.Equals(snap.CharKey, _selectedKey, StringComparison.OrdinalIgnoreCase))
                {
                    _message = "Portraits ready — compare left vs right.";
                    BeginCompareFromVariants();
                }
                else if (snap.Status == "error")
                {
                    _error = snap.Error ?? snap.Message ?? "Portrait generation failed";
                    _mode = Mode.PickSource;
                }
                else if (snap.Status == "cancelled")
                {
                    _mode = Mode.PickSource;
                }
                StateHasChanged();
            });
        }
        else
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void OnJobLog(string line)
    {
        if (_job is not null)
        {
            _job.Message = line;
            if (_job.Log.Count == 0 || _job.Log[^1] != line)
            {
                _job.Log.Add(line);
                if (_job.Log.Count > 80)
                    _job.Log = _job.Log.TakeLast(80).ToList();
            }
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnProjectChangedAsync()
    {
        ResetCompare();
        _mode = Mode.PickSource;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _plates = dto?.CharacterPlates;
            _imageSeedLimits = dto?.ImageSeedLimits;
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            // Do not auto-open a character — user clicks the list to choose source.
            if (_selectedKey is not null && _chars.Any(c => c.Key == _selectedKey))
                Select(_selectedKey, resetMode: false);
            else
            {
                _selectedKey = null;
                _selected = null;
                ResetCompare();
                _mode = Mode.PickSource;
            }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _chars = null;
            _plates = null;
            _imageSeedLimits = null;
        }
        finally { _busy = false; }
    }

    private async Task SoftReloadAsync()
    {
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _plates = dto?.CharacterPlates;
            _imageSeedLimits = dto?.ImageSeedLimits;
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (_selectedKey is not null)
                Select(_selectedKey, resetMode: false);
        }
        catch { /* ignore */ }
    }

    private void Select(string key, bool resetMode = true)
    {
        var switched = !string.Equals(_selectedKey, key, StringComparison.OrdinalIgnoreCase);
        _selectedKey = key;
        _selected = _chars?.FirstOrDefault(c => c.Key == key);
        if (_selected is not null)
        {
            _editDescription = _selected.Description ?? "";
            _editVisualLock = _selected.VisualLock ?? "";
            _editVoiceLabel = _selected.VoiceLabel ?? "";
            _editVoiceProfile = _selected.VoiceProfile ?? "";
        }
        if (switched)
            _hiddenSeedKeys.Clear();
        if (resetMode)
        {
            ResetCompare();
            _mode = Mode.PickSource;
            _error = null;
            _message = null;
            ResetSeedSelection();
        }
    }

    private void ResetSeedSelection()
    {
        _seedOrder.Clear();
        // Keep hidden keys across reselect of same char; clear when switching char in Select()
        // Default: preferred + up to 2 book plates (priority for API top-3)
        if (_selected is null) return;
        if (_selected.HasPreferred)
            _seedOrder.Add("p");
        var bookBudget = _selected.HasPreferred ? 2 : 3;
        foreach (var b in _selected.BookRefs
                     .Where(x => x.Exists && !IsWeakBookPlate(x.FileName))
                     .Take(bookBudget))
        {
            if (b.Index is int i)
                _seedOrder.Add($"b{i}");
        }
        if (_seedOrder.Count(k => k.StartsWith('b')) == 0)
        {
            foreach (var b in _selected.BookRefs.Where(x => x.Exists).Take(bookBudget))
                if (b.Index is int i)
                    _seedOrder.Add($"b{i}");
        }
    }

    private int SeedRank(string key)
    {
        var i = _seedOrder.FindIndex(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
        return i < 0 ? 0 : i + 1;
    }

    private bool SeedTileVisible(string key, bool isOn)
    {
        if (_hiddenSeedKeys.Contains(key)) return false;
        if (_hideUnselectedSeeds && !isOn) return false;
        return true;
    }

    private void ToggleSeedKey(string key)
    {
        var i = _seedOrder.FindIndex(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
        if (i >= 0)
            _seedOrder.RemoveAt(i);
        else
            _seedOrder.Add(key);
    }

    private void HideSeedKey(string key)
    {
        // Deselect if selected, then hide from grid
        var i = _seedOrder.FindIndex(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
        if (i >= 0)
            _seedOrder.RemoveAt(i);
        _hiddenSeedKeys.Add(key);
    }

    private static bool IsWeakBookPlate(string? fileName)
    {
        var n = (fileName ?? "").ToLowerInvariant();
        return n.Contains("sampled") || n.Contains("text_page") || n.Contains("ocr");
    }

    private static string BookPlateKindLabel(string? fileName)
    {
        var n = (fileName ?? "").ToLowerInvariant();
        if (n.Contains("cover")) return "cover";
        if (n.Contains("sparse")) return "art";
        if (n.Contains("sampled")) return "text?";
        if (n.Contains("embedded")) return "embed";
        if (n.Contains("bookref")) return "page";
        return "page";
    }

    private void BackToSource()
    {
        ResetCompare();
        _mode = Mode.PickSource;
    }

    private void ResetCompare()
    {
        _champion = null;
        _challenger = null;
        _allCandidates = new();
        _queueIndex = 0;
        _round = 0;
        _totalRounds = 0;
        _highlight = Side.None;
    }

    private async Task StartBookHintGenerate()
    {
        if (_selected is null) return;
        var bookCount = _selected.BookRefs.Count(b => b.Exists);
        _message = bookCount == 0
            ? $"No book pictures for {_selected.DisplayName} — using preferred + description."
            : $"Using preferred + up to 2 of {bookCount} book picture(s) for {_selected.DisplayName}.";
        await StartGenerateCoreAsync(new StartCharacterVariantsRequest
        {
            ProjectId = _projectId,
            CharKey = _selected.Key,
            SeedMode = "auto",
            IncludePreferred = true,
            MaxBookHints = 2,
            MaxRefs = 3,
        });
    }

    private async Task StartGeneratePreferred()
    {
        if (_selected is null) return;
        _message = _selected.HasPreferred
            ? $"Preferred picture only for {_selected.DisplayName}."
            : $"No preferred image — text-only generate for {_selected.DisplayName}.";
        await StartGenerateCoreAsync(new StartCharacterVariantsRequest
        {
            ProjectId = _projectId,
            CharKey = _selected.Key,
            SeedMode = _selected.HasPreferred ? "preferred_only" : "none",
            IncludePreferred = true,
            MaxRefs = 1,
            DescriptionOverride = _editDescription,
            VisualLockOverride = _editVisualLock,
            PersistDescription = true,
        });
    }

    /// <summary>
    /// Primary path: multi-select preferred + plates, optional description edit, regenerate → compare.
    /// </summary>
    private async Task StartRegenerateAsync()
    {
        if (_selected is null) return;
        if (SelectedSeedCount == 0 && string.IsNullOrWhiteSpace(_editDescription))
        {
            _error = "Select at least one reference picture, or enter a description.";
            return;
        }

        // Send ranked order (top N for active image provider); keep full order for ranking UI
        var maxSend = ApiMaxSeedRefs;
        var sendOrder = _seedOrder.Take(maxSend).ToList();
        var includePref = sendOrder.Any(k => k is "p");
        var variants = new List<int>();
        var books = new List<int>();
        foreach (var k in sendOrder)
        {
            if (k.Length >= 2 && k[0] == 'v' && int.TryParse(k[1..], out var vi))
                variants.Add(vi);
            if (k.Length >= 2 && k[0] == 'b' && int.TryParse(k[1..], out var bi))
                books.Add(bi);
        }

        var providerLabel = _imageSeedLimits?.Provider ?? "image API";
        if (SelectedSeedCount > maxSend)
            _message =
                $"Using ranks 1–{maxSend} of {SelectedSeedCount} selected pictures (max {maxSend}).";

        var seedMode = SelectedSeedCount == 0 ? "none" : "explicit";
        await StartGenerateCoreAsync(new StartCharacterVariantsRequest
        {
            ProjectId = _projectId,
            CharKey = _selected.Key,
            SeedMode = seedMode,
            IncludePreferred = includePref,
            IncludeLockedRef = includePref,
            BookRefIndices = books,
            VariantIndices = variants,
            SeedOrderKeys = sendOrder,
            MaxRefs = maxSend,
            DescriptionOverride = _editDescription,
            VisualLockOverride = _editVisualLock,
            PersistDescription = true,
        });
    }

    /// <summary>
    /// From compare (no more candidates): run another generate with the same seeds/description.
    /// </summary>
    private async Task TryRegenFromCompareAsync()
    {
        if (_selected is null) return;
        // Ensure preferred/locked is first so the next round refines the current best
        if (_selected.HasPreferred)
        {
            _seedOrder.RemoveAll(k => string.Equals(k, "p", StringComparison.OrdinalIgnoreCase));
            _seedOrder.Insert(0, "p");
        }
        _message = "Generating another round with the same references…";
        await StartRegenerateAsync();
    }

    private async Task StartExplicitGenerate() => await StartRegenerateAsync();

    /// <summary>
    /// Start Grok vision job: classify who appears on each book page → scenes.json plates.
    /// Progress via SignalR; cancel with CancelAsync.
    /// </summary>
    private async Task StartSortCharacterPlatesAsync(bool useGrok = true)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            try { await Hub.StartAsync(); } catch (Exception hex) { _error = $"SignalR: {hex.Message}"; }
            await Engine.StartSortCharacterPlatesAsync(_projectId, useGrok: useGrok, maxImages: 32);
            _message = "Matching book pictures…";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task StartGenerateCoreAsync(StartCharacterVariantsRequest req)
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            try { await Hub.StartAsync(); } catch (Exception hex) { _error = $"SignalR: {hex.Message}"; }
            await Engine.StartCharacterVariantsAsync(req);
            _mode = Mode.WaitingGenerate;
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _mode = Mode.PickSource;
        }
        finally { _busy = false; }
    }

    private void BeginCompareFromVariants()
    {
        if (_selected is null) return;
        var vars = _selected.Variants.Where(v => v.Exists).OrderBy(v => v.Index).ToList();
        if (vars.Count == 0)
        {
            _mode = Mode.PickSource;
            _error = "Generate finished but no variant files found.";
            return;
        }

        var candidates = vars.Select(v => new Candidate
        {
            Kind = "variant",
            Index = v.Index ?? 1,
            Label = $"Option {v.Index}",
            Url = CacheBust(Engine.CharacterVariantUrl(_projectId, _selected.Key, v.Index ?? 1)),
        }).ToList();

        BeginCompare(candidates);
    }

    private void BeginCompare(List<Candidate> candidates)
    {
        ResetCompare();
        _allCandidates = candidates;
        _totalRounds = candidates.Count;

        // Seed champion: existing lock if any, else first candidate
        if (_selected?.Locked == true && !string.IsNullOrEmpty(_selected.RefUrl))
        {
            _champion = new Candidate
            {
                Kind = "locked",
                Index = 0,
                Label = $"Locked · {_selected.RefFileName}",
                Url = CacheBust(Engine.CharacterRefUrl(_projectId, _selected.Key)),
            };
            _queueIndex = 0;
            _challenger = candidates.Count > 0 ? candidates[0] : null;
            _round = candidates.Count > 0 ? 1 : 0;
        }
        else if (candidates.Count > 0)
        {
            _champion = candidates[0];
            _queueIndex = 1;
            _challenger = candidates.Count > 1 ? candidates[1] : null;
            _round = candidates.Count > 1 ? 1 : 0;
            // if only one candidate, queue past end so UI shows lock-only
            if (candidates.Count == 1)
                _queueIndex = 1;
        }

        _mode = Mode.Compare;
        _highlight = Side.None;
    }

    private void PreferLeft()
    {
        if (_challenger is null) return;
        _highlight = Side.Left;
        AdvanceChallenger();
    }

    private void PreferRight()
    {
        if (_challenger is null) return;
        _highlight = Side.Right;
        _champion = _challenger;
        AdvanceChallenger();
    }

    private void AdvanceChallenger()
    {
        // Move past the challenger we just judged
        _queueIndex++;
        if (_queueIndex < _allCandidates.Count)
        {
            // If champion was taken from candidates[0] and queue points at same ref, skip
            _challenger = _allCandidates[_queueIndex];
            // Don't compare champion to itself
            if (_champion is not null &&
                _challenger.Kind == _champion.Kind &&
                _challenger.Index == _champion.Index)
            {
                _queueIndex++;
                _challenger = _queueIndex < _allCandidates.Count ? _allCandidates[_queueIndex] : null;
            }
            _round++;
        }
        else
        {
            _challenger = null;
        }
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(120);
            _highlight = Side.None;
            StateHasChanged();
        });
    }

    private async Task SaveVoiceAsync()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.UpdateCharacterVoiceAsync(
                _projectId,
                _selected.Key,
                voiceProfile: _editVoiceProfile,
                voiceLabel: _editVoiceLabel);
            _message = $"Saved voice for {_selected.DisplayName}";
            await LoadAsync();
            // re-bind edit fields after reload
            if (_selected is not null)
            {
                _editVoiceLabel = _selected.VoiceLabel ?? "";
                _editVoiceProfile = _selected.VoiceProfile ?? "";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LockChampionAsync()
    {
        if (_selected is null || _champion is null) return;
        _busy = true;
        _error = null;
        try
        {
            if (_champion.Kind == "locked")
            {
                _message = $"{_selected.DisplayName} already uses this lock.";
            }
            else if (_champion.Kind == "book")
            {
                await Engine.LockCharacterBookRefAsync(_projectId, _selected.Key, _champion.Index);
                _message = $"Locked book picture for {_selected.DisplayName}";
            }
            else if (_champion.Kind == "variant")
            {
                await Engine.LockCharacterVariantAsync(_projectId, _selected.Key, _champion.Index);
                _message = $"Locked portrait for {_selected.DisplayName}";
            }

            await LoadAsync();
            ResetCompare();
            _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task UnlockAsync()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.UnlockCharacterAsync(_projectId, _selected.Key);
            _message =
                $"Unlocked {_selected.DisplayName} — previous lock is now the preferred image (variant 1). " +
                "Generate portraits to refine, then lock again.";
            await LoadAsync();
            ResetCompare();
            _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            if (_mode == Mode.WaitingGenerate)
                _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private string CacheBust(string url) =>
        url + (url.Contains('?') ? "&" : "?") + "v=" + _imgBust;

    private static string Trunc(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= n ? s : s[..(n - 1)] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Task.CompletedTask;
    }
}
