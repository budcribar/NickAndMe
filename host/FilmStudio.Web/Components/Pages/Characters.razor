@page "/characters"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models

<PageTitle>Characters</PageTitle>

<h1>Characters</h1>
<p class="text-muted">
    Cast from Stage 1 / blueprint seeds. Lock a <strong>book plate</strong> or
    <strong>Grok variant</strong> as the video reference. Narrator is voice-only.
</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="LoadAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-outline-primary" disabled="@_busy" @onclick="LoadAsync">Reload</button>
        @if (JobRunning)
        {
            <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel job</button>
        }
    </div>
</div>

@if (_job is not null &&
     string.Equals(_job.Kind, "character", StringComparison.OrdinalIgnoreCase) &&
     _job.Status is "running" or "done" or "error" or "cancelled")
{
    <div class="card mb-3 border-@(_job.Status == "running" ? "primary" : _job.Status == "error" ? "danger" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <span class="badge bg-secondary">@_job.Status</span>
                <span class="badge bg-info text-dark">character</span>
                @if (!string.IsNullOrEmpty(_job.CharKey))
                {
                    <code class="small">@_job.CharKey</code>
                }
                @if (_job.Total > 0)
                {
                    <span class="small text-muted">@_job.Index / @_job.Total variants</span>
                }
                <span class="small">@_job.Message</span>
            </div>
            @if (_job.Status == "running" && _job.Total > 0)
            {
                var pct = (int)Math.Round(100.0 * Math.Clamp(_job.Index, 0, _job.Total) / _job.Total);
                <div class="progress mt-2" style="height: 0.5rem;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: @(Math.Max(8, pct))%"></div>
                </div>
            }
            @if (_job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 140px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(20))</pre>
            }
        </div>
    </div>
}

@if (_chars is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_chars.Count == 0)
{
    <div class="alert alert-warning">
        No character seeds. Run <strong>Adaptation → Stage 1</strong> first.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                @foreach (var c in _chars)
                {
                    var active = c.Key == _selectedKey;
                    <button type="button"
                            class="list-group-item list-group-item-action @(active ? "active" : "")"
                            @onclick="() => Select(c.Key)">
                        @(c.DisplayName)
                        @if (c.VoiceOnly)
                        {
                            <span class="badge bg-secondary ms-1">voice</span>
                        }
                        else if (c.Locked)
                        {
                            <span class="badge bg-success ms-1">locked</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-1">no ref</span>
                        }
                    </button>
                }
            </div>
        </div>
        <div class="col-md-9">
            @if (_selected is null)
            {
                <p class="text-muted">Select a character.</p>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span><code>@_selected.Key</code> — @_selected.DisplayName</span>
                        @if (_selected.VoiceOnly)
                        {
                            <span class="badge bg-secondary">voice-only (no image)</span>
                        }
                    </div>
                    <div class="card-body row">
                        <div class="col-md-4">
                            @if (!_selected.VoiceOnly && !string.IsNullOrEmpty(_selected.RefUrl))
                            {
                                <img src="@CacheBust(Engine.CharacterRefUrl(_projectId, _selected.Key))"
                                     alt="@_selected.DisplayName"
                                     class="img-fluid rounded border"
                                     style="max-height: 280px; object-fit: contain; width: 100%; background: #f8f9fa;" />
                                <div class="small text-muted mt-1">Locked: @_selected.RefFileName</div>
                            }
                            else if (!_selected.VoiceOnly)
                            {
                                <div class="border rounded p-4 text-center text-muted">No locked ref image</div>
                            }
                        </div>
                        <div class="col-md-8">
                            <h5>Description</h5>
                            <p class="small">@(_selected.Description is { Length: > 0 } d ? d : "—")</p>
                            <h5>Visual lock</h5>
                            <p class="small">@(_selected.VisualLock is { Length: > 0 } v ? v : "—")</p>
                            <h5>Voice</h5>
                            <p class="small mb-1"><strong>@(_selected.VoiceLabel is { Length: > 0 } l ? l : "—")</strong></p>
                            <p class="small">@(_selected.VoiceProfile is { Length: > 0 } vp ? vp : "—")</p>
                            @if (_selected.WardrobeAlways.Count > 0)
                            {
                                <h5>Wardrobe always</h5>
                                <ul class="small">
                                    @foreach (var w in _selected.WardrobeAlways)
                                    {
                                        <li>@w</li>
                                    }
                                </ul>
                            }
                            @if (!string.IsNullOrEmpty(_selected.AgeBand))
                            {
                                <p class="small text-muted mb-0">age_band: @_selected.AgeBand</p>
                            }
                        </div>
                    </div>
                </div>

                @if (!_selected.VoiceOnly)
                {
                    @* ---- Book plates ---- *@
                    <div class="card mb-3">
                        <div class="card-header">Book plates — lock as reference</div>
                        <div class="card-body">
                            @{
                                var bookExisting = _selected.BookRefs.Where(b => b.Exists).ToList();
                            }
                            @if (bookExisting.Count == 0)
                            {
                                <p class="small text-muted mb-0">
                                    No book reference images on disk for this character.
                                    Re-run Stage 1 attach / extract book images in Streamlit if needed.
                                </p>
                            }
                            else
                            {
                                <p class="small text-muted">
                                    From the PDF/source art. <strong>Use as locked ref</strong> sets this plate for video (no Grok variants required).
                                </p>
                                <div class="row g-3">
                                    @foreach (var br in bookExisting)
                                    {
                                        <div class="col-md-4">
                                            <div class="border rounded p-2 h-100 d-flex flex-column">
                                                <img src="@CacheBust(Engine.CharacterBookRefUrl(_projectId, _selected.Key, br.Index ?? 0))"
                                                     alt="@br.FileName"
                                                     class="img-fluid rounded mb-2"
                                                     style="max-height: 180px; object-fit: contain; width: 100%; background: #f8f9fa;" />
                                                <div class="small text-muted mb-2 text-truncate" title="@br.FileName">@br.FileName</div>
                                                <button class="btn btn-sm btn-primary mt-auto"
                                                        disabled="@_busy"
                                                        @onclick="() => LockBookRefAsync(br.Index ?? 0)">
                                                    Use as locked ref
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* ---- Variants ---- *@
                    <div class="card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <span>Grok portrait variants</span>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary"
                                        disabled="@(_busy || JobRunning)"
                                        @onclick="GenerateVariantsAsync">
                                    🎲 Generate 3 variants
                                </button>
                                @if (_selected.Locked)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            disabled="@_busy"
                                            @onclick="UnlockAsync">
                                        Unlock ref
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="small text-muted">
                                Needs <code>XAI_API_KEY</code> on the API process. Uses book plates as edit refs when available.
                            </p>
                            @{
                                var varsExisting = _selected.Variants.Where(v => v.Exists).ToList();
                            }
                            @if (varsExisting.Count == 0)
                            {
                                <p class="small text-muted mb-0">No open variants on disk. Click <strong>Generate 3 variants</strong>.</p>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var vr in varsExisting)
                                    {
                                        <div class="col-md-4">
                                            <div class="border rounded p-2 h-100 d-flex flex-column">
                                                <img src="@CacheBust(Engine.CharacterVariantUrl(_projectId, _selected.Key, vr.Index ?? 1))"
                                                     alt="@vr.FileName"
                                                     class="img-fluid rounded mb-2"
                                                     style="max-height: 200px; object-fit: contain; width: 100%; background: #f8f9fa;" />
                                                <div class="small text-muted mb-2">Variant @(vr.Index)</div>
                                                <button class="btn btn-sm btn-success mt-auto"
                                                        disabled="@_busy"
                                                        @onclick="() => LockVariantAsync(vr.Index ?? 1)">
                                                    Lock @(vr.Index)
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "Buster";
    private List<string> _projectIds = new();
    private List<CharacterSummary>? _chars;
    private string? _selectedKey;
    private CharacterSummary? _selected;
    private JobSnapshot? _job;
    private long _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string> { "Buster" };
            if (projs?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];

            try { await Hub.StartAsync(); } catch { /* optional */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        // Always accept hub snapshots for character jobs (or any running job while on this page)
        _job = snap;
        if ((snap.Status is "done" or "error" or "cancelled") &&
            string.Equals(snap.Kind, "character", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                // Re-fetch cast so variants / locked badges update from the API
                await SoftReloadAsync();
                if (snap.Status == "done")
                    _message = snap.Message ?? "Portrait variants ready — lock one below.";
                else if (snap.Status == "error")
                    _error = snap.Error ?? snap.Message ?? "Portrait generation failed";
                StateHasChanged();
            });
        }
        else
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void OnJobLog(string line)
    {
        // Prefer full snapshots from JobUpdated; keep message fresh if log arrives first
        if (_job is not null)
        {
            _job.Message = line;
            if (_job.Log.Count == 0 || _job.Log[^1] != line)
            {
                _job.Log.Add(line);
                if (_job.Log.Count > 80)
                    _job.Log = _job.Log.TakeLast(80).ToList();
            }
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (_chars.Count > 0)
            {
                if (_selectedKey is null || _chars.All(c => c.Key != _selectedKey))
                    _selectedKey = _chars[0].Key;
                Select(_selectedKey!);
            }
            else
            {
                _selectedKey = null;
                _selected = null;
            }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _chars = null;
        }
        finally { _busy = false; }
    }

    private async Task SoftReloadAsync()
    {
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (_selectedKey is not null)
                Select(_selectedKey);
            if (!string.IsNullOrEmpty(_message) || (_job?.Status is "done"))
                _message = _job?.Message ?? _message;
        }
        catch { /* ignore */ }
    }

    private void Select(string key)
    {
        _selectedKey = key;
        _selected = _chars?.FirstOrDefault(c => c.Key == key);
    }

    private async Task GenerateVariantsAsync()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            // Connect hub *before* starting so we don't miss early JobUpdated events
            try { await Hub.StartAsync(); } catch (Exception hex) { _error = $"SignalR: {hex.Message}"; }
            await Engine.StartCharacterVariantsAsync(_projectId, _selected.Key);
            _message = $"Generating variants for {_selected.DisplayName}… (live via SignalR)";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LockVariantAsync(int index)
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.LockCharacterVariantAsync(_projectId, _selected.Key, index);
            _message = $"Locked variant {index} for {_selected.DisplayName}";
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LockBookRefAsync(int index)
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.LockCharacterBookRefAsync(_projectId, _selected.Key, index);
            _message = $"Locked book plate for {_selected.DisplayName}";
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task UnlockAsync()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.UnlockCharacterAsync(_projectId, _selected.Key);
            _message = $"Unlocked {_selected.DisplayName}";
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private string CacheBust(string url) =>
        url + (url.Contains('?') ? "&" : "?") + "v=" + _imgBust;

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Task.CompletedTask;
    }
}
