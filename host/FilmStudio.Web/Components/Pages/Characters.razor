@page "/characters"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@using FilmStudio.Core.Models

<PageTitle>Characters</PageTitle>

<h1>Characters</h1>
<p class="text-muted">
    Pick a cast member, choose a <strong>source</strong> (book art or Grok), then use
    <strong>left vs right</strong> comparison until the best look is locked for video.
</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="OnProjectChangedAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-outline-primary" disabled="@_busy" @onclick="LoadAsync">Reload</button>
        @if (JobRunning)
        {
            <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelAsync">Cancel job</button>
        }
    </div>
</div>

@if (_job is not null &&
     string.Equals(_job.Kind, "character", StringComparison.OrdinalIgnoreCase) &&
     _job.Status is "running" or "done" or "error" or "cancelled")
{
    <div class="card mb-3 border-@(_job.Status == "running" ? "primary" : _job.Status == "error" ? "danger" : "secondary")">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <span class="badge bg-secondary">@_job.Status</span>
                <span class="badge bg-info text-dark">character</span>
                @if (!string.IsNullOrEmpty(_job.CharKey))
                {
                    <code class="small">@_job.CharKey</code>
                }
                @if (_job.Total > 0)
                {
                    <span class="small text-muted">@_job.Index / @_job.Total</span>
                }
                <span class="small">@_job.Message</span>
            </div>
            @if (_job.Status == "running" && _job.Total > 0)
            {
                var pct = (int)Math.Round(100.0 * Math.Clamp(_job.Index, 0, _job.Total) / Math.Max(1, _job.Total));
                <div class="progress mt-2" style="height: 0.5rem;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: @(Math.Max(8, pct))%"></div>
                </div>
            }
            @if (_job.Log.Count > 0)
            {
                <pre class="small mb-0 mt-2" style="max-height: 120px; overflow: auto;">@string.Join("\n", _job.Log.TakeLast(16))</pre>
            }
        </div>
    </div>
}

@if (_chars is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_chars.Count == 0)
{
    <div class="alert alert-warning">
        No character seeds. Run <strong>Adaptation → Stage 1</strong> first.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                @foreach (var c in _chars)
                {
                    var active = c.Key == _selectedKey;
                    <button type="button"
                            class="list-group-item list-group-item-action @(active ? "active" : "")"
                            @onclick="() => Select(c.Key)">
                        @(c.DisplayName)
                        @if (c.VoiceOnly)
                        {
                            <span class="badge bg-secondary ms-1">voice</span>
                        }
                        else if (c.Locked)
                        {
                            <span class="badge bg-success ms-1">locked</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-1">no ref</span>
                        }
                    </button>
                }
            </div>
        </div>
        <div class="col-md-9">
            @if (_selected is null)
            {
                <p class="text-muted">Select a character.</p>
            }
            else if (_selected.VoiceOnly)
            {
                <div class="card">
                    <div class="card-header"><code>@_selected.Key</code> — @_selected.DisplayName</div>
                    <div class="card-body">
                        <span class="badge bg-secondary mb-2">voice-only (no image)</span>
                        <p class="small mb-1"><strong>@(_selected.VoiceLabel is { Length: > 0 } l ? l : "—")</strong></p>
                        <p class="small mb-0">@(_selected.VoiceProfile is { Length: > 0 } vp ? vp : "—")</p>
                    </div>
                </div>
            }
            else
            {
                @* ---- Character summary (compact) ---- *@
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span><code>@_selected.Key</code> — @_selected.DisplayName</span>
                        @if (_selected.Locked)
                        {
                            <span class="badge bg-success">locked</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">needs lock</span>
                        }
                    </div>
                    <div class="card-body row g-3 align-items-start">
                        <div class="col-auto">
                            @if (_selected.Locked && !string.IsNullOrEmpty(_selected.RefUrl))
                            {
                                <img src="@CacheBust(Engine.CharacterRefUrl(_projectId, _selected.Key))"
                                     alt="Locked"
                                     class="rounded border"
                                     style="width: 120px; height: 120px; object-fit: contain; background: #f8f9fa;" />
                                <div class="small text-muted mt-1">Current lock</div>
                            }
                            else
                            {
                                <div class="rounded border d-flex align-items-center justify-content-center text-muted small"
                                     style="width: 120px; height: 120px; background: #f8f9fa;">No lock</div>
                            }
                        </div>
                        <div class="col char-meta">
                            <div class="small"><strong>Description</strong> — @Trunc(_selected.Description, 160)</div>
                            <div class="small mt-1"><strong>Visual</strong> — @Trunc(_selected.VisualLock, 120)</div>
                            @if (_mode != Mode.PickSource)
                            {
                                <button type="button" class="btn btn-sm btn-link px-0 mt-1" @onclick="BackToSource">← Change source</button>
                            }
                            @if (_selected.Locked)
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger ms-2 mt-1" disabled="@_busy" @onclick="UnlockAsync">Unlock</button>
                            }
                        </div>
                    </div>
                </div>

                @if (_mode == Mode.PickSource)
                {
                    <div class="mb-2"><strong>1) Choose image source</strong></div>
                    <div class="char-source-grid mb-3">
                        <button type="button" class="char-source-btn" disabled="@_busy" @onclick="StartBookSearch">
                            <span class="char-source-btn__title">📚 Search book</span>
                            <span class="char-source-btn__sub">
                                Find plates already attached for this character
                                (@(_selected.BookRefs.Count(b => b.Exists)) on disk).
                                Pick the best via left/right comparison.
                            </span>
                        </button>
                        <button type="button" class="char-source-btn" disabled="@(_busy || JobRunning)" @onclick="StartGenerate">
                            <span class="char-source-btn__title">✨ Generate with Grok</span>
                            <span class="char-source-btn__sub">
                                @if (_selected.Locked)
                                {
                                    <text>Create 1 refined portrait from the locked ref (+ book plates).</text>
                                }
                                else
                                {
                                    <text>Create 3 portraits to compare (uses book plates when available).</text>
                                }
                                Needs <code>XAI_API_KEY</code> on the API.
                            </span>
                        </button>
                    </div>
                    <p class="small text-muted mb-0">
                        Tip: for picture books, start with <strong>Search book</strong> and lock a plate — no API cost.
                        Use generate when you need a cleaner model-sheet style.
                    </p>
                }
                else if (_mode == Mode.BookEmpty)
                {
                    <div class="alert alert-warning">
                        No book plates found for <strong>@_selected.DisplayName</strong>.
                        Book plates attach after Stage 1 / prepare, or use <strong>Generate with Grok</strong>.
                    </div>
                    <button class="btn btn-outline-secondary" @onclick="BackToSource">← Back</button>
                }
                else if (_mode == Mode.WaitingGenerate)
                {
                    <div class="alert alert-info mb-0">
                        Generating portraits… when finished, left/right comparison starts automatically.
                    </div>
                }
                else if (_mode == Mode.Compare && _champion is not null)
                {
                    <div class="char-compare">
                        <div class="char-compare__head">
                            <div class="char-compare__title">2) Pick the better look</div>
                            <div class="char-compare__step">
                                @if (_challenger is null)
                                {
                                    <text>Champion ready · no more candidates</text>
                                }
                                else
                                {
                                    <text>Round @_round of @_totalRounds · @_remainingAfter challenger(s) left after this</text>
                                }
                            </div>
                        </div>

                        <div class="char-compare__pair">
                            <div class="char-compare__side @(_highlight == Side.Left ? "char-compare__side--pick" : "")">
                                <div class="char-compare__label">Left — current best</div>
                                <div class="char-compare__img-wrap">
                                    <img src="@_champion.Url" alt="@_champion.Label" />
                                </div>
                                <div class="char-compare__caption">@_champion.Label</div>
                            </div>
                            <div class="char-compare__vs">VS</div>
                            <div class="char-compare__side @(_highlight == Side.Right ? "char-compare__side--pick" : "")">
                                <div class="char-compare__label">Right — candidate</div>
                                <div class="char-compare__img-wrap">
                                    @if (_challenger is not null)
                                    {
                                        <img src="@_challenger.Url" alt="@_challenger.Label" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No more candidates</span>
                                    }
                                </div>
                                <div class="char-compare__caption">@(_challenger?.Label ?? "—")</div>
                            </div>
                        </div>

                        <div class="char-compare__actions">
                            @if (_challenger is not null)
                            {
                                <button type="button" class="btn btn-outline-primary btn-lg"
                                        disabled="@_busy" @onclick="PreferLeft">
                                    ◀ Left better
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-lg"
                                        disabled="@_busy" @onclick="PreferRight">
                                    Right better ▶
                                </button>
                            }
                            <button type="button" class="btn btn-success btn-lg"
                                    disabled="@_busy" @onclick="LockChampionAsync">
                                ✓ Lock left as final
                            </button>
                        </div>
                        <div class="char-compare__hint">
                            Like an eye exam: keep the better image on the left until you’re happy, then lock.
                            Keyboard: <kbd>L</kbd> left · <kbd>R</kbd> right · <kbd>Enter</kbd> lock
                        </div>

                        @if (_allCandidates.Count > 0)
                        {
                            <div class="char-thumb-strip" title="Candidate queue">
                                @for (var i = 0; i < _allCandidates.Count; i++)
                                {
                                    var c = _allCandidates[i];
                                    var cls = i < _queueIndex
                                        ? "char-thumb char-thumb--done"
                                        : i == _queueIndex && _challenger is not null
                                            ? "char-thumb char-thumb--current"
                                            : "char-thumb";
                                    <img src="@c.Url" alt="@c.Label" class="@cls" />
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private enum Mode { PickSource, BookEmpty, WaitingGenerate, Compare }
    private enum Side { None, Left, Right }

    private sealed class Candidate
    {
        public string Kind { get; init; } = ""; // book | variant | locked
        public int Index { get; init; }
        public string Label { get; init; } = "";
        public string Url { get; init; } = "";
    }

    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "Buster";
    private List<string> _projectIds = new();
    private List<CharacterSummary>? _chars;
    private string? _selectedKey;
    private CharacterSummary? _selected;
    private JobSnapshot? _job;
    private long _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    private Mode _mode = Mode.PickSource;
    private Candidate? _champion;
    private Candidate? _challenger;
    private List<Candidate> _allCandidates = new();
    private int _queueIndex; // next challenger index into _allCandidates (champion may be locked not in list)
    private int _round;
    private int _totalRounds;
    private Side _highlight = Side.None;

    private bool JobRunning =>
        string.Equals(_job?.Status, "running", StringComparison.OrdinalIgnoreCase);

    private int _remainingAfter =>
        Math.Max(0, _allCandidates.Count - _queueIndex - 1);

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string> { "Buster" };
            if (projs?.Active?.Id is { Length: > 0 } aid)
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];

            try { await Hub.StartAsync(); } catch { /* optional */ }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Optional: could wire JS keyboard; L/R handled via buttons for now
        await Task.CompletedTask;
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        if ((snap.Status is "done" or "error" or "cancelled") &&
            string.Equals(snap.Kind, "character", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                await SoftReloadAsync();
                if (snap.Status == "done" &&
                    string.Equals(snap.CharKey, _selectedKey, StringComparison.OrdinalIgnoreCase))
                {
                    _message = "Portraits ready — compare left vs right.";
                    BeginCompareFromVariants();
                }
                else if (snap.Status == "error")
                {
                    _error = snap.Error ?? snap.Message ?? "Portrait generation failed";
                    _mode = Mode.PickSource;
                }
                else if (snap.Status == "cancelled")
                {
                    _mode = Mode.PickSource;
                }
                StateHasChanged();
            });
        }
        else
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void OnJobLog(string line)
    {
        if (_job is not null)
        {
            _job.Message = line;
            if (_job.Log.Count == 0 || _job.Log[^1] != line)
            {
                _job.Log.Add(line);
                if (_job.Log.Count > 80)
                    _job.Log = _job.Log.TakeLast(80).ToList();
            }
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnProjectChangedAsync()
    {
        ResetCompare();
        _mode = Mode.PickSource;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (_chars.Count > 0)
            {
                if (_selectedKey is null || _chars.All(c => c.Key != _selectedKey))
                    _selectedKey = _chars[0].Key;
                Select(_selectedKey!, resetMode: false);
            }
            else
            {
                _selectedKey = null;
                _selected = null;
            }

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _chars = null;
        }
        finally { _busy = false; }
    }

    private async Task SoftReloadAsync()
    {
        try
        {
            var dto = await Engine.GetCharactersAsync(_projectId);
            _chars = dto?.Characters ?? new List<CharacterSummary>();
            _imgBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (_selectedKey is not null)
                Select(_selectedKey, resetMode: false);
        }
        catch { /* ignore */ }
    }

    private void Select(string key, bool resetMode = true)
    {
        _selectedKey = key;
        _selected = _chars?.FirstOrDefault(c => c.Key == key);
        if (resetMode)
        {
            ResetCompare();
            _mode = Mode.PickSource;
            _error = null;
            _message = null;
        }
    }

    private void BackToSource()
    {
        ResetCompare();
        _mode = Mode.PickSource;
    }

    private void ResetCompare()
    {
        _champion = null;
        _challenger = null;
        _allCandidates = new();
        _queueIndex = 0;
        _round = 0;
        _totalRounds = 0;
        _highlight = Side.None;
    }

    private void StartBookSearch()
    {
        if (_selected is null) return;
        var books = _selected.BookRefs.Where(b => b.Exists).ToList();
        if (books.Count == 0)
        {
            _mode = Mode.BookEmpty;
            return;
        }

        var candidates = books.Select(b => new Candidate
        {
            Kind = "book",
            Index = b.Index ?? 0,
            Label = $"Book · {b.FileName}",
            Url = CacheBust(Engine.CharacterBookRefUrl(_projectId, _selected.Key, b.Index ?? 0)),
        }).ToList();

        BeginCompare(candidates);
    }

    private async Task StartGenerate()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            try { await Hub.StartAsync(); } catch (Exception hex) { _error = $"SignalR: {hex.Message}"; }
            await Engine.StartCharacterVariantsAsync(_projectId, _selected.Key);
            _mode = Mode.WaitingGenerate;
            _message = $"Generating for {_selected.DisplayName}…";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _mode = Mode.PickSource;
        }
        finally { _busy = false; }
    }

    private void BeginCompareFromVariants()
    {
        if (_selected is null) return;
        var vars = _selected.Variants.Where(v => v.Exists).OrderBy(v => v.Index).ToList();
        if (vars.Count == 0)
        {
            _mode = Mode.PickSource;
            _error = "Generate finished but no variant files found.";
            return;
        }

        var candidates = vars.Select(v => new Candidate
        {
            Kind = "variant",
            Index = v.Index ?? 1,
            Label = $"Grok · variant {v.Index}",
            Url = CacheBust(Engine.CharacterVariantUrl(_projectId, _selected.Key, v.Index ?? 1)),
        }).ToList();

        BeginCompare(candidates);
    }

    private void BeginCompare(List<Candidate> candidates)
    {
        ResetCompare();
        _allCandidates = candidates;
        _totalRounds = candidates.Count;

        // Seed champion: existing lock if any, else first candidate
        if (_selected?.Locked == true && !string.IsNullOrEmpty(_selected.RefUrl))
        {
            _champion = new Candidate
            {
                Kind = "locked",
                Index = 0,
                Label = $"Locked · {_selected.RefFileName}",
                Url = CacheBust(Engine.CharacterRefUrl(_projectId, _selected.Key)),
            };
            _queueIndex = 0;
            _challenger = candidates.Count > 0 ? candidates[0] : null;
            _round = candidates.Count > 0 ? 1 : 0;
        }
        else if (candidates.Count > 0)
        {
            _champion = candidates[0];
            _queueIndex = 1;
            _challenger = candidates.Count > 1 ? candidates[1] : null;
            _round = candidates.Count > 1 ? 1 : 0;
            // if only one candidate, queue past end so UI shows lock-only
            if (candidates.Count == 1)
                _queueIndex = 1;
        }

        _mode = Mode.Compare;
        _highlight = Side.None;
    }

    private void PreferLeft()
    {
        if (_challenger is null) return;
        _highlight = Side.Left;
        AdvanceChallenger();
    }

    private void PreferRight()
    {
        if (_challenger is null) return;
        _highlight = Side.Right;
        _champion = _challenger;
        AdvanceChallenger();
    }

    private void AdvanceChallenger()
    {
        // Move past the challenger we just judged
        _queueIndex++;
        if (_queueIndex < _allCandidates.Count)
        {
            // If champion was taken from candidates[0] and queue points at same ref, skip
            _challenger = _allCandidates[_queueIndex];
            // Don't compare champion to itself
            if (_champion is not null &&
                _challenger.Kind == _champion.Kind &&
                _challenger.Index == _champion.Index)
            {
                _queueIndex++;
                _challenger = _queueIndex < _allCandidates.Count ? _allCandidates[_queueIndex] : null;
            }
            _round++;
        }
        else
        {
            _challenger = null;
        }
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(120);
            _highlight = Side.None;
            StateHasChanged();
        });
    }

    private async Task LockChampionAsync()
    {
        if (_selected is null || _champion is null) return;
        _busy = true;
        _error = null;
        try
        {
            if (_champion.Kind == "locked")
            {
                _message = $"{_selected.DisplayName} already uses this lock.";
            }
            else if (_champion.Kind == "book")
            {
                await Engine.LockCharacterBookRefAsync(_projectId, _selected.Key, _champion.Index);
                _message = $"Locked book plate for {_selected.DisplayName}";
            }
            else if (_champion.Kind == "variant")
            {
                await Engine.LockCharacterVariantAsync(_projectId, _selected.Key, _champion.Index);
                _message = $"Locked Grok variant {_champion.Index} for {_selected.DisplayName}";
            }

            await LoadAsync();
            ResetCompare();
            _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task UnlockAsync()
    {
        if (_selected is null) return;
        _busy = true;
        _error = null;
        try
        {
            await Engine.UnlockCharacterAsync(_projectId, _selected.Key);
            _message = $"Unlocked {_selected.DisplayName}";
            await LoadAsync();
            ResetCompare();
            _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            if (_mode == Mode.WaitingGenerate)
                _mode = Mode.PickSource;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private string CacheBust(string url) =>
        url + (url.Contains('?') ? "&" : "?") + "v=" + _imgBust;

    private static string Trunc(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= n ? s : s[..(n - 1)] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Task.CompletedTask;
    }
}
