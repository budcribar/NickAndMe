    private void ClearSelection()
    {
        _selected.Clear();
        _selectionMode = "";
    }

    private bool AllShownScenesSelected =>
        VisibleScenes.Count > 0 && VisibleScenes.All(s => _selected.Contains(s.SceneNumber));

    private void ToggleSelectAllShown(bool on)
    {
        if (on) SelectAll();
        else ClearSelection();
    }

    private int EstimateSelectedClips()
    {
        if (_scenes is null) return 0;
        var sum = 0;
        foreach (var s in _scenes.Where(x => _selected.Contains(x.SceneNumber)))
        {
            if (_onlyMissing)
                sum += Math.Max(0, s.ClipCount - s.ClipsOnDisk);
            else
                sum += s.ClipCount;
        }
        return sum;
    }

