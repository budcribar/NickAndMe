@page "/"
@implements IAsyncDisposable
@inject EngineApiClient Engine
@inject JobHubClient Hub
@inject NavigationManager Nav
@inject ActiveProjectState ActiveProject
@inject AdminSessionService Session
@using PageToMovie.Core.Models

<PageTitle>PageToMovie</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <img src="/favicon.png" alt="PageToMovie" width="68" height="68" class="rounded-3 shadow" />
    <div>
        <h1 class="display-6 fw-bold mb-0 lh-1">PageToMovie</h1>
        <span class="text-muted fs-6">Turn books and screenplays into movies</span>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

@if (_healthOk == false)
{
    <div class="alert alert-warning">
        Server not reachable. Start the Film Studio API, then reload this page.
    </div>
}

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Projects</span>
                <button class="btn btn-primary btn-sm"
                        data-testid="home-new-project"
                        disabled="@(_busy || !Session.IsLoggedIn)"
                        title="@(Session.IsLoggedIn ? "Create a project" : "Sign in to create projects")"
                        @onclick="() => _showNew = !_showNew">
                    @(_showNew ? "Cancel" : "New project")
                </button>
            </div>
            <div class="card-body">
                @if (!Session.IsLoggedIn)
                {
                    <div class="alert alert-warning py-2 small mb-3">
                        <strong>Sign in required.</strong>
                        <a href="login?returnUrl=/" class="alert-link">Sign in or create an account</a>
                        to create projects and save your Grok API key.
                    </div>
                }

                @if (_projects is null)
                {
                    <p class="text-muted mb-0">Loading…</p>
                }
                else if (_projects.Projects.Count == 0 && !_showNew)
                {
                    <p class="text-muted mb-0">No projects yet. Click <strong>New project</strong> to get started.</p>
                }
                else if (_projects.Projects.Count > 0)
                {
                    <div class="list-group project-list">
                        @foreach (var p in _projects.Projects)
                        {
                            var id = p.Id ?? "";
                            var active = string.Equals(id, _projects.Active?.Id, StringComparison.OrdinalIgnoreCase);
                            <div class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-0 px-0 @(active ? "active" : null)">
                                <button type="button"
                                        class="btn border-0 bg-transparent flex-grow-1 text-start py-2 px-3 project-list__pick @(active ? "text-white" : null)"
                                        data-testid="@($"home-project-{id}")"
                                        data-project-id="@id"
                                        data-project-active="@(active ? "true" : "false")"
                                        title="Click to select, double-click to open"
                                        disabled="@_busy"
                                        @onclick="() => SelectProjectAsync(id)"
                                        @ondblclick="() => OpenProjectAsync(id)">
                                    <strong>@(p.Label ?? p.Title ?? id)</strong>
                                </button>
                                @if (active)
                                {
                                    <a class="btn btn-sm btn-light flex-shrink-0" data-testid="home-open-adaptation" href="adaptation">Open</a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger me-2 flex-shrink-0 @(active ? "border-light text-white" : null)"
                                            disabled="@_busy"
                                            @onclick="() => BeginDeleteAsync(id, p.Label ?? p.Title ?? id)">
                                        Delete
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }

                @* New project form sits under the list so the list stays stable; Create is on the right. *@
                @if (_showNew && Session.IsLoggedIn)
                {
                    <div class="border rounded p-2 mt-3 bg-body-tertiary">
                        @if (ActiveProject.Status is not null && !ActiveProject.Status.XaiConfigured)
                        {
                            <div class="alert alert-warning py-1 px-2 small mb-2">
                                ⚠️ <strong>Notice:</strong> No AI API key yet.
                                <a href="configuration" class="alert-link">Add your Grok key →</a>
                                before book import / OCR.
                            </div>
                        }
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <input class="form-control form-control-sm flex-grow-1"
                                   style="min-width: 10rem;"
                                   data-testid="home-new-project-name"
                                   value="@_newName"
                                   @oninput="OnNewNameInput"
                                   @onkeydown="OnNewNameKeyDown"
                                   disabled="@_busy"
                                   placeholder="Project name"
                                   maxlength="80"
                                   autofocus
                                   aria-label="New project name" />
                            <button class="btn btn-success btn-sm flex-shrink-0"
                                    data-testid="home-create-project"
                                    disabled="@(_busy || string.IsNullOrWhiteSpace(_newName))"
                                    @onclick="CreateProjectAsync">
                                Create
                            </button>
                        </div>
                    </div>
                }

                @if (_deleteId is not null)
                {
                    <div class="border border-danger rounded p-2 mt-3 bg-light">
                        <p class="small mb-2">
                            Delete <strong>@_deleteLabel</strong>? This removes the project folder and all its files.
                        </p>
                        <label class="form-label small mb-1">Type the project name to confirm</label>
                        <input class="form-control form-control-sm mb-2"
                               value="@_deleteConfirm"
                               @oninput="OnDeleteConfirmInput"
                               disabled="@_busy"
                               placeholder="@_deleteLabel"
                               autocomplete="off" />
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    disabled="@(_busy || !CanConfirmDelete)"
                                    @onclick="ConfirmDeleteAsync">
                                Delete permanently
                            </button>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    disabled="@_busy"
                                    @onclick="CancelDelete">
                                Cancel
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <button type="button"
                    class="card-header d-flex justify-content-between align-items-center w-100 border-0 text-start home-jobs-toggle"
                    data-testid="home-jobs-toggle"
                    aria-expanded="@(_jobsExpanded ? "true" : "false")"
                    @onclick="ToggleJobsExpanded">
                <span class="d-flex align-items-center gap-2">
                    <span class="home-jobs-chevron @(_jobsExpanded ? "home-jobs-chevron--open" : null)" aria-hidden="true">▾</span>
                    <span>My jobs</span>
                    @if (HasActiveJob)
                    {
                        <span class="badge text-bg-primary">@FriendlyStatus(_job!.Status)</span>
                    }
                </span>
                <span class="badge text-bg-secondary">@_myJobs.Count</span>
            </button>
            @if (_jobsExpanded)
            {
                <div class="card-body">
                    @if (_myJobs.Count == 0 && _job is null)
                    {
                        <p class="text-muted mb-0">No recent jobs. Generation and adaptation work will show up here.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var j in _myJobs.Take(8))
                            {
                                <li class="list-group-item px-0 py-2 small">
                                    <span class="badge bg-secondary">@FriendlyStatus(j.Status)</span>
                                    <span>@FriendlyKind(j.Kind)</span>
                                    @if (j.Total > 0) { <span class="text-muted">@j.Index/@j.Total</span> }
                                    <div class="text-muted">@FriendlyJobLine(j)</div>
                                </li>
                            }
                        </ul>
                    }
                    @if (_job is not null)
                    {
                        var jobLine = FriendlyJobLine(_job);
                        var showError = string.Equals(_job.Status, "error", StringComparison.OrdinalIgnoreCase)
                                        && !string.IsNullOrWhiteSpace(_job.Error);
                        <p class="mb-1">
                            <strong>Current:</strong>
                            <span class="badge bg-secondary">@FriendlyStatus(_job.Status)</span>
                            @if (_job.Total > 0)
                            {
                                <span class="ms-1">@_job.Index / @_job.Total</span>
                            }
                        </p>
                        @if (showError || string.Equals(_job.Status, "error", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="alert alert-danger py-2 small mb-2">
                                <div class="fw-semibold mb-1">@FriendlyKind(_job.Kind) failed</div>
                                <div>@FriendlyOperatorError(_job)</div>
                                @if (Session.IsAdmin &&
                                     !string.IsNullOrWhiteSpace(_job.Error) &&
                                     !string.Equals(_job.Error.Trim(), FriendlyOperatorError(_job), StringComparison.Ordinal))
                                {
                                    <div class="text-muted mt-1" style="word-break: break-word;">
                                        <code class="small">@_job.Error</code>
                                    </div>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(jobLine))
                        {
                            <p class="small mb-2">@jobLine</p>
                        }
                        @if (Session.IsAdmin && _job.Log.Count > 0)
                        {
                            <details class="mb-2" open="@JobLogHasVideoPayload(_job)">
                                <summary class="small text-muted" style="cursor:pointer">
                                    Details (admin)
                                    @if (JobLogHasVideoPayload(_job))
                                    {
                                        <span class="badge text-bg-dark ms-1">video API</span>
                                    }
                                </summary>
                                <pre class="small mb-0 mt-1" style="max-height: 420px; overflow: auto; white-space: pre-wrap;">@string.Join("\n", _job.Log.TakeLast(400))</pre>
                                <p class="form-text mb-0 mt-1">
                                    Full prompts also under <code>projects/…/assets/video/prompts/SxxCyy.txt</code>
                                </p>
                            </details>
                        }
                        @if (string.Equals(_job.Status, "running", StringComparison.OrdinalIgnoreCase) ||
                             string.Equals(_job.Status, "queued", StringComparison.OrdinalIgnoreCase))
                        {
                            <button class="btn btn-outline-danger btn-sm mt-2" disabled="@_busy" @onclick="CancelAsync">
                                Cancel
                            </button>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool? _healthOk;
    private bool _busy;
    private string? _error;
    private string? _message;
    private ProjectsDto? _projects;
    private JobSnapshot? _job;
    private List<JobSnapshot> _myJobs = new();
    private bool _showNew;
    private string _newName = "";
    private string? _deleteId;
    private string _deleteLabel = "";
    private string _deleteConfirm = "";
    /// <summary>My jobs panel; collapsed by default, auto-opens when a job is running/queued.</summary>
    private bool _jobsExpanded;
    /// <summary>Null = follow auto rules; otherwise honor last user click.</summary>
    private bool? _jobsUserPreference;

    private bool CanConfirmDelete =>
        _deleteId is not null &&
        (string.Equals(_deleteConfirm.Trim(), _deleteId, StringComparison.OrdinalIgnoreCase) ||
         string.Equals(_deleteConfirm.Trim(), _deleteLabel.Trim(), StringComparison.OrdinalIgnoreCase));

    private bool HasActiveJob =>
        _job is not null &&
        (string.Equals(_job.Status, "running", StringComparison.OrdinalIgnoreCase) ||
         string.Equals(_job.Status, "queued", StringComparison.OrdinalIgnoreCase));

    private void ToggleJobsExpanded()
    {
        _jobsExpanded = !_jobsExpanded;
        _jobsUserPreference = _jobsExpanded;
    }

    private void SyncJobsExpandedFromJob()
    {
        if (_jobsUserPreference is bool prefer)
            _jobsExpanded = prefer;
        else
            _jobsExpanded = HasActiveJob; // collapsed when idle, open when work is running
    }

    protected override async Task OnInitializedAsync()
    {
        Hub.JobUpdated += OnJobUpdated;
        Hub.JobLog += OnJobLog;
        try { await Session.EnsureHydratedAsync(); } catch { /* optional */ }
        await LoadAsync();
        try
        {
            await Hub.StartAsync();
        }
        catch
        {
            // SignalR optional for browse
        }
    }

    private void OnJobUpdated(JobSnapshot snap)
    {
        _job = snap;
        SyncJobsExpandedFromJob();
        _ = InvokeAsync(async () =>
        {
            try
            {
                var mine = await Engine.GetJobsAsync(mine: true);
                _myJobs = mine?.Jobs?
                    .OrderByDescending(j => j.StartedAt ?? j.QueuedAt)
                    .Take(12)
                    .ToList()
                    ?? new List<JobSnapshot>();
            }
            catch { /* ignore */ }
            SyncJobsExpandedFromJob();
            StateHasChanged();
        });
    }

    private void OnJobLog(string line)
    {
        if (_job is not null)
        {
            _job.Message = line;
            // Keep rolling admin log so video API prompts appear live on Home
            _job.Log ??= new List<string>();
            _job.Log.Add(line);
            if (_job.Log.Count > 2000)
                _job.Log.RemoveRange(0, _job.Log.Count - 1500);
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private static bool JobLogHasVideoPayload(JobSnapshot j) =>
        j.Log.Any(l =>
            l.Contains("PROMPT BEGIN", StringComparison.OrdinalIgnoreCase) ||
            l.Contains("[Grok] Submit", StringComparison.OrdinalIgnoreCase) ||
            l.Contains("video-extend", StringComparison.OrdinalIgnoreCase) ||
            l.Contains("reference-to-video", StringComparison.OrdinalIgnoreCase));

    private async Task LoadAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            try
            {
                await Engine.EnsureHealthyAsync();
                _healthOk = true;
            }
            catch
            {
                _healthOk = false;
                _projects = null;
                return;
            }

            _projects = await Engine.GetProjectsAsync();
            await ActiveProject.RefreshFromApiAsync(Engine);

            var jobs = await Engine.GetJobAsync();
            _job = jobs?.Job;
            try
            {
                var mine = await Engine.GetJobsAsync(mine: true);
                _myJobs = mine?.Jobs?
                    .OrderByDescending(j => j.StartedAt ?? j.QueuedAt)
                    .Take(12)
                    .ToList()
                    ?? new List<JobSnapshot>();
            }
            catch { _myJobs = new List<JobSnapshot>(); }
            SyncJobsExpandedFromJob();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnNewNameInput(ChangeEventArgs e)
    {
        _newName = e.Value?.ToString() ?? "";
    }

    private async Task OnNewNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_busy && !string.IsNullOrWhiteSpace(_newName))
            await CreateProjectAsync();
    }

    private async Task CreateProjectAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        if (!Session.IsLoggedIn)
        {
            _error = "Sign in required to create a project.";
            Nav.NavigateTo("/login?returnUrl=/");
            return;
        }
        _busy = true;
        _error = null;
        try
        {
            var name = _newName.Trim();
            var result = await Engine.CreateProjectAsync(name);
            _projects = result ?? await Engine.GetProjectsAsync();
            var created = _projects?.Active;
            if (created?.Id is { Length: > 0 } cid)
            {
                ActiveProject.Set(cid, created.Label ?? created.Title ?? cid);
                await ActiveProject.RefreshReadinessAsync(Engine);
            }
            else
                await ActiveProject.RefreshFromApiAsync(Engine);
            _message = $"Created “{name}”";
            _newName = "";
            _showNew = false;
            Nav.NavigateTo("adaptation");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task SelectProjectAsync(string id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        if (string.Equals(id, _projects?.Active?.Id, StringComparison.OrdinalIgnoreCase))
            return;

        _busy = true;
        _error = null;
        _message = null;
        _deleteId = null;
        _deleteConfirm = "";
        try
        {
            await Engine.ActivateProjectAsync(id);
            _projects = await Engine.GetProjectsAsync();
            var a = _projects?.Active;
            ActiveProject.Set(id, a?.Label ?? a?.Title ?? id);
            await ActiveProject.RefreshReadinessAsync(Engine);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task OpenProjectAsync(string id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        await SelectProjectAsync(id);
        Nav.NavigateTo("adaptation");
    }

    private Task BeginDeleteAsync(string id, string label)
    {
        _deleteId = id;
        _deleteLabel = label;
        _deleteConfirm = "";
        _error = null;
        _message = null;
        return Task.CompletedTask;
    }

    private void OnDeleteConfirmInput(ChangeEventArgs e) =>
        _deleteConfirm = e.Value?.ToString() ?? "";

    private void CancelDelete()
    {
        _deleteId = null;
        _deleteLabel = "";
        _deleteConfirm = "";
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteId is null || !CanConfirmDelete) return;
        var id = _deleteId;
        _busy = true;
        _error = null;
        try
        {
            var result = await Engine.DeleteProjectAsync(id);
            _projects = result ?? await Engine.GetProjectsAsync();
            await ActiveProject.RefreshFromApiAsync(Engine);
            _message = $"Deleted “{_deleteLabel}”";
            CancelDelete();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            await Engine.CancelJobAsync();
            _message = "Cancel requested";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private static string FriendlyStatus(string? status) =>
        string.IsNullOrWhiteSpace(status) ? "…" : status!;

    private static string FriendlyKind(string? kind) => kind switch
    {
        "character" => "Portrait",
        "character-plates" => "Book pictures",
        "stage1" => "Screenplay",
        "stage2" => "Shot plan",
        "video" or "clip" => "Clip",
        _ => string.IsNullOrWhiteSpace(kind) ? "Job" : kind!,
    };

    /// <summary>Short operator line — prefer real error text when the job failed.</summary>
    private static string FriendlyJobLine(JobSnapshot j)
    {
        if (string.Equals(j.Status, "error", StringComparison.OrdinalIgnoreCase))
            return FriendlyOperatorError(j);
        if (string.Equals(j.Status, "cancelled", StringComparison.OrdinalIgnoreCase))
            return "Cancelled.";
        if (string.Equals(j.Status, "done", StringComparison.OrdinalIgnoreCase))
            return "Done.";
        // Running / queued: prefer a short outcome phrase over raw Message (which may be technical)
        if (string.Equals(j.Kind, "character", StringComparison.OrdinalIgnoreCase))
            return "Creating portrait…";
        if (string.Equals(j.Kind, "character-plates", StringComparison.OrdinalIgnoreCase))
            return "Matching book pictures…";
        if (string.Equals(j.Kind, "book_import", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(j.Kind, "book_prepare", StringComparison.OrdinalIgnoreCase))
        {
            var running = j.Message ?? "Importing book…";
            return TrimOneLine(running, 160);
        }
        var msg = j.Message ?? "";
        return TrimOneLine(msg, 120);
    }

    /// <summary>
    /// Operator-facing error. Prefer the job's Error/Message (what failed) with light cleanup,
    /// instead of a useless generic "Something went wrong."
    /// </summary>
    private static string FriendlyOperatorError(JobSnapshot j)
    {
        var raw = FirstNonEmpty(j.Error, j.Message);
        if (!string.IsNullOrWhiteSpace(raw))
        {
            var cleaned = SanitizeOperatorError(raw);
            if (!string.IsNullOrWhiteSpace(cleaned))
                return cleaned;
        }

        // Fallbacks only when the job carried no useful text
        if (string.Equals(j.Kind, "character", StringComparison.OrdinalIgnoreCase))
            return "Portrait generation failed. Check your image API key and try again.";
        if (string.Equals(j.Kind, "character-plates", StringComparison.OrdinalIgnoreCase))
            return "Could not match book pictures. Ensure the book was prepared and a vision-capable key is set.";
        if (string.Equals(j.Kind, "book_import", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(j.Kind, "book_prepare", StringComparison.OrdinalIgnoreCase))
            return "Book import failed. Check API key (Grok for picture-book OCR), PDF upload, and job details.";
        if (string.Equals(j.Kind, "stage1", StringComparison.OrdinalIgnoreCase))
            return "Screenplay draft failed. Check the planning model key and book text.";
        if (string.Equals(j.Kind, "stage2", StringComparison.OrdinalIgnoreCase))
            return "Shot plan failed. Check the planning model key and screenplay.";
        return "Job failed. Open the project and check Configuration keys / job details.";
    }

    private static string? FirstNonEmpty(params string?[] parts)
    {
        foreach (var p in parts)
        {
            if (!string.IsNullOrWhiteSpace(p))
                return p.Trim();
        }
        return null;
    }

    /// <summary>Strip stack/path noise; keep the actionable sentence.</summary>
    private static string SanitizeOperatorError(string raw)
    {
        var s = raw.Replace("\r\n", "\n").Trim();
        // First line only (stacks often follow)
        var nl = s.IndexOf('\n');
        if (nl > 0) s = s[..nl].Trim();

        // Drop leading "System.X: " type prefixes
        if (s.StartsWith("System.", StringComparison.Ordinal))
        {
            var colon = s.IndexOf(": ", StringComparison.Ordinal);
            if (colon > 0 && colon < 80)
                s = s[(colon + 2)..].Trim();
        }

        // Known high-value rewrites (clearer than raw API blobs)
        if (s.Contains("XAI_API_KEY", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("API key missing", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Connect your AI", StringComparison.OrdinalIgnoreCase))
            return "No AI API key. Open Configuration and add your xAI / Grok key (required for picture-book OCR and screenplay).";

        if (s.Contains("No page images", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Could not extract or render page images", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Page render failed", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("libpdfium", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("libSkiaSharp", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("DllNotFoundException", StringComparison.OrdinalIgnoreCase))
            return "Could not render PDF pages for OCR (picture books need page images). " +
                   "On Railway, the server needs PDF render libraries; redeploy after the Docker font/Skia fix. Detail: " +
                   TrimOneLine(s, 180);

        if (s.Contains("No PDF and no book_full", StringComparison.OrdinalIgnoreCase))
            return "No book file found on the server. Re-upload the PDF, then import again.";

        if (s.Contains("timeout", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("timed out", StringComparison.OrdinalIgnoreCase))
            return "Book import timed out (OCR + screenplay can take several minutes). Try again; for long books use a smaller PDF or check the job log.";

        if (s.Contains("could not be decrypted", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("encryption keys changed", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("DataProtector", StringComparison.OrdinalIgnoreCase))
            return "Saved Grok key cannot be decrypted after redeploy. Re-open Configuration and save the key again. Mount a Railway Volume at /data so keys persist.";

        if (s.Contains("HTTP 401", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Incorrect API key", StringComparison.OrdinalIgnoreCase))
            return "xAI rejected the API key (401). Re-save a valid Grok key in Configuration, or set XAI_API_KEY on the Railway service.";

        if (s.Contains("HTTP 429", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("rate limit", StringComparison.OrdinalIgnoreCase))
            return "xAI rate limit hit. Wait a minute and try import again.";

        if (s.Contains("Could not build a usable screenplay", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("Book adapt", StringComparison.OrdinalIgnoreCase) ||
            s.Contains("chunk", StringComparison.OrdinalIgnoreCase) && s.Contains("failed", StringComparison.OrdinalIgnoreCase))
            return "Screenplay generation failed after book text was ready. " + TrimOneLine(s, 200);

        return TrimOneLine(s, 280);
    }

    private static string TrimOneLine(string s, int max)
    {
        s = s.Replace('\n', ' ').Replace('\r', ' ').Trim();
        while (s.Contains("  ", StringComparison.Ordinal))
            s = s.Replace("  ", " ", StringComparison.Ordinal);
        if (s.Length > max) return s[..(max - 1)] + "…";
        return s;
    }

    public async ValueTask DisposeAsync()
    {
        Hub.JobUpdated -= OnJobUpdated;
        Hub.JobLog -= OnJobLog;
        await Hub.DisposeAsync();
    }
}
