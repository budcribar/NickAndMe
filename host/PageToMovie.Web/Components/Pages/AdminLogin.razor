@page "/admin/login"
@inject EngineApiClient Api
@inject AdminSessionService Session
@inject NavigationManager Nav

<PageTitle>Admin login — Film Studio</PageTitle>

<div class="container py-4" style="max-width: 28rem;">
    <h1 class="h3 mb-3">Admin login</h1>
    <p class="text-muted small">
        API login returns a JWT (not a browser cookie). Dev: <code>admin</code> / <code>admin</code>.
    </p>

    @if (_busy && string.IsNullOrEmpty(_error))
    {
        <p class="text-muted">@_status</p>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input class="form-control" @bind="_username" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="_password" autocomplete="current-password"
                   @onkeydown="OnKeyDown" />
        </div>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }
        <button type="button" class="btn btn-primary" @onclick="LoginAsync" disabled="@_busy">
            @(_busy ? "Signing in…" : "Sign in")
        </button>
        <p class="small text-muted mt-3 mb-0">
            Prefer <code>http://localhost:5079</code> (Web <strong>http</strong> profile).
        </p>
    }
</div>

@code {
    private string _username = "admin";
    private string _password = "admin";
    private string? _error;
    private string _status = "Checking session…";
    private bool _busy;
    private bool _started;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        try
        {
            await Session.EnsureHydratedAsync();
            if (Session.IsAdmin)
            {
                _busy = true;
                _status = $"Signed in as {Session.UserId}. Opening dashboard…";
                StateHasChanged();
                // forceLoad: full navigation so layout/nav re-bind cleanly
                Nav.NavigateTo("/admin", forceLoad: true);
                return;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoginAsync();
    }

    private async Task LoginAsync()
    {
        _busy = true;
        _error = null;
        _status = "Signing in…";
        try
        {
            var resp = await Api.LoginAsync(_username ?? "", _password ?? "");
            if (resp is null || !resp.Ok || string.IsNullOrWhiteSpace(resp.Token))
            {
                _error = resp?.Error
                         ?? "Login failed — is PageToMovie.Api running on http://127.0.0.1:5088?";
                return;
            }

            Session.SetSession(resp.Token!, resp.UserId, resp.Roles, resp.ExpiresAt);

            // Give sessionStorage a moment to flush
            await Task.Delay(50);
            await Session.EnsureHydratedAsync();

            if (!Session.IsAdmin)
            {
                Session.Clear();
                _error = "Token missing admin role. Check PageToMovie:Auth on the API.";
                return;
            }

            _status = "Opening dashboard…";
            Nav.NavigateTo("/admin", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            _error = $"Cannot reach API: {ex.Message}. Start PageToMovie.Api (port 5088).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
