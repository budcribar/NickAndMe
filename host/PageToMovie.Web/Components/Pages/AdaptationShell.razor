@* Shared header + step strip + job log for Adaptation step pages *@
@inject AdminSessionService Session

@if (Host is null)
{
    return;
}

<div class="d-flex flex-wrap align-items-baseline justify-content-between gap-2 mb-1">
    <h1 class="mb-0">Adaptation</h1>
    @if (!string.IsNullOrEmpty(Host.ProjectLabel))
    {
        <span class="text-muted small">@Host.ProjectLabel</span>
    }
</div>
<p class="text-muted mb-3">Import → screenplay → characters → shot plan → scenes.</p>

@* ---- Step strip (frozen while a job runs — only Cancel in the progress card is live) ---- *@
@{
    var stepsLocked = Host.JobRunning;
}
<nav class="nav nav-pills flex-wrap gap-1 mb-3" aria-label="Adaptation steps">
    <a class="nav-link @(Step == "import" || Step == "book" ? "active" : "") @(stepsLocked ? "disabled" : "")"
       href="@(stepsLocked ? "javascript:void(0)" : "adaptation/import")"
       @onclick:preventDefault="stepsLocked">1 · Import</a>
    <a class="nav-link @(Step == "screenplay" ? "active" : "") @(!OutlineEnabled || stepsLocked ? "disabled" : "")"
       href="@(!OutlineEnabled || stepsLocked ? "javascript:void(0)" : "adaptation/screenplay")"
       @onclick:preventDefault="@(!OutlineEnabled || stepsLocked)"
       title="@(stepsLocked ? "Wait for the current job to finish" : OutlineEnabled ? null : "Import a source first")">2 · Screenplay</a>
    <a class="nav-link @(Step == "characters" ? "active" : "") @(!ShotsEnabled || stepsLocked ? "disabled" : "")"
       href="@(!ShotsEnabled || stepsLocked ? "javascript:void(0)" : "characters")"
       @onclick:preventDefault="@(!ShotsEnabled || stepsLocked)"
       title="@(stepsLocked ? "Wait for the current job to finish" : ShotsEnabled ? "Pin cast likeness before clips" : "Approve a screenplay first")">3 · Characters</a>
    <a class="nav-link @(Step == "shots" ? "active" : "") @(!ShotsEnabled || stepsLocked ? "disabled" : "")"
       href="@(!ShotsEnabled || stepsLocked ? "javascript:void(0)" : "adaptation/shots")"
       @onclick:preventDefault="@(!ShotsEnabled || stepsLocked)"
       title="@(stepsLocked ? "Wait for the current job to finish" : ShotsEnabled ? null : "Approve a screenplay first")">4 · Shot plan</a>
</nav>

@if (!string.IsNullOrEmpty(Host.Error))
{
    <div class="alert alert-danger">@Host.Error</div>
}
@* Hide completion/status noise while Import or a job is still running *@
@if (!string.IsNullOrEmpty(Host.Message) && !Host.SuppressGuidanceBanners)
{
    <div class="alert alert-info">@Host.Message</div>
}

@* In-page busy (e.g. screenplay approve) — not a background job, but can take many seconds.
   Skip on Import: that page already has its own progress card. *@
@if (Host.Busy && !Host.JobRunning && Step is not "import" and not "book")
{
    <div class="card mb-3 border-primary" data-testid="busy-progress">
        <div class="card-body py-2">
            <div class="small mb-1">@(string.IsNullOrWhiteSpace(Host.BusyMessage) ? "Working…" : Host.BusyMessage)</div>
            <div class="progress" style="height: 0.85rem;" role="progressbar"
                 aria-valuemin="0" aria-valuemax="100" aria-valuenow="45"
                 aria-label="@(Host.BusyMessage ?? "Working")">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                     style="width: 45%"></div>
            </div>
        </div>
    </div>
}

@* Job panel: progress + Cancel only while running. Admin can expand Details. *@
@if (ShowJobPanel)
{
    <div class="card mb-3 border-@(Host.Job!.Status is "running" or "queued" ? "primary" : Host.Job.Status == "error" ? "danger" : "secondary")"
         data-testid="job-panel"
         data-job-status="@Host.Job.Status"
         data-job-kind="@(Host.Job.Kind ?? "")"
         data-job-running="@(Host.JobRunning ? "true" : "false")">
        <div class="card-body py-2">
            @{
                var (jobIdx, jobTot, waiting, displayIdx) = AdaptationPageBase.ComputeJobProgress(
                    Host.Job, Host.ProgressIndex, Host.ProgressTotal, Host.JobRunning);
            }
            <div class="d-flex justify-content-between flex-wrap gap-2 align-items-center">
                <div class="small">
                    <span class="visually-hidden" data-testid="job-status">@Host.Job.Status</span>
                    @if (Host.JobRunning)
                    {
                        <span>@AdaptationPageBase.OperatorJobRunningMessage(Host.Job)</span>
                    }
                    else
                    {
                        <span>@AdaptationPageBase.OperatorJobDoneMessage(Host.Job)</span>
                    }
                </div>
                @if (Host.JobRunning)
                {
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-testid="job-cancel"
                            @onclick="Host.CancelAsync">Cancel</button>
                }
            </div>
            @if (Host.JobRunning)
            {
                var pct = AdaptationPageBase.ComputeProgressPercent(
                    displayIdx, jobTot, waiting, Host.JobRunning, Host.Job.StartedAt);
                <div class="progress mt-2" style="height: 0.85rem;" role="progressbar"
                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"
                     aria-label="@AdaptationPageBase.OperatorJobRunningMessage(Host.Job)">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         style="width: @pct%"></div>
                </div>
            }
            @* Admin-only: expandable log — not shown by default (avoids stacking with the message line). *@
            @if (Session.IsAdmin && Host.Job.Log.Count > 0 && !Host.JobRunning)
            {
                <button type="button"
                        class="btn btn-sm btn-link text-muted p-0 mt-1 text-decoration-none"
                        @onclick="() => _showHistory = !_showHistory">
                    @(_showHistory ? "Hide details" : "Details (admin)")
                </button>
                @if (_showHistory)
                {
                    <pre class="small mb-0 mt-1" style="max-height: 200px; overflow: auto;">@string.Join("\n", Host.Job.Log.TakeLast(40))</pre>
                }
            }
        </div>
    </div>
}

@if (Host.Status is null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @* Skip “Next” when it only restates the step you’re already on *@
    @if (ShowNextBanner)
    {
        <div class="alert @AdaptationPageBase.NextStepAlertClass(Host.Status.NextStep) py-2">
            <strong>Next:</strong> @AdaptationPageBase.NextStepLabel(Host.Status.NextStep)
            @if (!Host.Status.XaiConfigured && Host.Status.NextStep is "draft_screenplay" or "run_stage1" or "run_stage2" or "replan_stage2")
            {
                <span class="ms-2">· <a href="configuration">Connect service</a></span>
            }
        </div>
    }

    @ChildContent
}

@code {
    [Parameter, EditorRequired] public AdaptationPageBase Host { get; set; } = null!;
    [Parameter, EditorRequired] public string Step { get; set; } = "book";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _showHistory;

    private bool OutlineEnabled => AdaptationPageBase.OutlineEnabled(Host.Status);

    private bool ShotsEnabled => AdaptationPageBase.ShotsEnabled(Host.Status);

    private bool ShowJobPanel => AdaptationPageBase.ShowJobPanel(Session.IsAdmin, Host.Job, Step);

    protected override async Task OnInitializedAsync()
    {
        try { await Session.EnsureHydratedAsync(); } catch { /* optional */ }
    }

    private bool ShowNextBanner =>
        AdaptationPageBase.ShowNextStepBanner(Host.Status, Host.SuppressGuidanceBanners, Step ?? "");

}
