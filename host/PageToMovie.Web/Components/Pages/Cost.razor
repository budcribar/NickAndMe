@page "/cost"
@inject EngineApiClient Engine
@using PageToMovie.Core.Models

<PageTitle>Cost</PageTitle>

<h1>Cost</h1>
<p class="text-muted">
    <strong>Actual</strong> = tracked spend at vendor list rates for the models used.
    <strong>Estimates</strong> = catalog rates for the project’s selected video/image models × plan size.
    Neither is your cloud invoice.
</p>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-3">
        <label class="form-label">Project</label>
        <select class="form-select" @bind="_projectId" @bind:after="LoadAsync" disabled="@_busy">
            @foreach (var p in _projectIds)
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Draft res</label>
        <select class="form-select" @bind="_draftRes" @bind:after="LoadAsync" disabled="@_busy">
            <option value="480p">480p</option>
            <option value="720p">720p</option>
            <option value="1080p">1080p</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Hero res</label>
        <select class="form-select" @bind="_heroRes" @bind:after="LoadAsync" disabled="@_busy">
            <option value="720p">720p</option>
            <option value="1080p">1080p</option>
            <option value="480p">480p</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Avg retries</label>
        <input type="number" class="form-control" min="0" max="3" step="0.25"
               @bind="_retries" @bind:after="LoadAsync" disabled="@_busy" />
    </div>
    <div class="col-md-3 d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="LoadAsync">Reload</button>
        <button class="btn btn-outline-primary" disabled="@_busy" @onclick="BackfillAsync"
                title="Infer ledger rows for on-disk clips with no tracked event">
            Backfill actuals
        </button>
    </div>
</div>

@if (_report is null)
{
    <p class="text-muted">Loading cost report…</p>
}
else
{
    var s = _report.Summary;
    var a = _report.Actual;

    <div class="card mb-3">
        <div class="card-header">Actual (tracked)</div>
        <div class="card-body">
            <p class="small text-muted">@a.Notes</p>
            <div class="row g-3 text-center">
                <div class="col-6 col-md-3">
                    <div class="display-6 fs-3">@Usd(s.ActualUsd)</div>
                    <div class="small text-muted">Actual total</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="display-6 fs-3">@s.ActualEvents</div>
                    <div class="small text-muted">Ledger events</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="display-6 fs-3">@s.ActualVideoJobs</div>
                    <div class="small text-muted">Video jobs</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="display-6 fs-3">@s.ActualVideoSec.ToString("0.#")</div>
                    <div class="small text-muted">Video seconds</div>
                </div>
            </div>
            @if (a.ByKind.Count > 0)
            {
                <p class="small mt-3 mb-1">
                    By kind:
                    @string.Join(" · ", a.ByKind.Select(kv => $"{kv.Key}={Usd(kv.Value)}"))
                </p>
            }
            @if (a.ByModel.Count > 0)
            {
                <p class="small mb-0">
                    By model:
                    @string.Join(" · ", a.ByModel.Select(kv => $"`{kv.Key}` {Usd(kv.Value)}"))
                </p>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Estimates (planning)</div>
        <div class="card-body">
            <p class="small text-muted">
                Vendor rates for <strong>@(_report.VideoProvider)</strong> /
                <code>@(_report.ModelName)</code>
                · Draft @Usd(_report.OutputRateDraft)/sec · Hero @Usd(_report.OutputRateHero)/sec
                · retries @_report.AssumeAvgRetries.ToString("0.##")
                (from model catalog; change models in Configuration)
            </p>
            <div class="row g-3 text-center mb-3">
                <div class="col-6 col-md-3">
                    <div class="fs-4">@s.ClipsOnDisk/@s.ClipsTotal</div>
                    <div class="small text-muted">Clips on disk</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-4">@Usd(s.SpentUsd)</div>
                    <div class="small text-muted">Est. spent (on disk)</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-4">@Usd(s.RemainingFirstPassUsd)</div>
                    <div class="small text-muted">Remaining first pass</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-4">@Usd(s.RemainingHeroUpgradeUsd)</div>
                    <div class="small text-muted">Hero upgrades left</div>
                </div>
            </div>
            <div class="row g-3 text-center">
                <div class="col-6 col-md-3">
                    <div class="fs-5">@Usd(s.FinishDraftUsd)</div>
                    <div class="small text-muted">Finish draft (est+missing)</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5">@Usd(s.FinishFromActualUsd)</div>
                    <div class="small text-muted">Finish from actual+missing</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5">@Usd(s.FullFilmAllDraftUsd)</div>
                    <div class="small text-muted">Full film @(_report.DraftResolution)</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fs-5">@Usd(s.FullFilmAllHeroUsd)</div>
                    <div class="small text-muted">Full film @(_report.HeroResolution)</div>
                </div>
            </div>
            <div class="progress mt-3" style="height: 1.25rem;">
                <div class="progress-bar" role="progressbar"
                     style="width: @(ProgressPct(s))%"
                     aria-valuenow="@s.ClipsOnDisk" aria-valuemin="0" aria-valuemax="@Math.Max(1, s.ClipsTotal)">
                    @s.ClipsOnDisk / @s.ClipsTotal clips
                </div>
            </div>
            <p class="small text-muted mt-2 mb-0">
                @s.ScenesWithMedia/@s.ScenesTotal scenes with media · @s.ScenesHero hero
                · @s.SecOnDisk.ToString("0.#")s on disk · @s.SecMissing.ToString("0.#")s missing
            </p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Compare resolutions</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Scenario</th>
                            <th>$/sec</th>
                            <th>Full film</th>
                            <th>Remaining</th>
                            <th>Regen on-disk</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _report.Scenarios)
                        {
                            var cheap = _cheapestLabel == r.Label;
                            <tr class="@(cheap ? "table-success" : "")">
                                <td>
                                    @r.Label
                                    @if (cheap)
                                    {
                                        <span class="badge bg-success ms-1">cheapest</span>
                                    }
                                </td>
                                <td>@Usd(r.RatePerSec)</td>
                                <td>@Usd(r.FullFilmUsd)</td>
                                <td>@Usd(r.RemainingMissingUsd)</td>
                                <td>@Usd(r.RegenOnDiskUsd)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Breakdown by scene</span>
            <div class="btn-group btn-group-sm">
                @foreach (var mode in new[] { "all", "with media", "incomplete" })
                {
                    <button type="button"
                            class="btn @(_filter == mode ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="() => _filter = mode">
                        @mode
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small mb-0">Character</label>
                    <select class="form-select form-select-sm" @bind="_filterCharacter">
                        <option value="">All characters</option>
                        @foreach (var c in CharacterOptions)
                        {
                            <option value="@c">@ShortChar(c)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-0">Location</label>
                    <select class="form-select form-select-sm" @bind="_filterLocation">
                        <option value="">All locations</option>
                        @foreach (var loc in LocationOptions)
                        {
                            <option value="@loc">@ShortLoc(loc)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-0">Setting text</label>
                    <input class="form-control form-control-sm" @bind="_filterText" @bind:event="oninput"
                           placeholder="e.g. yard" />
                </div>
                <div class="col-md-2">
                    @if (HasSceneFilters)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearSceneFilters">Clear</button>
                    }
                    <span class="small text-muted ms-1">@FilteredScenes.Count() shown</span>
                </div>
            </div>
            <div class="table-responsive p-0" style="max-height: 420px; overflow: auto;">
                <table class="table table-sm table-hover mb-0">
                    <thead class="sticky-top bg-white">
                        <tr>
                            <th>#</th>
                            <th>Setting</th>
                            <th>Cast / loc</th>
                            <th>Clips</th>
                            <th>Actual $</th>
                            <th>Est spent</th>
                            <th>Remaining</th>
                            <th>Hero upg</th>
                            <th>All @_report.DraftResolution</th>
                            <th>All @_report.HeroResolution</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredScenes)
                        {
                            <tr>
                                <td><code>S@(r.Scene.ToString("D2"))</code></td>
                                <td class="small">@(string.IsNullOrEmpty(r.Setting) ? "—" : r.Setting)</td>
                                <td class="small text-muted">
                                    @string.Join(", ", r.CharactersOnScreen.Select(ShortChar).Take(3))
                                    @if (!string.IsNullOrEmpty(r.PrimaryLocationId) || r.LocationIds.Count > 0)
                                    {
                                        <div><code>@ShortLoc(r.PrimaryLocationId ?? r.LocationIds.FirstOrDefault() ?? "")</code></div>
                                    }
                                </td>
                                <td class="small">@r.ClipsOnDisk/@r.ClipsTotal</td>
                                <td>@Usd(r.ActualUsd)</td>
                                <td>@Usd(r.SpentUsd)</td>
                                <td class="@(r.RemainingDraftUsd > 0 ? "text-warning" : "")">@Usd(r.RemainingDraftUsd)</td>
                                <td>@Usd(r.HeroUpgradeUsd)</td>
                                <td>@Usd(r.AllDraftUsd)</td>
                                <td>@Usd(r.AllHeroUsd)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (_topRemaining.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header">Highest remaining first-pass costs</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Scene</th>
                            <th>Setting</th>
                            <th>Missing</th>
                            <th>Remaining $</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _topRemaining)
                        {
                            <tr>
                                <td><code>S@(r.Scene.ToString("D2"))</code></td>
                                <td class="small">@r.Setting</td>
                                <td>@r.ClipsMissing</td>
                                <td>@Usd(r.RemainingDraftUsd)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">Recent ledger events</div>
        <div class="card-body p-0">
            @if (_report.RecentEvents.Count == 0)
            {
                <p class="text-muted p-3 mb-0">No ledger events — generate a clip or run Backfill.</p>
            }
            else
            {
                <div class="table-responsive" style="max-height: 320px; overflow: auto;">
                    <table class="table table-sm mb-0">
                        <thead class="sticky-top bg-white">
                            <tr>
                                <th>When</th>
                                <th>Kind</th>
                                <th>S/C</th>
                                <th>Sec</th>
                                <th>Res</th>
                                <th>USD</th>
                                <th>Src</th>
                                <th>Model</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _report.RecentEvents)
                            {
                                <tr>
                                    <td class="small">@(e.Ts ?? "—")</td>
                                    <td><span class="badge bg-secondary">@e.Kind</span></td>
                                    <td class="small">
                                        @if (e.Scene is int sn)
                                        {
                                            <span>S@sn</span>
                                        }
                                        @if (e.Clip is int cn)
                                        {
                                            <span>C@cn</span>
                                        }
                                    </td>
                                    <td class="small">@(e.DurationSec?.ToString("0.#") ?? "—")</td>
                                    <td class="small">@(e.Resolution ?? "—")</td>
                                    <td>@Usd(e.Usd)</td>
                                    <td class="small">@(e.Source ?? "—")</td>
                                    <td class="small">@Trunc(e.Model, 28)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer small text-muted">
            Edit rates under <a href="configuration">Configuration</a> → cost estimates.
            @_report.Notes
        </div>
    </div>
}

@code {
    private bool _busy;
    private string? _error;
    private string? _message;
    private string _projectId = "";
    private List<string> _projectIds = new();
    private string _draftRes = "480p";
    private string _heroRes = "720p";
    private double _retries;
    private string _filter = "all";
    private string _filterCharacter = "";
    private string _filterLocation = "";
    private string _filterText = "";
    private CostReport? _report;
    private string? _cheapestLabel;
    private List<CostSceneRow> _topRemaining = new();

    private bool HasSceneFilters =>
        !string.IsNullOrWhiteSpace(_filterCharacter) ||
        !string.IsNullOrWhiteSpace(_filterLocation) ||
        !string.IsNullOrWhiteSpace(_filterText);

    private List<string> CharacterOptions =>
        _report?.Scenes
            .SelectMany(s => s.CharactersOnScreen)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(ShortChar, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? new List<string>();

    private List<string> LocationOptions =>
        _report?.Scenes
            .SelectMany(s =>
            {
                var list = new List<string>(s.LocationIds);
                if (!string.IsNullOrWhiteSpace(s.PrimaryLocationId))
                    list.Add(s.PrimaryLocationId!);
                return list;
            })
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(ShortLoc, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? new List<string>();

    private IEnumerable<CostSceneRow> FilteredScenes
    {
        get
        {
            if (_report is null) return Enumerable.Empty<CostSceneRow>();
            IEnumerable<CostSceneRow> q = _filter switch
            {
                "with media" => _report.Scenes.Where(r => r.ClipsOnDisk > 0),
                "incomplete" => _report.Scenes.Where(r => r.ClipsMissing > 0),
                _ => _report.Scenes,
            };

            if (!string.IsNullOrWhiteSpace(_filterCharacter))
            {
                q = q.Where(r =>
                    r.CharactersOnScreen.Any(c =>
                        string.Equals(c, _filterCharacter, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(_filterLocation))
            {
                q = q.Where(r =>
                    string.Equals(r.PrimaryLocationId, _filterLocation, StringComparison.OrdinalIgnoreCase) ||
                    r.LocationIds.Any(l =>
                        string.Equals(l, _filterLocation, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(_filterText))
            {
                q = q.Where(r =>
                    (r.Setting ?? "").Contains(_filterText, StringComparison.OrdinalIgnoreCase));
            }

            return q;
        }
    }

    private void ClearSceneFilters()
    {
        _filterCharacter = "";
        _filterLocation = "";
        _filterText = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var projs = await Engine.GetProjectsAsync();
            _projectIds = projs?.Projects.Select(p => p.Id ?? "").Where(s => s.Length > 0).ToList()
                          ?? new List<string>();
            if (projs?.Active?.Id is { Length: > 0 } aid &&
                _projectIds.Exists(id => string.Equals(id, aid, StringComparison.OrdinalIgnoreCase)))
                _projectId = aid;
            else if (_projectIds.Count > 0)
                _projectId = _projectIds[0];
            else
                _projectId = "";

            // Seed draft res from config when possible
            if (!string.IsNullOrEmpty(_projectId))
            {
                try
                {
                    var cfg = await Engine.GetConfigAsync(_projectId);
                    if (cfg?.Config is not null &&
                        cfg.Config.TryGetValue("resolution", out var res) &&
                        res.ValueKind == System.Text.Json.JsonValueKind.String &&
                        res.GetString() is { Length: > 0 } r)
                        _draftRes = r;
                    if (cfg?.Config is not null &&
                        cfg.Config.TryGetValue("cost_estimates", out var ce) &&
                        ce.ValueKind == System.Text.Json.JsonValueKind.Object &&
                        ce.TryGetProperty("assume_avg_retries", out var ar) &&
                        ar.TryGetDouble(out var retries))
                        _retries = retries;
                }
                catch { /* ignore */ }

                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var dto = await Engine.GetCostAsync(_projectId, _draftRes, _heroRes, _retries);
            _report = dto?.Cost;
            if (_report?.Scenarios is { Count: > 0 } sc)
                _cheapestLabel = sc.MinBy(x => x.FullFilmUsd)?.Label;
            _topRemaining = _report?.Scenes
                .Where(r => r.RemainingDraftUsd > 0)
                .OrderByDescending(r => r.RemainingDraftUsd)
                .Take(15)
                .ToList() ?? new List<CostSceneRow>();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _report = null;
        }
        finally { _busy = false; }
    }

    private async Task BackfillAsync()
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            var result = await Engine.BackfillCostAsync(_projectId);
            var b = result?.Backfill;
            _message = b is null
                ? "Backfill done"
                : $"Added {b.Added} events (skipped {b.Skipped}); ledger {b.LedgerEvents}; actual {Usd(b.ActualUsd)}";
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private static string Usd(double v) => $"${v:0.00}";

    private static int ProgressPct(CostReportSummary s) =>
        (int)Math.Round(100.0 * s.ClipsOnDisk / Math.Max(1, s.ClipsTotal));

    private static string Trunc(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= n ? s : s[..(n - 1)] + "…";
    }

    private static string ShortChar(string key) => KeyFormatting.ShortChar(key);

    private static string ShortLoc(string key) => KeyFormatting.ShortLoc(key);
}
