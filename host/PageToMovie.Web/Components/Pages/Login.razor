@page "/login"
@page "/signup"
@inject EngineApiClient Api
@inject AdminSessionService Session
@inject NavigationManager Nav

<PageTitle>@(_isSignup ? "Sign Up" : "Sign In") — PageToMovie</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo d-flex align-items-center justify-content-center gap-3 mb-3">
                <img src="/favicon.png" alt="PageToMovie" width="64" height="64" class="rounded-3 shadow" />
                <span class="logo-text fs-2 fw-bold mb-0">PageToMovie</span>
            </div>
            <p class="auth-subtitle">
                @(_isSignup ? "Create your account to start generating films" : "Sign in to access your film studio projects")
            </p>
        </div>

        <div class="auth-tabs">
            <button type="button" class="tab-btn @(!_isSignup ? "active" : "")" @onclick="() => SetMode(false)">
                Sign In
            </button>
            <button type="button" class="tab-btn @(_isSignup ? "active" : "")" @onclick="() => SetMode(true)">
                Create Account
            </button>
        </div>

        @if (_busy && string.IsNullOrEmpty(_error))
        {
            <div class="auth-status text-center py-4">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
                <p class="text-muted mb-0">@_status</p>
            </div>
        }
        else
        {
            <form class="auth-form" @onsubmit="SubmitAsync">
                <div class="mb-3">
                    <label class="form-label" for="username-input">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input id="username-input" class="form-control" @bind="_username" @bind:event="oninput" placeholder="Enter username" autocomplete="username" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password-input">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input id="password-input" type="@(_showPassword ? "text" : "password")" class="form-control" @bind="_password" @bind:event="oninput" placeholder="Enter password" autocomplete="@(_isSignup ? "new-password" : "current-password")" required />
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => _showPassword = !_showPassword">
                            <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>

                @if (_isSignup)
                {
                    <div class="mb-3">
                        <label class="form-label" for="confirm-password-input">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
                            <input id="confirm-password-input" type="@(_showPassword ? "text" : "password")" class="form-control" @bind="_confirmPassword" @bind:event="oninput" placeholder="Confirm password" autocomplete="new-password" required />
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger d-flex align-items-center py-2" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div>@_error</div>
                    </div>
                }

                <button type="submit" class="btn btn-gradient w-100 py-2 mt-2" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>@(_isSignup ? "Creating account…" : "Signing in…")</span>
                    }
                    else
                    {
                        <span>@(_isSignup ? "Create Account" : "Sign In")</span>
                    }
                </button>
            </form>
        }

        <div class="auth-footer text-center mt-4">
            @if (!_isSignup)
            {
                <span class="text-muted">Don't have an account yet? </span>
                <button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SetMode(true)">
                    Sign up now
                </button>
            }
            else
            {
                <span class="text-muted">Already have an account? </span>
                <button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SetMode(false)">
                    Sign in
                </button>
            }
        </div>
    </div>
</div>

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 8rem);
        padding: 1.5rem;
    }

    .auth-card {
        width: 100%;
        max-width: 26rem;
        background: rgba(22, 27, 34, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 1rem;
        padding: 2.25rem 2rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(16px);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 1.75rem;
    }

    .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .logo-icon {
        font-size: 2rem;
    }

    .logo-text {
        font-family: 'Outfit', sans-serif;
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .auth-subtitle {
        color: #9ca3af;
        font-size: 0.9rem;
        margin: 0;
    }

    .auth-tabs {
        display: flex;
        background: rgba(0, 0, 0, 0.25);
        border-radius: 0.5rem;
        padding: 0.25rem;
        margin-bottom: 1.5rem;
    }

    .tab-btn {
        flex: 1;
        background: transparent;
        border: none;
        color: #9ca3af;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        font-weight: 500;
        border-radius: 0.375rem;
        transition: all 0.2s ease;
    }

    .tab-btn.active {
        background: rgba(99, 102, 241, 0.2);
        color: #ffffff;
        border: 1px solid rgba(99, 102, 241, 0.4);
    }

    .form-label {
        font-size: 0.85rem;
        font-weight: 500;
        color: #d1d5db;
        margin-bottom: 0.35rem;
    }

    .input-group-text {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.15);
        color: #94a3b8;
    }

    .form-control {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.15);
        color: #f8fafc;
    }

    .form-control:focus {
        background: rgba(15, 23, 42, 0.8);
        border-color: #6366f1;
        box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
        color: #ffffff;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        border: none;
        color: #ffffff;
        font-weight: 600;
        border-radius: 0.5rem;
        transition: opacity 0.2s ease, transform 0.1s ease;
    }

    .btn-gradient:hover:not(:disabled) {
        opacity: 0.92;
        transform: translateY(-1px);
        color: #ffffff;
    }

    .btn-gradient:disabled {
        opacity: 0.6;
    }

    .auth-footer {
        font-size: 0.875rem;
    }
</style>

@code {
    private string _username = "";
    private string _password = "";
    private string _confirmPassword = "";
    private bool _isSignup;
    private bool _showPassword;
    private string? _error;
    private string _status = "Checking session…";
    private bool _busy;
    private bool _started;

    protected override void OnInitialized()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        _isSignup = relative.StartsWith("signup", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        try
        {
            await Session.EnsureHydratedAsync();
            if (Session.IsLoggedIn)
            {
                Nav.NavigateTo("/", forceLoad: true);
            }
        }
        catch { /* ignore hydration blip */ }
    }

    private void SetMode(bool isSignup)
    {
        _isSignup = isSignup;
        _error = null;
        if (_isSignup && !Nav.Uri.EndsWith("/signup", StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo("/signup", replace: true);
        else if (!_isSignup && !Nav.Uri.EndsWith("/login", StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo("/login", replace: true);
    }

    private async Task SubmitAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_username) || _username.Trim().Length < 3)
        {
            _error = "Username must be at least 3 characters long.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 4)
        {
            _error = "Password must be at least 4 characters long.";
            return;
        }

        if (_isSignup && _password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _busy = true;
        _status = _isSignup ? "Creating account…" : "Signing in…";
        StateHasChanged();

        try
        {
            var resp = _isSignup
                ? await Api.SignupAsync(_username.Trim(), _password)
                : await Api.LoginAsync(_username.Trim(), _password);

            if (resp is null || !resp.Ok || string.IsNullOrWhiteSpace(resp.Token))
            {
                _error = resp?.Error ?? (_isSignup ? "Sign up failed." : "Sign in failed.");
                return;
            }

            Session.SetSession(resp.Token!, resp.UserId ?? _username.Trim(), resp.Roles, resp.ExpiresAt);
            await Task.Delay(50);
            await Session.EnsureHydratedAsync();

            _status = "Redirecting…";
            StateHasChanged();

            Nav.NavigateTo("/", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
