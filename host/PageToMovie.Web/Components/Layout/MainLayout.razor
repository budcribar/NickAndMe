@inherits LayoutComponentBase
@inject IJSRuntime Js
@inject NavigationManager Nav
@inject EngineApiClient Engine
@inject AdminSessionService Session
@inject IHostEnvironment Env
@using Microsoft.AspNetCore.WebUtilities

<div class="page @(_sidebarCollapsed ? "sidebar-collapsed" : null)">
    <div class="sidebar">
        <div class="sidebar-header">
            @if (!_sidebarCollapsed)
            {
                <a class="navbar-brand sidebar-brand" href="/" title="Film Studio">
                    Film Studio
                </a>
            }
            <button type="button"
                    class="sidebar-toggle"
                    title="@(_sidebarCollapsed ? "Expand menu" : "Collapse menu")"
                    aria-label="@(_sidebarCollapsed ? "Expand menu" : "Collapse menu")"
                    @onclick="ToggleSidebarAsync">
                @(_sidebarCollapsed ? "»" : "«")
            </button>
        </div>
        <NavMenu Collapsed="_sidebarCollapsed" />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _sidebarCollapsed;
    private bool _hydrated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hydrated) return;
        _hydrated = true;
        try
        {
            var v = await Js.InvokeAsync<string?>("localStorage.getItem", "fs.sidebarCollapsed");
            if (string.Equals(v, "1", StringComparison.Ordinal))
            {
                _sidebarCollapsed = true;
                StateHasChanged();
            }
        }
        catch { /* ignore */ }

        // Local/dev: ?admin=1 or ?admin=user:pass bootstraps admin JWT (no login form)
        await TryBootstrapAdminFromQueryAsync();
    }

    /// <summary>
    /// Query string bootstrap for local runs:
    /// <c>?admin=1</c> → admin/admin (dev defaults),
    /// <c>?admin=admin:secret</c> → username:password.
    /// Only when host is localhost / Development.
    /// </summary>
    private async Task TryBootstrapAdminFromQueryAsync()
    {
        try
        {
            await Session.EnsureHydratedAsync();
            if (Session.IsAdmin) return;

            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            if (!IsLocalHost(uri.Host) && !Env.IsDevelopment())
                return;

            if (!QueryHelpers.ParseQuery(uri.Query).TryGetValue("admin", out var vals))
                return;
            var raw = vals.FirstOrDefault()?.Trim() ?? "";
            if (raw.Length == 0) return;

            string user = "admin", pass = "admin";
            if (raw is "1" or "true" or "yes")
            {
                // defaults
            }
            else if (raw.Contains(':'))
            {
                var parts = raw.Split(':', 2);
                user = parts[0].Trim();
                pass = parts[1];
            }
            else
            {
                // single token treated as password for user admin
                pass = raw;
            }

            var login = await Engine.LoginAsync(user, pass);
            if (login?.Ok == true && !string.IsNullOrWhiteSpace(login.Token))
            {
                Session.SetSession(
                    login.Token!,
                    login.UserId ?? user,
                    login.Roles,
                    login.ExpiresAt);
                // Strip query so refresh doesn't re-login; stay on same path
                var clean = uri.GetLeftPart(UriPartial.Path);
                if (!string.IsNullOrEmpty(uri.Fragment))
                    clean += uri.Fragment;
                Nav.NavigateTo(clean, replace: true);
            }
        }
        catch
        {
            // silent — operator can use /admin/login
        }
    }

    private static bool IsLocalHost(string host) =>
        string.Equals(host, "localhost", StringComparison.OrdinalIgnoreCase) ||
        host is "127.0.0.1" or "::1" ||
        host.EndsWith(".local", StringComparison.OrdinalIgnoreCase);

    private async Task ToggleSidebarAsync()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
        try
        {
            await Js.InvokeVoidAsync(
                "localStorage.setItem",
                "fs.sidebarCollapsed",
                _sidebarCollapsed ? "1" : "0");
        }
        catch { /* ignore */ }
    }
}
