@inject AdminSessionService Session
@inject ActiveProjectState ActiveProject
@inject EngineApiClient Engine
@inject ThemeState Theme
@inject IJSRuntime Js
@implements IDisposable

@* Mobile hamburger (desktop collapse is on MainLayout) *@
<input type="checkbox" title="Navigation menu" class="navbar-toggler" id="nav-toggler" />

<div class="nav-scrollable @(Collapsed ? "nav-collapsed" : null)"
     onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="nav flex-column" aria-label="Main">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" title="Studio" data-testid="nav-studio">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                @if (!Collapsed) { <span class="nav-label">Studio</span> }
            </NavLink>
        </div>

        @if (ActiveProject.HasProject)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/adaptation" Match="NavLinkMatch.Prefix" title="Adaptation" data-testid="nav-adaptation">
                    <span class="bi bi-book-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Adaptation</span> }
                </NavLink>
            </div>

            @NavItem(
                enabled: ActiveProject.CanCharacters,
                href: "/characters",
                title: ActiveProject.CanCharacters ? "Characters" : ActiveProject.CharactersBlockedReason,
                iconClass: "bi-people-fill-nav-menu",
                label: "Characters",
                testId: "nav-characters")

            @NavItem(
                enabled: ActiveProject.CanScenes,
                href: "/scenes",
                title: ActiveProject.CanScenes ? "Scenes" : ActiveProject.ScenesBlockedReason,
                iconClass: "bi-film-nav-menu",
                label: "Scenes",
                testId: "nav-scenes")

            @NavItem(
                enabled: ActiveProject.CanReview,
                href: "/review",
                title: ActiveProject.CanReview ? "Review" : ActiveProject.ReviewBlockedReason,
                iconClass: "bi-check2-square-nav-menu",
                label: "Review",
                testId: "nav-review")

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/cost" title="Cost">
                    <span class="bi bi-cash-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Cost</span> }
                </NavLink>
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/configuration" title="Configuration">
                <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span>
                @if (!Collapsed) { <span class="nav-label">Configuration</span> }
            </NavLink>
        </div>

        @if (Session.IsAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin" title="Admin">
                    <span class="bi bi-shield-lock-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Admin</span> }
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/config" title="Admin config">
                    <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Admin config</span> }
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/learning" title="Learning from reviews" data-testid="nav-learning">
                    <span class="bi bi-lightbulb-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Learning</span> }
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/login" title="Admin login">
                    <span class="bi bi-shield-lock-nav-menu" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">Admin login</span> }
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }

    private bool _started;

    private RenderFragment NavItem(bool enabled, string href, string title, string iconClass, string label, string? testId = null) => __builder =>
    {
        <div class="nav-item px-3">
            @if (enabled)
            {
                <NavLink class="nav-link" href="@href" title="@title" data-testid="@testId">
                    <span class="bi @iconClass" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">@label</span> }
                </NavLink>
            }
            else
            {
                <span class="nav-link nav-link-disabled"
                      title="@title"
                      data-testid="@(testId is null ? null : testId + "-disabled")"
                      aria-disabled="true">
                    <span class="bi @iconClass" aria-hidden="true"></span>
                    @if (!Collapsed) { <span class="nav-label">@label</span> }
                </span>
            }
        </div>
    };

    private string? _themedProjectId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;
        await Session.EnsureHydratedAsync();
        Session.Changed += OnSessionChanged;
        ActiveProject.Changed += OnProjectChanged;
        await ActiveProject.RefreshFromApiAsync(Engine);
        await RefreshThemeAsync();
        StateHasChanged();
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    // Readiness is refreshed by RefreshFromApiAsync / callers after Set — only re-render here
    // (RefreshReadinessAsync must not be invoked from Changed or it loops).
    private void OnProjectChanged() => InvokeAsync(async () =>
    {
        await RefreshThemeAsync();
        StateHasChanged();
    });

    /// <summary>Pulls ui_theme from the active project's config and applies it to the DOM.
    /// Cheap no-op re-fetch guarded by project id so it only hits the API on an actual switch.</summary>
    private async Task RefreshThemeAsync()
    {
        var pid = ActiveProject.HasProject ? ActiveProject.ProjectId : null;
        if (string.Equals(pid, _themedProjectId, StringComparison.OrdinalIgnoreCase)) return;
        _themedProjectId = pid;

        var pref = "dark";
        if (pid is { Length: > 0 })
        {
            try
            {
                var dto = await Engine.GetConfigAsync(pid);
                if (dto?.Config is { } cfg &&
                    cfg.TryGetValue("ui_theme", out var el) &&
                    el.ValueKind == System.Text.Json.JsonValueKind.String)
                    pref = el.GetString() ?? "dark";
            }
            catch { /* API blip — keep default */ }
        }

        Theme.Set(pref);
        try { await Js.InvokeVoidAsync("fsTheme.apply", pref); }
        catch { /* prerender / no JS yet */ }
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
        ActiveProject.Changed -= OnProjectChanged;
    }
}
